# Recreate the 4 browser-smoke test users with correct group bindings.
existing = env['res.users'].search([('login', 'in', [
    'p2m75_sales', 'p2m75_mgr', 'p2m75_lead', 'p2m75_crew'
])])
if existing:
    print(f"Removing {len(existing)} existing user(s) (id={existing.ids})")
    # FK guard: drop crew assignments that reference these users first.
    crew_rows = env['commercial.job.crew'].sudo().search([
        ('user_id', 'in', existing.ids),
    ])
    if crew_rows:
        print(f"  cleaning {len(crew_rows)} dependent commercial.job.crew rows")
        crew_rows.unlink()
    # Also drop any mail.activity assigned to these users on commercial.job.
    activities = env['mail.activity'].sudo().search([
        ('user_id', 'in', existing.ids),
    ])
    if activities:
        print(f"  cleaning {len(activities)} mail.activity rows")
        activities.unlink()
    existing.unlink()

g_user = env.ref('neon_jobs.group_neon_jobs_user')
g_manager = env.ref('neon_jobs.group_neon_jobs_manager')
g_crew_leader = env.ref('neon_jobs.group_neon_jobs_crew_leader')
g_crew = env.ref('neon_jobs.group_neon_jobs_crew')
g_internal = env.ref('base.group_user')

users_spec = [
    ('p2m75_sales', 'P2M75 Sales', g_user, 'p2m75_sales@test.local'),
    ('p2m75_mgr', 'P2M75 Manager', g_manager, 'p2m75_mgr@test.local'),
    ('p2m75_lead', 'P2M75 Crew Leader', g_crew_leader, 'p2m75_lead@test.local'),
    ('p2m75_crew', 'P2M75 Crew', g_crew, 'p2m75_crew@test.local'),
]

for login, name, neon_group, email in users_spec:
    user = env['res.users'].create({
        'name': name,
        'login': login,
        'password': 'test123',
        'email': email,
        'groups_id': [(6, 0, [g_internal.id, neon_group.id])],
    })
    print(f"Created {login} (id={user.id})")
    if neon_group in (g_crew_leader, g_crew):
        if g_user in user.groups_id:
            print(f"  WARNING: {login} has neon_jobs_user — removing")
            user.write({'groups_id': [(3, g_user.id)]})

env.cr.commit()
print("All 4 test users created and committed.")

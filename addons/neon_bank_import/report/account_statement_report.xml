<?xml version="1.0" encoding="UTF-8"?>
<!--
  PDF export for the Account-Ledger statement (XLSX is Odoo's native list export).
  Bound to account.move.line so it prints from the statement view's Print menu:
  select the statement rows -> Print -> "Account Statement". Reuses the Stage-1
  computes (neon_counterpart_code, neon_running_balance). Read-only.
-->
<odoo>

    <template id="report_neon_account_statement_doc">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="mb-3">Account Statement</h2>
                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Details</th>
                                <th>Acc Code</th>
                                <th class="text-end">Dr</th>
                                <th class="text-end">Cr</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs.sorted(key=lambda l: (l.date, l.id))" t-as="line">
                                <td><span t-field="line.date"/></td>
                                <td><span t-esc="line.name"/></td>
                                <td><span t-esc="line.neon_counterpart_code"/></td>
                                <td class="text-end">
                                    <span t-esc="line.debit" t-options='{"widget": "monetary", "display_currency": line.company_currency_id}'/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="line.credit" t-options='{"widget": "monetary", "display_currency": line.company_currency_id}'/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="line.neon_running_balance" t-options='{"widget": "monetary", "display_currency": line.company_currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_neon_account_statement" model="ir.actions.report">
        <field name="name">Account Statement</field>
        <field name="model">account.move.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">neon_bank_import.report_neon_account_statement_doc</field>
        <field name="report_file">neon_bank_import.report_neon_account_statement_doc</field>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_type">report</field>
    </record>

</odoo>

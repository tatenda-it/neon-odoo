<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- B11 Programme Status board. Self-contained dark-theme page:
         inline style + script (NO asset bundle, so no asset-cache
         staleness). Rendered by the neon_status controller, which
         prepends the DOCTYPE. -->
    <template id="programme_status_page" name="Neon Programme Status">
        <html lang="en">
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>Neon Events — Programme Status</title>
            <style><![CDATA[
:root{
  --bg:#0f0f17; --bg2:#14141f; --panel:#1b1b2a; --panel2:#202033;
  --border:#2a2a40; --text:#e9e9f3; --muted:#9a9ab4; --faint:#6f6f88;
  --purple:#4752a3; --purple2:#7f60a9; --teal:#2dd4bf; --amber:#f5a524;
  --green:#34d399; --red:#f87171; --grey:#5a5a72;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:radial-gradient(1200px 600px at 15% -10%,#1d1d33 0%,var(--bg) 55%) fixed,var(--bg);
  color:var(--text);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  font-size:15px; line-height:1.5; -webkit-font-smoothing:antialiased;
}
a{color:var(--teal);}
.wrap{max-width:1080px;margin:0 auto;padding:32px 20px 72px;}
.muted{color:var(--muted);}
.faint{color:var(--faint);}

/* ---- header ---- */
.hdr{display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:16px;
  padding-bottom:22px;border-bottom:1px solid var(--border);margin-bottom:30px;}
.hdr h1{margin:0 0 6px;font-size:26px;font-weight:700;letter-spacing:.2px;}
.hdr h1 .brand{background:linear-gradient(90deg,var(--purple2),var(--teal));
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
.hdr .sub{color:var(--muted);font-size:13.5px;max-width:560px;}
.refresh-box{display:flex;flex-direction:column;align-items:flex-end;gap:8px;}
.btn{appearance:none;border:1px solid var(--purple2);cursor:pointer;
  background:linear-gradient(180deg,#4f57a8,#3c3f86);color:#fff;
  padding:10px 16px;border-radius:10px;font-size:14px;font-weight:600;
  box-shadow:0 2px 10px rgba(71,82,163,.35);transition:filter .15s,transform .05s;}
.btn:hover{filter:brightness(1.12);}
.btn:active{transform:translateY(1px);}
.btn:disabled{opacity:.55;cursor:progress;}
.stamp{display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--muted);}
.dot{width:9px;height:9px;border-radius:50%;display:inline-block;background:var(--green);
  box-shadow:0 0 0 0 rgba(52,211,153,.5);}
.dot.ok{background:var(--green);}
.dot.loading{background:var(--amber);animation:pulse 1s infinite;}
.dot.err{background:var(--red);}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(245,165,36,.5);}70%{box-shadow:0 0 0 7px rgba(245,165,36,0);}100%{box-shadow:0 0 0 0 rgba(245,165,36,0);}}

/* ---- section + panels ---- */
section{margin:34px 0;}
.sec-title{font-size:12px;letter-spacing:1.6px;text-transform:uppercase;color:var(--faint);
  font-weight:700;margin:0 0 14px;}
.panel{background:linear-gradient(180deg,var(--panel),var(--bg2));border:1px solid var(--border);
  border-radius:16px;padding:22px;}
.grid{display:grid;gap:16px;}

/* ---- overall / donut ---- */
.overall{display:flex;flex-wrap:wrap;align-items:center;gap:30px;}
.donut{flex:0 0 auto;width:190px;height:190px;position:relative;}
.donut svg{transform:rotate(0deg);}
.donut .pct{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.donut .pct b{font-size:40px;font-weight:800;}
.donut .pct span{font-size:11px;letter-spacing:2px;color:var(--muted);}
.overall-copy{flex:1 1 320px;min-width:280px;}
.overall-copy h2{margin:0 0 10px;font-size:20px;font-weight:700;}
.overall-copy p{margin:0;color:var(--muted);font-size:14px;}

/* ---- track bars ---- */
.bars{margin-top:22px;display:flex;flex-direction:column;gap:14px;}
.bar-row .bar-top{display:flex;justify-content:space-between;font-size:13.5px;margin-bottom:6px;}
.bar-row .bar-top b{font-weight:700;}
.track{height:12px;background:#13131f;border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.bar-fill{height:100%;border-radius:8px;}
.bar-purple{background:linear-gradient(90deg,var(--purple),var(--purple2));}
.bar-teal{background:linear-gradient(90deg,#1aa896,var(--teal));}
.bar-amber{background:linear-gradient(90deg,#c97f12,var(--amber));}

/* ---- WA cards ---- */
.cards{grid-template-columns:repeat(auto-fill,minmax(280px,1fr));}
.card{background:var(--panel2);border:1px solid var(--border);border-radius:14px;padding:16px;}
.card .ct{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px;}
.card .key{font-weight:800;font-size:13px;letter-spacing:.5px;color:var(--teal);}
.card .title{font-weight:600;font-size:14.5px;}
.card .body{color:var(--muted);font-size:13px;margin:8px 0 12px;}
.card .meter{height:7px;background:#13131f;border-radius:6px;overflow:hidden;border:1px solid var(--border);}
.card .meter i{display:block;height:100%;background:linear-gradient(90deg,var(--purple2),var(--teal));}
.card .ct .pct{font-size:13px;font-weight:700;color:var(--muted);}
.pill{font-size:10.5px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;
  padding:3px 9px;border-radius:999px;border:1px solid transparent;}
.state-live{background:rgba(52,211,153,.14);color:var(--green);border-color:rgba(52,211,153,.4);}
.state-active{background:rgba(245,165,36,.14);color:var(--amber);border-color:rgba(245,165,36,.4);}
.state-verifying{background:rgba(96,165,250,.16);color:#7db3ff;border-color:rgba(96,165,250,.42);}
.state-roadmap{background:rgba(122,122,150,.14);color:#aeaecb;border-color:rgba(122,122,150,.35);}
.note{font-size:12.5px;color:var(--faint);margin:0 0 14px;font-style:italic;}

/* ---- track milestones ---- */
.mile{border-left:3px solid var(--border);padding:2px 0 2px 16px;margin-bottom:18px;}
.mile.purple{border-left-color:var(--purple2);}
.mile.teal{border-left-color:var(--teal);}
.mile.amber{border-left-color:var(--amber);}
.mile h3{margin:0 0 8px;font-size:15.5px;font-weight:700;display:flex;justify-content:space-between;}
.mile h3 .p{color:var(--muted);font-weight:700;}
.mile .ln{font-size:13.5px;margin:4px 0;color:var(--muted);}
.mile .ln b{color:var(--text);font-weight:600;}

/* ---- live from prod ---- */
.live-grid{grid-template-columns:repeat(auto-fit,minmax(220px,1fr));}
.live-card{background:var(--panel2);border:1px solid var(--border);border-radius:14px;padding:16px;}
.live-card .lc-h{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--faint);font-weight:700;margin-bottom:12px;}
.kv-list{display:flex;flex-direction:column;gap:8px;}
.kv{display:flex;justify-content:space-between;align-items:center;gap:10px;font-size:13.5px;}
.kv-k{color:var(--muted);font-family:ui-monospace,Menlo,Consolas,monospace;}
.kv-v{display:flex;align-items:center;gap:8px;}
.ver{font-family:ui-monospace,Menlo,Consolas,monospace;font-weight:700;}
.dot-state{font-size:10px;padding:2px 7px;border-radius:999px;text-transform:lowercase;}
.dot-state.s-installed{background:rgba(52,211,153,.14);color:var(--green);}
.dot-state.s-to_upgrade,.dot-state.s-to_install{background:rgba(245,165,36,.14);color:var(--amber);}
.big-stat{display:flex;flex-direction:column;align-items:flex-start;gap:2px;}
.bs-num{font-size:34px;font-weight:800;line-height:1;background:linear-gradient(90deg,var(--purple2),var(--teal));
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
.bs-lbl{font-size:12.5px;color:var(--muted);}
.chips{display:flex;flex-wrap:wrap;gap:6px;}
.chip{font-family:ui-monospace,Menlo,Consolas,monospace;font-size:11.5px;padding:3px 8px;border-radius:7px;
  background:#13131f;border:1px solid var(--border);}
.chip.wl-executed{border-color:rgba(52,211,153,.5);color:var(--green);}
.chip.wl-cancelled,.chip.wl-expired{border-color:var(--grey);color:#aeaecb;}
.chip.wl-error{border-color:rgba(248,113,113,.5);color:var(--red);}
.chip.wl-proposed,.chip.wl-confirmed{border-color:rgba(245,165,36,.5);color:var(--amber);}

/* ---- governance lists ---- */
.list-cols{grid-template-columns:repeat(auto-fit,minmax(300px,1fr));}
.glist h4{margin:0 0 12px;font-size:14px;font-weight:700;display:flex;align-items:center;gap:8px;}
.glist h4 .tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px;}
.tag.done{background:rgba(52,211,153,.14);color:var(--green);}
.tag.decided{background:rgba(245,165,36,.14);color:var(--amber);}
.tag.parked{background:rgba(122,122,150,.16);color:#aeaecb;}
.glist ul{margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:9px;}
.glist li{font-size:13px;color:var(--muted);padding-left:18px;position:relative;}
.glist li:before{content:"";position:absolute;left:0;top:7px;width:7px;height:7px;border-radius:50%;background:var(--purple2);}
.glist.g-done li:before{background:var(--green);}
.glist.g-decided li:before{background:var(--amber);}
.glist.g-parked li:before{background:var(--grey);}

.foot{margin-top:48px;padding-top:18px;border-top:1px solid var(--border);
  font-size:12px;color:var(--faint);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;}
            ]]></style>
        </head>
        <body>
        <div class="wrap">

            <!-- ============ 1. HEADER ============ -->
            <div class="hdr">
                <div>
                    <h1>Neon Events — <span class="brand">Programme Status</span></h1>
                    <div class="sub">B11 WhatsApp Assistant · live read from
                        crm.neonhiring.com <span class="faint">(prod, read-only)</span></div>
                </div>
                <div class="refresh-box">
                    <button id="sv-refresh" class="btn" type="button">↻ Refresh live status</button>
                    <div class="stamp">
                        <span id="sv-dot" class="dot ok"></span>
                        <span>Last read: <span id="sv-timestamp" t-esc="live['generated_at_display']"/></span>
                    </div>
                </div>
            </div>

            <!-- ============ 2. OVERALL PROGRESS ============ -->
            <section>
                <p class="sec-title">Overall progress</p>
                <div class="panel">
                    <div class="overall">
                        <t t-set="circ" t-value="round(2 * 3.141592653589793 * 80, 2)"/>
                        <t t-set="dash_off" t-value="round(circ * (1 - overall_pct / 100.0), 2)"/>
                        <div class="donut">
                            <svg width="190" height="190" viewBox="0 0 200 200">
                                <defs>
                                    <linearGradient id="donutGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#7f60a9"/>
                                        <stop offset="100%" stop-color="#2dd4bf"/>
                                    </linearGradient>
                                </defs>
                                <circle cx="100" cy="100" r="80" fill="none" stroke="#23233a" stroke-width="18"/>
                                <circle cx="100" cy="100" r="80" fill="none" stroke="url(#donutGrad)"
                                        stroke-width="18" stroke-linecap="round"
                                        t-att-stroke-dasharray="circ"
                                        t-att-stroke-dashoffset="dash_off"
                                        transform="rotate(-90 100 100)"/>
                            </svg>
                            <div class="pct"><b><t t-esc="overall_pct"/>%</b><span>OVERALL</span></div>
                        </div>
                        <div class="overall-copy">
                            <h2><t t-esc="overall_pct"/>% complete across three tracks</h2>
                            <p>By milestone count, reflecting WA-0–WA-11 complete (WA-9 in
                                final verification). Core platform
                                near-done with the LMS track closed; HR well advanced; the AI
                                module's active scope tightened — Drive dropped and the
                                mobile/QR/predictive arm deferred — leaving WhatsApp (B11) as
                                the live frontier.</p>
                        </div>
                    </div>
                    <div class="bars">
                        <t t-foreach="tracks" t-as="tr">
                            <div class="bar-row">
                                <div class="bar-top">
                                    <span t-esc="tr['name']"/>
                                    <b t-esc="str(tr['pct']) + '%'"/>
                                </div>
                                <div class="track">
                                    <div t-attf-class="bar-fill bar-#{tr['accent']}"
                                         t-attf-style="width:#{tr['pct']}%;"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </section>

            <!-- ============ 3. B11 WHATSAPP BREAKDOWN ============ -->
            <section>
                <p class="sec-title">B11 WhatsApp — module breakdown (inside AI Equipment Module)</p>
                <p class="note">WA-0 through WA-11 all live &amp; verified on prod (WA-9 client
                    contact-matching in final verification) — the phone-native ops cycle
                    (crew select → finalize → checkout → check-in) is proven end-to-end on real
                    phones; sales availability (Face 1) is live; and the client lane now CRM-matches
                    contacts (WA-9), the post-event feedback loop closes to staff (WA-10), and the
                    manager insights layer reads the feedback corpus (WA-11).</p>
                <div class="grid cards">
                    <t t-foreach="wa_modules" t-as="m">
                        <div class="card">
                            <div class="ct">
                                <span class="key" t-esc="m['key']"/>
                                <span t-attf-class="pill state-#{m['state']}"
                                      t-esc="'Live' if m['state'] == 'live' else ('In progress' if m['state'] == 'active' else ('In verification' if m['state'] == 'verifying' else 'Roadmap'))"/>
                            </div>
                            <div class="title" t-esc="m['title']"/>
                            <div class="body" t-esc="m['body']"/>
                            <div class="ct">
                                <div class="meter" style="flex:1;">
                                    <i t-attf-style="width:#{m['pct']}%;"/>
                                </div>
                                <span class="pct" t-esc="str(m['pct']) + '%'"/>
                            </div>
                        </div>
                    </t>
                </div>
            </section>

            <!-- ============ 4. TRACK MILESTONES ============ -->
            <section>
                <p class="sec-title">Track milestones (real items)</p>
                <div class="panel">
                    <t t-foreach="track_milestones" t-as="tm">
                        <div t-attf-class="mile #{tm['accent']}">
                            <h3><span t-esc="tm['name']"/><span class="p" t-esc="str(tm['pct']) + '%'"/></h3>
                            <div class="ln"><b>Live:</b> <t t-esc="tm['live']"/></div>
                            <div class="ln"><b>Remaining:</b> <t t-esc="tm['remaining']"/></div>
                        </div>
                    </t>
                </div>
            </section>

            <!-- ============ 5. LIVE FROM PROD ============ -->
            <section>
                <p class="sec-title">Live from prod <span class="faint">· read-only, refreshed on demand</span></p>
                <div class="grid live-grid">
                    <div class="live-card">
                        <div class="lc-h">Module versions</div>
                        <div id="sv-modules" class="kv-list">
                            <t t-foreach="live['module_versions']" t-as="mv">
                                <div class="kv">
                                    <span class="kv-k" t-esc="mv['name']"/>
                                    <span class="kv-v">
                                        <span class="ver" t-esc="mv['version']"/>
                                        <span t-attf-class="dot-state s-#{mv['state']}" t-esc="mv['state']"/>
                                    </span>
                                </div>
                            </t>
                        </div>
                    </div>
                    <div class="live-card">
                        <div class="lc-h">Bot users (active / total)</div>
                        <div id="sv-bot" class="big-stat">
                            <span class="bs-num"><t t-esc="live['bot_users']['active']"/>/<t t-esc="live['bot_users']['total']"/></span>
                            <span class="bs-lbl">mapped WhatsApp team members</span>
                        </div>
                    </div>
                    <div class="live-card">
                        <div class="lc-h">WhatsApp messages</div>
                        <div id="sv-wa" class="big-stat">
                            <span class="bs-num"><t t-esc="live['whatsapp']['canonical']"/>/<t t-esc="live['whatsapp']['total']"/></span>
                            <span class="bs-lbl">canonical (E.164) of total</span>
                        </div>
                    </div>
                    <div class="live-card">
                        <div class="lc-h">AI Copilot write-log (id : status)</div>
                        <div id="sv-writelog" class="chips">
                            <t t-foreach="live['write_log']" t-as="wl">
                                <span t-attf-class="chip wl-#{wl['status']}"><t t-esc="wl['id']"/>:<t t-esc="wl['status']"/></span>
                            </t>
                            <t t-if="not live['write_log']">
                                <span class="muted">No write-log entries.</span>
                            </t>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============ 6. GOVERNANCE LISTS ============ -->
            <section>
                <p class="sec-title">Programme governance</p>
                <div class="grid list-cols">
                    <div class="live-card glist g-done">
                        <h4>Done &amp; verified on prod <span class="tag done" t-esc="str(len(done_verified))"/></h4>
                        <ul>
                            <t t-foreach="done_verified" t-as="d"><li t-esc="d"/></t>
                        </ul>
                    </div>
                    <div class="live-card glist g-decided">
                        <h4>Decided · not yet built <span class="tag decided" t-esc="str(len(decided_not_built))"/></h4>
                        <ul>
                            <t t-foreach="decided_not_built" t-as="d"><li t-esc="d"/></t>
                        </ul>
                    </div>
                    <div class="live-card glist g-parked">
                        <h4>Parked / backlog <span class="tag parked" t-esc="str(len(parked_backlog))"/></h4>
                        <ul>
                            <t t-foreach="parked_backlog" t-as="d"><li t-esc="d"/></t>
                        </ul>
                    </div>
                </div>
            </section>

            <div class="foot">
                <span>Neon Events Elements · Programme Status board (B11)</span>
                <span>Percentages are a planning judgment · only the “Live from prod” box reads real-time.</span>
            </div>

        </div>

        <script><![CDATA[
(function(){
  function esc(s){
    return String(s).replace(/[&<>"']/g,function(c){
      return {"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c];
    });
  }
  function renderModules(list){
    return (list||[]).map(function(m){
      return '<div class="kv"><span class="kv-k">'+esc(m.name)+
        '</span><span class="kv-v"><span class="ver">'+esc(m.version)+
        '</span><span class="dot-state s-'+esc(m.state)+'">'+esc(m.state)+
        '</span></span></div>';
    }).join("");
  }
  function renderWriteLog(list){
    if(!list || !list.length){ return '<span class="muted">No write-log entries.</span>'; }
    return list.map(function(w){
      return '<span class="chip wl-'+esc(w.status)+'">'+esc(w.id)+":"+esc(w.status)+'</span>';
    }).join("");
  }
  function apply(live){
    document.getElementById("sv-modules").innerHTML = renderModules(live.module_versions);
    document.getElementById("sv-bot").innerHTML =
      '<span class="bs-num">'+esc(live.bot_users.active)+"/"+esc(live.bot_users.total)+
      '</span><span class="bs-lbl">mapped WhatsApp team members</span>';
    document.getElementById("sv-wa").innerHTML =
      '<span class="bs-num">'+esc(live.whatsapp.canonical)+"/"+esc(live.whatsapp.total)+
      '</span><span class="bs-lbl">canonical (E.164) of total</span>';
    document.getElementById("sv-writelog").innerHTML = renderWriteLog(live.write_log);
    document.getElementById("sv-timestamp").textContent = live.generated_at_display || "";
  }
  function setDot(state){
    var d = document.getElementById("sv-dot");
    if(d){ d.className = "dot " + state; }
  }
  function refresh(){
    var btn = document.getElementById("sv-refresh");
    if(btn){ btn.disabled = true; }
    setDot("loading");
    fetch("/neon/status/data",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      credentials:"same-origin",
      body: JSON.stringify({jsonrpc:"2.0", method:"call", params:{}})
    }).then(function(r){ return r.json(); }).then(function(json){
      var data = json && json.result;
      if(!data || !data.ok){ setDot("err"); if(btn){btn.disabled=false;} return; }
      apply(data.live);
      setDot("ok");
      if(btn){ btn.disabled = false; }
    }).catch(function(){
      setDot("err");
      if(btn){ btn.disabled = false; }
    });
  }
  document.addEventListener("DOMContentLoaded", function(){
    var btn = document.getElementById("sv-refresh");
    if(btn){ btn.addEventListener("click", refresh); }
  });
})();
            ]]></script>
        </body>
        </html>
    </template>

    <!-- Access-denied page (portal/public or outside the audience gate). -->
    <template id="programme_status_denied" name="Programme Status — no access">
        <html lang="en">
        <head>
            <meta charset="utf-8"/>
            <title>Neon Events — Programme Status</title>
            <style><![CDATA[
body{margin:0;background:#0f0f17;color:#e9e9f3;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
  display:flex;align-items:center;justify-content:center;min-height:100vh;text-align:center;}
.box{max-width:460px;padding:32px;border:1px solid #2a2a40;border-radius:16px;background:#1b1b2a;}
.box h1{font-size:20px;margin:0 0 10px;}
.box p{color:#9a9ab4;font-size:14px;margin:0 0 18px;}
.box a{color:#2dd4bf;text-decoration:none;font-weight:600;}
            ]]></style>
        </head>
        <body>
            <div class="box">
                <h1>Programme Status</h1>
                <p>This board is available to Neon internal users only. Your account
                    does not have access.</p>
                <a href="/web">← Back to Odoo</a>
            </div>
        </body>
        </html>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- 2F learning-loop cron STUBS. Both ship active=False (INERT). Hard
         data-gated: do not activate until substantial post-cutover outcome
         history exists AND the #2 intel boards are rebuilt on live data. -->
    <record id="ir_cron_neon_winloss_loop" model="ir.cron">
        <field name="name">Neon Learning: Win/Loss Loop (STUB - INACTIVE)</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._cron_neon_winloss_loop()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="active" eval="False"/>
    </record>
    <record id="ir_cron_neon_learning_loops_other" model="ir.cron">
        <field name="name">Neon Learning: Other Loops (STUB - INACTIVE)</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._cron_neon_learning_loops_other()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active" eval="False"/>
    </record>
</odoo>

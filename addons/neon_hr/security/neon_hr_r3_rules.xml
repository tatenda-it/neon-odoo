<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <!--
        R3a confidentiality (Q28 pattern): driver licences and employee
        competencies are sensitive — visible to OD/MD
        (group_neon_superuser), HR Admin (group_neon_hr_admin) and the
        record OWNER only. Same OR-rule combination as R1a/R1b/R2;
        perm_unlink=0 everywhere. The competency CATALOG
        (neon.hr.competency) and the role->competency MAP
        (neon.hr.role.competency) are config, not personal data — left
        internal-readable via ACL, no record rule.
    -->
    <data>
        <!-- ===== owner-only read (base.group_user) ===== -->
        <record id="rule_licence_own" model="ir.rule">
            <field name="name">Licence: owner sees own</field>
            <field name="model_id" ref="model_neon_hr_licence"/>
            <field name="domain_force">[('employee_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        <record id="rule_emp_competency_own" model="ir.rule">
            <field name="name">Employee Competency: owner sees own</field>
            <field name="model_id" ref="model_neon_hr_employee_competency"/>
            <field name="domain_force">[('employee_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===== OD/MD + HR Admin: full (read/write/create, no unlink) ===== -->
        <record id="rule_licence_all" model="ir.rule">
            <field name="name">Licence: OD/MD/Admin see all</field>
            <field name="model_id" ref="model_neon_hr_licence"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('neon_core.group_neon_superuser'), ref('neon_hr.group_neon_hr_admin')])]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        <record id="rule_emp_competency_all" model="ir.rule">
            <field name="name">Employee Competency: OD/MD/Admin see all</field>
            <field name="model_id" ref="model_neon_hr_employee_competency"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('neon_core.group_neon_superuser'), ref('neon_hr.group_neon_hr_admin')])]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>

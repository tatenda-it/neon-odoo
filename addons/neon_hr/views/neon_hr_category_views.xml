<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_neon_hr_category_tree" model="ir.ui.view">
        <field name="model">neon.hr.category</field>
        <field name="arch" type="xml">
            <tree string="Employee Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="default_pay_type"/>
                <field name="required_document_count" string="# Required Docs"/>
                <field name="notice_period_days"/>
                <field name="notice_flagged_for_legal"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_hr_category_form" model="ir.ui.view">
        <field name="model">neon.hr.category</field>
        <field name="arch" type="xml">
            <form string="Employee Category">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Category name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_pay_type"/>
                            <field name="notice_period_days"/>
                            <field name="notice_flagged_for_legal"/>
                        </group>
                    </group>
                    <group string="Required Documents">
                        <field name="required_document_type_ids" nolabel="1"
                               widget="many2many_tags"/>
                    </group>
                    <group string="Notes">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_neon_hr_category" model="ir.actions.act_window">
        <field name="name">Employee Categories</field>
        <field name="res_model">neon.hr.category</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

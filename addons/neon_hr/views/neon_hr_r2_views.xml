<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ ACCIDENT / NSSA ============ -->
    <record id="view_neon_hr_accident_tree" model="ir.ui.view">
        <field name="model">neon.hr.accident</field>
        <field name="arch" type="xml">
            <tree string="Workplace Accidents" decoration-danger="state in ('captured','reviewed') and days_to_deadline &lt; 0"
                  decoration-warning="state in ('captured','reviewed')" decoration-success="state == 'nssa_submitted'">
                <field name="employee_id"/>
                <field name="accident_date"/>
                <field name="reporting_deadline"/>
                <field name="days_to_deadline"/>
                <field name="state" widget="badge"/>
                <field name="penalty_risk"/>
            </tree>
        </field>
    </record>
    <record id="view_neon_hr_accident_form" model="ir.ui.view">
        <field name="model">neon.hr.accident</field>
        <field name="arch" type="xml">
            <form string="Workplace Accident">
                <header>
                    <button name="action_review" type="object" string="Review (OD/MD)"
                            class="btn-primary" invisible="state != 'captured'"/>
                    <button name="action_nssa_submit" type="object" string="Record NSSA Submission"
                            class="btn-primary" invisible="state not in ('captured','reviewed')"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state != 'nssa_submitted'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="accident_date"/>
                            <field name="reporting_deadline"/>
                            <field name="days_to_deadline"/>
                        </group>
                        <group string="NSSA Submission">
                            <field name="nssa_submission_ref"/>
                            <field name="nssa_submitted_date"/>
                            <field name="nssa_proof_attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="injury_description"/>
                        <field name="witnesses"/>
                    </group>
                    <group string="NSSA Penalty (advisory only — figure pending finance/legal)">
                        <field name="penalty_risk"/>
                        <field name="penalty_note" placeholder="Advisory note only — do NOT enter a calculated penalty."/>
                    </group>
                    <group string="Evidence">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <div class="oe_chatter"><field name="message_ids"/></div>
            </form>
        </field>
    </record>
    <record id="action_neon_hr_accident" model="ir.actions.act_window">
        <field name="name">Workplace Accidents</field>
        <field name="res_model">neon.hr.accident</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============ CASE (disciplinary etc.) ============ -->
    <record id="view_neon_hr_case_tree" model="ir.ui.view">
        <field name="model">neon.hr.case</field>
        <field name="arch" type="xml">
            <tree string="HR Cases" decoration-danger="severity in ('high','critical')">
                <field name="employee_id"/>
                <field name="case_type"/>
                <field name="subject"/>
                <field name="severity"/>
                <field name="absence_flow"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_neon_hr_case_form" model="ir.ui.view">
        <field name="model">neon.hr.case</field>
        <field name="arch" type="xml">
            <form string="HR Case">
                <header>
                    <button name="action_open" type="object" string="Open" invisible="state != 'draft'"/>
                    <button name="action_resolve" type="object" string="Resolve" invisible="state not in ('draft','in_progress')"/>
                    <button name="action_close" type="object" string="Close" invisible="state != 'resolved'"/>
                    <button name="action_escalate_line_manager" type="object" string="Escalate: Line Manager"
                            invisible="absence_flow != 'not_applicable' or not event_job_id"/>
                    <button name="action_escalate_disciplinary" type="object" string="Escalate: Disciplinary"
                            invisible="absence_flow != 'escalated_line_manager'"/>
                    <button name="action_od_clear" type="object" string="OD Clear (resume allocation)"
                            class="btn-primary" invisible="absence_flow not in ('escalated_line_manager','escalated_disciplinary')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="case_type"/>
                            <field name="severity"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="reported_by_id"/>
                            <field name="handled_by_id"/>
                            <field name="event_job_id"/>
                            <field name="absence_flow"/>
                        </group>
                    </group>
                    <group>
                        <field name="subject"/>
                        <field name="description"/>
                        <field name="outcome"/>
                    </group>
                    <group string="Evidence">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <div class="oe_chatter"><field name="message_ids"/></div>
            </form>
        </field>
    </record>
    <record id="action_neon_hr_case" model="ir.actions.act_window">
        <field name="name">HR Cases</field>
        <field name="res_model">neon.hr.case</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============ OVERTIME / TOIL ============ -->
    <record id="view_neon_hr_overtime_tree" model="ir.ui.view">
        <field name="model">neon.hr.overtime</field>
        <field name="arch" type="xml">
            <tree string="Overtime / TOIL" decoration-success="state == 'approved'">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="hours" sum="Hours"/>
                <field name="resolution"/>
                <field name="event_job_id" optional="hide"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_neon_hr_overtime_form" model="ir.ui.view">
        <field name="model">neon.hr.overtime</field>
        <field name="arch" type="xml">
            <form string="Overtime / TOIL">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="date"/>
                            <field name="hours"/>
                        </group>
                        <group>
                            <field name="resolution"/>
                            <field name="event_job_id"/>
                            <field name="toil_allocation_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
                <div class="oe_chatter"><field name="message_ids"/></div>
            </form>
        </field>
    </record>
    <record id="action_neon_hr_overtime" model="ir.actions.act_window">
        <field name="name">Overtime / TOIL</field>
        <field name="res_model">neon.hr.overtime</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============ HANDBOOK ============ -->
    <record id="view_neon_hr_handbook_tree" model="ir.ui.view">
        <field name="model">neon.hr.handbook</field>
        <field name="arch" type="xml">
            <tree string="Handbook Versions" decoration-success="is_current">
                <field name="name"/>
                <field name="version"/>
                <field name="publish_date"/>
                <field name="is_current"/>
                <field name="ack_count" string="# Acknowledged"/>
            </tree>
        </field>
    </record>
    <record id="view_neon_hr_handbook_form" model="ir.ui.view">
        <field name="model">neon.hr.handbook</field>
        <field name="arch" type="xml">
            <form string="Handbook Version">
                <header>
                    <button name="action_acknowledge" type="object" string="I Acknowledge"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="version"/>
                        </group>
                        <group>
                            <field name="publish_date"/>
                            <field name="is_current"/>
                            <field name="ack_count"/>
                        </group>
                    </group>
                    <group string="Document">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                    <field name="ack_ids">
                        <tree>
                            <field name="employee_id"/>
                            <field name="state" widget="badge"/>
                            <field name="acknowledged_date"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_neon_hr_handbook" model="ir.actions.act_window">
        <field name="name">Handbook</field>
        <field name="res_model">neon.hr.handbook</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_neon_hr_handbook_pending" model="ir.actions.act_window">
        <field name="name">Handbook — Not Acknowledged</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('handbook_ack_pending', '=', True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Everyone has acknowledged the current handbook.</p>
            <p>Employees who have not acknowledged the current handbook version appear here.</p>
        </field>
    </record>

    <!-- Employee form: surface the handbook compliance flag -->
    <record id="view_employee_form_neon_hr_r2" model="ir.ui.view">
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="neon_hr.view_employee_form_neon_hr"/>
        <field name="arch" type="xml">
            <field name="is_compliant" position="after">
                <field name="handbook_ack_pending"/>
            </field>
        </field>
    </record>
</odoo>

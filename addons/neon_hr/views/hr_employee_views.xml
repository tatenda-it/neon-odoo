<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee form: add a Neon HR / Compliance page. -->
    <record id="view_employee_form_neon_hr" model="ir.ui.view">
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Neon HR" name="neon_hr">
                    <group>
                        <group string="Classification">
                            <field name="neon_category_id"/>
                            <field name="neon_employment_status"/>
                        </group>
                        <group string="Statutory (Zimbabwe)">
                            <field name="nssa_number"/>
                            <field name="zimra_tin"/>
                        </group>
                    </group>
                    <group>
                        <group string="Compliance">
                            <field name="is_compliant"/>
                            <field name="compliance_summary"/>
                            <field name="document_count"/>
                        </group>
                        <group string="Assignment Gate (Q6)">
                            <field name="has_valid_contract"/>
                            <field name="assignment_override"/>
                            <button name="action_assignment_gate" type="object"
                                    string="Check Assignability" class="btn-secondary"/>
                            <button name="action_override_assignment" type="object"
                                    string="Override (OD/MD)" class="btn-warning"
                                    confirm="Override the assignment soft-block? This is an OD/MD decision."
                                    invisible="assignment_override"/>
                        </group>
                    </group>
                    <group>
                        <button name="action_generate_checklist" type="object"
                                string="Generate Document Checklist" class="btn-primary"
                                invisible="not neon_category_id"/>
                    </group>
                    <field name="document_ids">
                        <tree editable="bottom"
                              decoration-danger="state == 'expired'"
                              decoration-warning="state == 'missing'"
                              decoration-success="state == 'provided'">
                            <field name="document_type_id"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'provided'"
                                   decoration-danger="state == 'expired'"
                                   decoration-warning="state == 'missing'"/>
                            <field name="requires_expiry" column_invisible="1"/>
                            <field name="expiry_date"
                                   readonly="not requires_expiry"/>
                            <field name="attachment_count" string="# Files"/>
                            <field name="notes"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Employee tree: surface category + compliance at a glance. -->
    <record id="view_employee_tree_neon_hr" model="ir.ui.view">
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="neon_category_id" optional="show"/>
                <field name="is_compliant" optional="show" widget="boolean_toggle"/>
            </field>
        </field>
    </record>
</odoo>

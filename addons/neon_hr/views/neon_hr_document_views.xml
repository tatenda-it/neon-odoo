<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===== Document Type catalog ===== -->
    <record id="view_neon_hr_document_type_tree" model="ir.ui.view">
        <field name="model">neon.hr.document.type</field>
        <field name="arch" type="xml">
            <tree string="Document Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="requires_expiry"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_hr_document_type_form" model="ir.ui.view">
        <field name="model">neon.hr.document.type</field>
        <field name="arch" type="xml">
            <form string="Document Type">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="requires_expiry"/>
                        <field name="active"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_neon_hr_document_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">neon.hr.document.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ===== Employee Documents (checklist rows) ===== -->
    <record id="view_neon_hr_document_tree" model="ir.ui.view">
        <field name="model">neon.hr.document</field>
        <field name="arch" type="xml">
            <tree string="Employee Documents" decoration-danger="state == 'expired'"
                  decoration-warning="state == 'missing'"
                  decoration-success="state == 'provided'">
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'provided'"
                       decoration-danger="state == 'expired'"
                       decoration-warning="state == 'missing'"/>
                <field name="requires_expiry" optional="hide"/>
                <field name="expiry_date"/>
                <field name="attachment_count" string="# Files"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_hr_document_form" model="ir.ui.view">
        <field name="model">neon.hr.document</field>
        <field name="arch" type="xml">
            <form string="Employee Document">
                <sheet>
                    <widget name="web_ribbon" title="Expired" bg_color="text-bg-danger"
                            invisible="state != 'expired'"/>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="document_type_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="requires_expiry"/>
                            <field name="expiry_date"
                                   invisible="not requires_expiry"/>
                        </group>
                    </group>
                    <group string="Files">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_neon_hr_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">neon.hr.document</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

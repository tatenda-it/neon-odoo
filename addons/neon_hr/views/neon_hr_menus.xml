<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Menus live under the native HR app root (hr.menu_hr_root),
        which is itself gated by hr groups — so only HR Admin / OD/MD
        (the holders of an hr group) reach them. Confidentiality of
        record CONTENT is enforced by record rules, not by these menus
        (Q28).
    -->
    <menuitem id="menu_neon_hr_root"
              name="Neon HR"
              parent="hr.menu_hr_root"
              sequence="90"/>

    <menuitem id="menu_neon_hr_contracts_expiring"
              name="Contracts Expiring / Expired"
              parent="menu_neon_hr_root"
              action="action_neon_hr_contracts_expiring"
              sequence="10"/>

    <menuitem id="menu_neon_hr_documents"
              name="Employee Documents"
              parent="menu_neon_hr_root"
              action="action_neon_hr_document"
              sequence="20"/>

    <menuitem id="menu_neon_hr_config"
              name="Configuration"
              parent="menu_neon_hr_root"
              sequence="90"/>

    <menuitem id="menu_neon_hr_categories"
              name="Employee Categories"
              parent="menu_neon_hr_config"
              action="action_neon_hr_category"
              sequence="10"/>

    <menuitem id="menu_neon_hr_document_types"
              name="Document Types"
              parent="menu_neon_hr_config"
              action="action_neon_hr_document_type"
              sequence="20"/>

    <menuitem id="menu_neon_hr_contract_templates"
              name="Contract Templates"
              parent="menu_neon_hr_config"
              action="action_neon_hr_contract_template"
              sequence="30"/>

    <!-- ===== R1b-1: leave / availability ===== -->
    <menuitem id="menu_neon_hr_availability"
              name="Crew Availability (Leave)"
              parent="menu_neon_hr_root"
              action="action_neon_hr_availability"
              sequence="25"/>

    <!-- ===== R1b-2: payroll ===== -->
    <menuitem id="menu_neon_hr_payroll" name="Payroll"
              parent="menu_neon_hr_root" sequence="40"/>
    <menuitem id="menu_neon_hr_payslips" name="Payslips"
              parent="menu_neon_hr_payroll"
              action="action_neon_hr_payslip" sequence="10"/>
    <menuitem id="menu_neon_hr_event_wages" name="Event Wages"
              parent="menu_neon_hr_payroll"
              action="action_neon_hr_event_wage" sequence="20"/>
    <menuitem id="menu_neon_hr_commissions" name="Commissions"
              parent="menu_neon_hr_payroll"
              action="action_neon_hr_commission" sequence="30"/>
    <menuitem id="menu_neon_hr_loans" name="Staff Loans"
              parent="menu_neon_hr_payroll"
              action="action_neon_hr_loan" sequence="40"/>
    <menuitem id="menu_neon_hr_statutory" name="Statutory Rules"
              parent="menu_neon_hr_config"
              action="action_neon_hr_statutory" sequence="40"/>
    <menuitem id="menu_neon_hr_wage_grades" name="Freelance Wage Grades"
              parent="menu_neon_hr_config"
              action="action_neon_hr_wage_grade" sequence="50"/>

    <!-- ===== R2: safety / conduct / handbook ===== -->
    <menuitem id="menu_neon_hr_safety" name="Safety &amp; Conduct"
              parent="menu_neon_hr_root" sequence="50"/>
    <menuitem id="menu_neon_hr_accidents" name="Workplace Accidents"
              parent="menu_neon_hr_safety"
              action="action_neon_hr_accident" sequence="10"/>
    <menuitem id="menu_neon_hr_cases" name="Cases (Disciplinary / Incident / etc.)"
              parent="menu_neon_hr_safety"
              action="action_neon_hr_case" sequence="20"/>
    <!-- R3b C4 — TOIL retired per OD/MD (overtime is incentive
         covered; the workflow stays in the codebase but is hidden
         from menus + records active=False'd. To re-enable, drop
         the groups attribute below and run the post-migrate's
         reverse step manually. Data is preserved (perm_unlink=0
         + active=False, not unlink) for audit. -->
    <menuitem id="menu_neon_hr_overtime" name="Overtime / TOIL [retired]"
              parent="menu_neon_hr_safety"
              action="action_neon_hr_overtime" sequence="30"
              groups="base.group_no_one"/>
    <menuitem id="menu_neon_hr_handbook_pending" name="Handbook — Not Acknowledged"
              parent="menu_neon_hr_safety"
              action="action_neon_hr_handbook_pending" sequence="40"/>
    <menuitem id="menu_neon_hr_handbook" name="Handbook Versions"
              parent="menu_neon_hr_config"
              action="action_neon_hr_handbook" sequence="60"/>

    <!-- ===== R3a: fleet / competency ===== -->
    <menuitem id="menu_neon_hr_fleet" name="Fleet &amp; Competency"
              parent="menu_neon_hr_root" sequence="55"/>
    <menuitem id="menu_neon_hr_licences" name="Driver Licences"
              parent="menu_neon_hr_fleet"
              action="action_neon_hr_licence" sequence="10"/>
    <menuitem id="menu_neon_hr_crew_gate" name="Crew Assignment Gate"
              parent="menu_neon_hr_fleet"
              action="action_neon_hr_crew_gate" sequence="20"/>
    <menuitem id="menu_neon_hr_competencies" name="Competencies"
              parent="menu_neon_hr_config"
              action="action_neon_hr_competency" sequence="70"/>
    <menuitem id="menu_neon_hr_role_competency" name="Role Competency Requirements"
              parent="menu_neon_hr_config"
              action="action_neon_hr_role_competency" sequence="80"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Trigger config for the driver-licence-expiry alert. Reuses the
        neon_jobs Action Centre (action.centre.trigger.config). The
        trigger_type value 'licence_expiry' is contributed by neon_hr
        via selection_add (models/action_centre_ext.py) so no neon_jobs
        file is touched. noupdate="1" so ops edits (enable/role/priority)
        survive upgrades — mirrors the contract-expiry seed.
    -->
    <record id="trigger_config_licence_expiry"
            model="action.centre.trigger.config">
        <field name="trigger_type">licence_expiry</field>
        <field name="is_enabled" eval="True"/>
        <field name="item_type">task</field>
        <field name="primary_role">manager</field>
        <field name="priority">high</field>
        <field name="escalation_minutes">1440</field>
        <field name="escalated_to_role">manager</field>
        <field name="description">Raised N days before a driver-licence expiry (lead configurable via neon_hr.licence_expiry_lead_days, default 30) and for already-expired licences. Assigned to HR Admin, visible to OD/MD.</field>
    </record>

    <!--
        Config defaults (noupdate so ops edits survive upgrades). The
        migration also ensures these exist on upgrade.
        - licence_expiry_lead_days : alert + 'expiring' lead window.
        - competency_gate_mode     : 'warn' (default) | 'block'. Drives
          the COMPETENCY gate only; the driver-licence block ignores it.
    -->
    <record id="param_licence_lead_days" model="ir.config_parameter">
        <field name="key">neon_hr.licence_expiry_lead_days</field>
        <field name="value">30</field>
    </record>
    <record id="param_competency_gate_mode" model="ir.config_parameter">
        <field name="key">neon_hr.competency_gate_mode</field>
        <field name="value">warn</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <!--
            Document tier rules (OR-merged per operation):
            READ: every internal user reads every document.
            WRITE/CREATE: only the document's OWN author (create_uid), so a
            regular user can neither edit NOR MOVE (change folder_id) another
            user's file. Managers (neon_core.group_neon_superuser) get the
            full dataset incl. unlink. UNLINK for base.group_user is blocked
            at the ACL (perm_unlink=0), so only managers can delete.
            Folders + tags carry NO record rules (shared structure): all
            internal users create/rename/reparent them; only managers (ACL
            perm_unlink=1) delete. Moving a FILE is a document write, so it
            stays governed by the own-write rule above.
        -->

        <record id="rule_library_document_read_all" model="ir.rule">
            <field name="name">Library Document: internal users read all</field>
            <field name="model_id" ref="model_neon_library_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_library_document_write_own" model="ir.rule">
            <field name="name">Library Document: author writes/creates own</field>
            <field name="model_id" ref="model_neon_library_document"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_library_document_manager_all" model="ir.rule">
            <field name="name">Library Document: managers full access</field>
            <field name="model_id" ref="model_neon_library_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('neon_core.group_neon_superuser'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_library_folder" model="ir.actions.act_window">
        <field name="name">Folders</field>
        <field name="res_model">neon.library.folder</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_library_folder_tree" model="ir.ui.view">
        <field name="name">neon.library.folder.tree</field>
        <field name="model">neon.library.folder</field>
        <field name="arch" type="xml">
            <tree>
                <field name="complete_name" string="Folder"/>
                <field name="parent_id"/>
                <field name="document_count" string="Documents"/>
            </tree>
        </field>
    </record>

    <record id="view_library_folder_form" model="ir.ui.view">
        <field name="name">neon.library.folder.form</field>
        <field name="model">neon.library.folder</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_documents" type="object"
                                class="oe_stat_button" icon="fa-file-o">
                            <field name="document_count" widget="statinfo"
                                   string="Documents"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Folder name"/></h1>
                    </div>
                    <group>
                        <field name="parent_id"/>
                        <field name="complete_name"/>
                    </group>
                    <notebook>
                        <page string="Documents">
                            <field name="document_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                    <field name="file_name"/>
                                    <field name="uploaded_by"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Subfolders">
                            <field name="child_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="document_count"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

</odoo>

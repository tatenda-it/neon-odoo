<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_library_tag" model="ir.actions.act_window">
        <field name="name">Library Tags</field>
        <field name="res_model">neon.library.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_library_tag_tree" model="ir.ui.view">
        <field name="name">neon.library.tag.tree</field>
        <field name="model">neon.library.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

    <record id="view_library_tag_form" model="ir.ui.view">
        <field name="name">neon.library.tag.form</field>
        <field name="model">neon.library.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>

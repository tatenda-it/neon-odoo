<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_neon_subhire_request_tree" model="ir.ui.view">
        <field name="name">neon.subhire.request.tree</field>
        <field name="model">neon.subhire.request</field>
        <field name="arch" type="xml">
            <tree string="Sub-hire Requests"
                  default_order="event_job_id, revision desc"
                  decoration-success="status == 'sent'"
                  decoration-info="status == 'approved'"
                  decoration-warning="status in ('generated', 'reviewed')"
                  decoration-muted="status in ('draft', 'superseded')">
                <field name="name"/>
                <field name="event_job_id"/>
                <field name="revision"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'sent'"
                       decoration-info="status == 'approved'"
                       decoration-warning="status in ('generated', 'reviewed')"
                       decoration-muted="status in ('draft', 'superseded')"/>
                <field name="line_count" optional="show"/>
                <field name="supplier_partner_id" optional="show"/>
                <field name="po_draft_id" optional="show"/>
                <field name="model_used" optional="hide"/>
                <field name="generated_at" optional="show"/>
                <field name="generated_by_id" optional="hide"/>
                <field name="sent_at" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_subhire_request_form" model="ir.ui.view">
        <field name="name">neon.subhire.request.form</field>
        <field name="model">neon.subhire.request</field>
        <field name="arch" type="xml">
            <form string="Sub-hire Request">
                <header>
                    <button name="action_mark_reviewed"
                            type="object"
                            string="Mark Reviewed"
                            class="oe_highlight"
                            invisible="status != 'generated'"/>
                    <button name="action_approve_and_create_po"
                            type="object"
                            string="Approve + Create PO Draft"
                            class="oe_highlight"
                            invisible="status != 'reviewed' or not supplier_partner_id"
                            confirm="This creates a Purchase Order in DRAFT state for the chosen supplier. Confirming + sending the PO happens separately via the standard Purchase Orders menu (B4 never auto-sends)."/>
                    <button name="action_mark_sent"
                            type="object"
                            string="Mark Sent"
                            class="oe_highlight"
                            invisible="status != 'approved'"
                            confirm="Mark this request as Sent. NOTE: this is metadata only -- it does NOT confirm the linked PO. Confirm the PO in the Purchase Orders menu before marking sent."/>
                    <button name="action_unsend"
                            type="object"
                            string="Un-send"
                            class="btn-warning"
                            invisible="status != 'sent'"
                            groups="neon_jobs.group_neon_jobs_manager"/>
                    <button name="action_regenerate"
                            type="object"
                            string="Regenerate"
                            class="btn-secondary"
                            invisible="status in ('sent', 'superseded')"/>
                    <button name="action_open_po_draft"
                            type="object"
                            string="Open PO Draft"
                            class="btn-secondary"
                            invisible="not po_draft_id"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,generated,reviewed,approved,sent"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <div invisible="has_supplier_candidates"
                         class="alert alert-warning" role="alert">
                        <strong>No vendor partners configured.</strong>
                        Add at least one partner with
                        <em>Vendor = True</em> (Contacts &#8594; New Vendor)
                        before approving this request. The Supplier
                        dropdown filters to partners with supplier_rank &gt; 0.
                        <field name="has_supplier_candidates"
                               invisible="1"/>
                    </div>

                    <group>
                        <group string="Source">
                            <field name="event_job_id" readonly="1"/>
                            <field name="revision" readonly="1"/>
                            <field name="source_conflict_id" readonly="1"/>
                            <field name="source_conflict_window_start"
                                   readonly="1" optional="hide"/>
                            <field name="source_conflict_window_end"
                                   readonly="1" optional="hide"/>
                        </group>
                        <group string="Supplier + PO">
                            <field name="supplier_partner_id"
                                   options="{'no_create': True}"
                                   readonly="status in ('approved', 'sent', 'superseded')"/>
                            <field name="po_draft_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Generation metadata">
                            <field name="generated_at" readonly="1"/>
                            <field name="generated_by_id" readonly="1"/>
                            <field name="reviewed_at" readonly="1"
                                   invisible="not reviewed_at"/>
                            <field name="reviewed_by_id" readonly="1"
                                   invisible="not reviewed_by_id"/>
                            <field name="approved_at" readonly="1"
                                   invisible="not approved_at"/>
                            <field name="approved_by_id" readonly="1"
                                   invisible="not approved_by_id"/>
                            <field name="sent_at" readonly="1"
                                   invisible="not sent_at"/>
                            <field name="sent_by_id" readonly="1"
                                   invisible="not sent_by_id"/>
                        </group>
                        <group string="Model usage">
                            <field name="model_used" readonly="1"/>
                            <field name="prompt_tokens" readonly="1"/>
                            <field name="completion_tokens" readonly="1"/>
                            <field name="latency_ms" readonly="1"/>
                        </group>
                    </group>

                    <div invisible="not error_message"
                         class="alert alert-danger" role="alert">
                        <strong>Last error:</strong>
                        <field name="error_message" readonly="1"
                               nolabel="1"/>
                    </div>

                    <notebook>
                        <page string="Draft" name="page_draft">
                            <field name="draft_summary_html"
                                   nolabel="1" readonly="1"
                                   widget="html"/>
                        </page>
                        <page string="Lines" name="page_lines">
                            <field name="line_ids" nolabel="1"
                                   readonly="1">
                                <tree>
                                    <field name="sub_hire_priority"/>
                                    <field name="product_template_id"/>
                                    <field name="qty_short"/>
                                    <field name="event_window"/>
                                    <field name="competing_event_names_csv"/>
                                    <field name="po_line_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Raw JSON"
                              name="page_raw"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <field name="draft_json" nolabel="1"
                                   readonly="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Quarantine"
                              name="page_quarantine"
                              invisible="not quarantine_json"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <p class="text-muted">
                                Validator-rejected output kept here
                                for debugging. NOT rendered to
                                users.
                            </p>
                            <field name="quarantine_json"
                                   nolabel="1" readonly="1"
                                   widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                    </notebook>

                    <div invisible="not superseded_by_request_id"
                         class="alert alert-info" role="alert">
                        Superseded by
                        <field name="superseded_by_request_id"
                               readonly="1" nolabel="1"/>
                        at <field name="superseded_at" readonly="1"
                                  nolabel="1"/>.
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_neon_subhire_request_search" model="ir.ui.view">
        <field name="name">neon.subhire.request.search</field>
        <field name="model">neon.subhire.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="event_job_id"/>
                <field name="supplier_partner_id"/>
                <separator/>
                <filter name="filter_active" string="Active"
                        domain="[('status','not in',('superseded','draft'))]"/>
                <filter name="filter_pending_review" string="Pending Review"
                        domain="[('status','=','generated')]"/>
                <filter name="filter_pending_approval" string="Pending Approval"
                        domain="[('status','=','reviewed')]"/>
                <filter name="filter_approved" string="Approved (PO drafted)"
                        domain="[('status','=','approved')]"/>
                <filter name="filter_sent" string="Sent"
                        domain="[('status','=','sent')]"/>
                <group expand="0" string="Group by">
                    <filter name="group_status" string="Status"
                            context="{'group_by':'status'}"/>
                    <filter name="group_event" string="Event"
                            context="{'group_by':'event_job_id'}"/>
                    <filter name="group_supplier" string="Supplier"
                            context="{'group_by':'supplier_partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_neon_subhire_request"
            model="ir.actions.act_window">
        <field name="name">Sub-hire Requests</field>
        <field name="res_model">neon.subhire.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sub-hire requests yet
            </p>
            <p>
                Open an event job with B2 deficits and click
                "Generate Sub-hire" to produce one. Lifecycle:
                draft &#8594; generated &#8594; reviewed &#8594;
                approved (PO drafted) &#8594; sent.
            </p>
        </field>
    </record>

    <!-- Server-action wrapper for the "Generate Sub-hire" button
         placed on the event_job form. Inline-return ir.actions
         per the Owl-dashboard pattern (no persisted action). -->
    <record id="server_action_generate_subhire_request"
            model="ir.actions.server">
        <field name="name">Generate Sub-hire Request</field>
        <field name="model_id" ref="model_neon_subhire_request"/>
        <field name="state">code</field>
        <field name="binding_model_id"
               ref="model_commercial_event_job"/>
        <field name="binding_view_types">form</field>
        <field name="code">
ev_ids = env.context.get('active_ids') or (
    [env.context.get('active_id')] if env.context.get('active_id') else [])
if not ev_ids:
    raise UserError("Open an event job first.")
action = env['neon.subhire.request'].sudo() \
    .action_generate_for_event(ev_ids[0])
        </field>
        <field name="groups_id" eval="[
            (4, ref('neon_jobs.group_neon_jobs_manager')),
            (4, ref('neon_jobs.group_neon_jobs_crew_leader')),
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

    <menuitem id="menu_neon_subhire_request"
              name="Sub-hire Requests"
              parent="menu_operations_root"
              action="action_neon_subhire_request"
              sequence="50"
              groups="neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader,neon_core.group_neon_superuser"/>

</odoo>

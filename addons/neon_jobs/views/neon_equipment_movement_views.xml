<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_equipment_movement_view_tree" model="ir.ui.view">
        <field name="name">neon.equipment.movement.tree</field>
        <field name="model">neon.equipment.movement</field>
        <field name="arch" type="xml">
            <tree string="Equipment Movements" create="false">
                <field name="create_date" string="When"/>
                <field name="name"/>
                <field name="movement_type"/>
                <field name="unit_id"/>
                <field name="event_job_id" optional="show"/>
                <field name="actor_id" optional="show"/>
                <field name="assignee_id" optional="hide"/>
                <field name="from_location_text" optional="hide"/>
                <field name="to_location_text" optional="hide"/>
                <field name="condition_at_event" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="neon_equipment_movement_view_form" model="ir.ui.view">
        <field name="name">neon.equipment.movement.form</field>
        <field name="model">neon.equipment.movement</field>
        <field name="arch" type="xml">
            <form string="Equipment Movement" create="false">
                <header>
                    <!-- P5.M6 — destination Accept / Decline buttons
                         on pending transfer_out records. Authority
                         is enforced in the action method, but the
                         button only shows when the record is in a
                         state that the action accepts. -->
                    <button name="action_accept_transfer"
                            string="Accept Transfer"
                            type="object"
                            class="oe_highlight"
                            invisible="movement_type != 'transfer_out' or transfer_state not in ('pending', 'expired')"/>
                    <button name="action_decline_transfer"
                            string="Decline Transfer"
                            type="object"
                            class="btn-danger"
                            invisible="movement_type != 'transfer_out' or transfer_state not in ('pending', 'expired')"
                            confirm="Decline this transfer? The unit will be returned to the source event."/>
                    <field name="transfer_state" widget="statusbar"
                           invisible="movement_type != 'transfer_out'"
                           statusbar_visible="pending,accepted,declined"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Subject">
                            <field name="movement_type" readonly="1"/>
                            <field name="unit_id" readonly="1"/>
                            <field name="event_job_id" readonly="1"
                                   string="Event Job (source / current)"/>
                            <field name="destination_event_job_id"
                                   readonly="1"
                                   invisible="movement_type not in ('transfer_out', 'transfer_in')"/>
                            <field name="equipment_line_id" readonly="1"/>
                            <field name="reservation_id" readonly="1"/>
                            <field name="transfer_out_movement_id"
                                   readonly="1"
                                   invisible="movement_type != 'transfer_in'"/>
                        </group>
                        <group string="Actor + Context">
                            <field name="actor_id" readonly="1"/>
                            <field name="assignee_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="condition_at_event" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Location">
                            <field name="from_location_text" readonly="1"/>
                            <field name="to_location_text" readonly="1"/>
                        </group>
                        <group string="Approval (transfers)">
                            <field name="requires_approval" readonly="1"/>
                            <field name="approved_by_id" readonly="1"/>
                            <field name="approved_at" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Decline" name="decline"
                              invisible="not decline_reason">
                            <field name="decline_reason" nolabel="1"
                                   readonly="1"/>
                        </page>
                        <page string="Photo" name="photo"
                              invisible="not photo">
                            <field name="photo" widget="image" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search view defined BEFORE the actions that reference it.
         Odoo's data loader resolves ref() against records already
         materialised in ir_model_data plus those loaded earlier in
         the current XML file. On a fresh-install upgrade path
         (production going from a pre-P5 version), the search view
         must exist by the time the pending_transfers_action's
         search_view_id ref is resolved — local upgrades hid this
         load-order bug because the records were already in
         ir_model_data from prior loads. (Discovered during P5.M11
         Hetzner deploy 2026-05-18; rolled back cleanly via
         transaction abort, no DB state corruption.) -->
    <record id="neon_equipment_movement_view_search" model="ir.ui.view">
        <field name="name">neon.equipment.movement.search</field>
        <field name="model">neon.equipment.movement</field>
        <field name="arch" type="xml">
            <search string="Equipment Movements">
                <field name="name"/>
                <field name="unit_id"/>
                <field name="event_job_id"/>
                <field name="actor_id"/>
                <separator/>
                <filter name="type_checkout" string="Checkouts"
                        domain="[('movement_type', '=', 'checkout')]"/>
                <filter name="type_checkin" string="Check-Ins"
                        domain="[('movement_type', '=', 'checkin')]"/>
                <filter name="type_transfer" string="Transfers"
                        domain="[('movement_type', 'in', ('transfer_out', 'transfer_in'))]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'movement_type'}"/>
                    <filter name="group_unit" string="Unit"
                            context="{'group_by': 'unit_id'}"/>
                    <filter name="group_event_job" string="Event Job"
                            context="{'group_by': 'event_job_id'}"/>
                    <filter name="group_actor" string="Actor"
                            context="{'group_by': 'actor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- P5.M6 — pending transfers list (action used by the new
         Workshop > Equipment > Pending Transfers menu). -->
    <record id="neon_equipment_movement_pending_transfers_action"
            model="ir.actions.act_window">
        <field name="name">Pending Transfers</field>
        <field name="res_model">neon.equipment.movement</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('movement_type', '=', 'transfer_out'),
                              ('transfer_state', 'in',
                               ('pending', 'expired'))]</field>
        <field name="search_view_id"
               ref="neon_equipment_movement_view_search"/>
    </record>

    <record id="neon_equipment_movement_action" model="ir.actions.act_window">
        <field name="name">Equipment Movements</field>
        <field name="res_model">neon.equipment.movement</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="neon_equipment_movement_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No equipment movements recorded yet
            </p>
            <p>
                Movements are an append-only audit log of physical
                equipment events: checkouts to jobs, transfers between
                jobs, check-ins back to the workshop.
            </p>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_neon_event_reconciliation_tree" model="ir.ui.view">
        <field name="name">neon.event.reconciliation.tree</field>
        <field name="model">neon.event.reconciliation</field>
        <field name="arch" type="xml">
            <tree string="Post-event Reconciliations"
                  default_order="event_job_id, revision desc"
                  decoration-success="status == 'final'"
                  decoration-info="status == 'reviewed'"
                  decoration-warning="status == 'generated'"
                  decoration-muted="status in ('draft', 'superseded')">
                <field name="name"/>
                <field name="event_job_id"/>
                <field name="revision"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'final'"
                       decoration-info="status == 'reviewed'"
                       decoration-warning="status == 'generated'"
                       decoration-muted="status in ('draft', 'superseded')"/>
                <field name="written_off_count" optional="show"/>
                <field name="needs_repair_count" optional="show"/>
                <field name="cost_variance_total" optional="show"/>
                <field name="source_plan_id" optional="hide"/>
                <field name="generated_at" optional="show"/>
                <field name="generated_by_id" optional="hide"/>
                <field name="finalised_at" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_event_reconciliation_form" model="ir.ui.view">
        <field name="name">neon.event.reconciliation.form</field>
        <field name="model">neon.event.reconciliation</field>
        <field name="arch" type="xml">
            <form string="Post-event Reconciliation">
                <header>
                    <button name="action_mark_reviewed"
                            type="object"
                            string="Mark Reviewed"
                            class="oe_highlight"
                            invisible="status != 'generated'"/>
                    <button name="action_mark_final"
                            type="object"
                            string="Mark Final"
                            class="oe_highlight"
                            invisible="status != 'reviewed'"
                            confirm="Mark this reconciliation final. If any units are flagged as needs_repair or written_off, a workshop alert + activity will be posted. NOTE: B5 does NOT auto-flip condition_status; that remains a Workshop user action."/>
                    <button name="action_regenerate"
                            type="object"
                            string="Regenerate"
                            class="btn-secondary"
                            invisible="status == 'superseded'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,generated,reviewed,final"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Source">
                            <field name="event_job_id" readonly="1"/>
                            <field name="revision" readonly="1"/>
                            <field name="source_plan_id" readonly="1"/>
                        </group>
                        <group string="Outcome counts">
                            <field name="written_off_count" readonly="1"/>
                            <field name="needs_repair_count" readonly="1"/>
                            <field name="cost_variance_total" readonly="1"
                                   help="Positive means over-budget. INFORMATIONAL only -- B5 does not post journal entries."/>
                        </group>
                    </group>
                    <group>
                        <group string="Generation metadata">
                            <field name="generated_at" readonly="1"/>
                            <field name="generated_by_id" readonly="1"/>
                            <field name="reviewed_at" readonly="1"
                                   invisible="not reviewed_at"/>
                            <field name="reviewed_by_id" readonly="1"
                                   invisible="not reviewed_by_id"/>
                            <field name="finalised_at" readonly="1"
                                   invisible="not finalised_at"/>
                            <field name="finalised_by_id" readonly="1"
                                   invisible="not finalised_by_id"/>
                        </group>
                        <group string="Model usage">
                            <field name="model_used" readonly="1"/>
                            <field name="prompt_tokens" readonly="1"/>
                            <field name="completion_tokens" readonly="1"/>
                            <field name="latency_ms" readonly="1"/>
                        </group>
                    </group>

                    <div invisible="not error_message"
                         class="alert alert-danger" role="alert">
                        <strong>Last error:</strong>
                        <field name="error_message" readonly="1"
                               nolabel="1"/>
                    </div>

                    <notebook>
                        <page string="Summary" name="page_summary">
                            <field name="summary_html"
                                   nolabel="1" readonly="1"
                                   widget="html"/>
                        </page>
                        <page string="Sub-hire references"
                              name="page_subhire">
                            <field name="source_subhire_request_ids"
                                   nolabel="1" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="status"/>
                                    <field name="supplier_partner_id"/>
                                    <field name="po_draft_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Raw summary JSON"
                              name="page_raw_summary"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <field name="summary_json" nolabel="1"
                                   readonly="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Raw facts JSON"
                              name="page_raw_facts"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <field name="facts_json" nolabel="1"
                                   readonly="1" widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Quarantine"
                              name="page_quarantine"
                              invisible="not quarantine_json"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <p class="text-muted">
                                Validator-rejected output kept here
                                for debugging. NOT rendered to users.
                            </p>
                            <field name="quarantine_json"
                                   nolabel="1" readonly="1"
                                   widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                    </notebook>

                    <div invisible="not superseded_by_recon_id"
                         class="alert alert-info" role="alert">
                        Superseded by
                        <field name="superseded_by_recon_id"
                               readonly="1" nolabel="1"/>
                        at <field name="superseded_at" readonly="1"
                                  nolabel="1"/>.
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_neon_event_reconciliation_search" model="ir.ui.view">
        <field name="name">neon.event.reconciliation.search</field>
        <field name="model">neon.event.reconciliation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="event_job_id"/>
                <separator/>
                <filter name="filter_active" string="Active"
                        domain="[('status','not in',('superseded','draft'))]"/>
                <filter name="filter_pending_review" string="Pending Review"
                        domain="[('status','=','generated')]"/>
                <filter name="filter_pending_final" string="Pending Final"
                        domain="[('status','=','reviewed')]"/>
                <filter name="filter_final" string="Final"
                        domain="[('status','=','final')]"/>
                <filter name="filter_has_writeoffs" string="With Written-Off Units"
                        domain="[('written_off_count','>',0)]"/>
                <filter name="filter_variance_positive" string="Over Budget"
                        domain="[('cost_variance_total','>',0)]"/>
                <group expand="0" string="Group by">
                    <filter name="group_status" string="Status"
                            context="{'group_by':'status'}"/>
                    <filter name="group_event" string="Event"
                            context="{'group_by':'event_job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_neon_event_reconciliation"
            model="ir.actions.act_window">
        <field name="name">Post-event Reconciliations</field>
        <field name="res_model">neon.event.reconciliation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reconciliations yet
            </p>
            <p>
                Open a post-event job (returned / completed / closed)
                and click "Generate Reconciliation" to produce one.
                Lifecycle: draft &#8594; generated &#8594; reviewed
                &#8594; final.
            </p>
        </field>
    </record>

    <record id="server_action_generate_event_reconciliation"
            model="ir.actions.server">
        <field name="name">Generate Reconciliation</field>
        <field name="model_id" ref="model_neon_event_reconciliation"/>
        <field name="state">code</field>
        <field name="binding_model_id"
               ref="model_commercial_event_job"/>
        <field name="binding_view_types">form</field>
        <field name="code">
ev_ids = env.context.get('active_ids') or (
    [env.context.get('active_id')] if env.context.get('active_id') else [])
if not ev_ids:
    raise UserError("Open an event job first.")
action = env['neon.event.reconciliation'].sudo() \
    .action_generate_for_event(ev_ids[0])
        </field>
        <field name="groups_id" eval="[
            (4, ref('neon_jobs.group_neon_jobs_manager')),
            (4, ref('neon_jobs.group_neon_jobs_crew_leader')),
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

    <menuitem id="menu_neon_event_reconciliation"
              name="Post-event Reconciliations"
              parent="menu_operations_root"
              action="action_neon_event_reconciliation"
              sequence="55"
              groups="neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader,neon_core.group_neon_superuser"/>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_equipment_recommission_wizard_view_form"
            model="ir.ui.view">
        <field name="name">neon.equipment.recommission.wizard.form</field>
        <field name="model">neon.equipment.recommission.wizard</field>
        <field name="arch" type="xml">
            <form string="Recommission Equipment Unit">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>Manager override.</strong>
                        This reverses a write-off (decommissioned) status.
                        The transition is logged to the unit's chatter
                        with your justification — there is no soft
                        delete; pick the right target state on the
                        first try.
                    </div>
                    <group>
                        <field name="equipment_unit_id" readonly="1"/>
                        <field name="target_state"/>
                        <field name="reason"
                               placeholder="Why is this write-off being reversed? Be specific — workshop audits will read this."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="Confirm Recommission"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

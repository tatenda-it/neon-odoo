<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commercial_checklist_template_view_tree" model="ir.ui.view">
        <field name="name">commercial.checklist.template.tree</field>
        <field name="model">commercial.checklist.template</field>
        <field name="arch" type="xml">
            <tree string="Checklist Templates" default_order="sequence, id">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="type"/>
                <field name="ownership_role"/>
                <field name="item_count"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="commercial_checklist_template_view_form" model="ir.ui.view">
        <field name="name">commercial.checklist.template.form</field>
        <field name="model">commercial.checklist.template</field>
        <field name="arch" type="xml">
            <form string="Checklist Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="ownership_role" readonly="1"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="item_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items" name="page_items">
                            <field name="item_ids">
                                <tree editable="bottom" default_order="sequence, id">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="photo_required" widget="boolean_toggle"/>
                                    <field name="active" widget="boolean_toggle"
                                           optional="hide"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="sequence"/>
                                        <field name="name"/>
                                        <field name="photo_required"/>
                                        <field name="active"/>
                                    </group>
                                    <separator string="Description"/>
                                    <field name="description" nolabel="1"
                                           placeholder="Optional longer guidance shown to crew on this step…"/>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="commercial_checklist_template_action" model="ir.actions.act_window">
        <field name="name">Checklist Templates</field>
        <field name="res_model">commercial.checklist.template</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('neon_jobs.group_neon_jobs_manager'),
        ])]"/>
    </record>

</odoo>

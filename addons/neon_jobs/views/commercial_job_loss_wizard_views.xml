<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commercial_job_loss_wizard_view_form" model="ir.ui.view">
        <field name="name">commercial.job.loss.wizard.form</field>
        <field name="model">commercial.job.loss.wizard</field>
        <field name="arch" type="xml">
            <!-- P3.M8.5 — No <sheet>. Bare Text field (loss_reason) is
                 a direct child of <form> so it stretches full-width.
                 Char field (lost_to_competitor) stays in a <group>
                 for label rendering. -->
            <form string="Capture Loss Details">
                <div class="alert alert-warning" role="alert">
                    Record why this lead was lost. Linked pending Commercial
                    Jobs will be archived with this loss reason for future
                    sales-process learning.
                </div>
                <group>
                    <field name="lead_id" readonly="1"/>
                    <field name="job_ids" widget="many2many_tags" readonly="1"/>
                </group>
                <separator string="Loss Reason"/>
                <field name="loss_reason" nolabel="1"
                       placeholder="Why was the lead lost? (competitor, budget, timing, scope, etc.)"/>
                <group>
                    <field name="lost_to_competitor"
                           placeholder="Optional — competitor name if known"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Archive Lost"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="commercial_job_loss_wizard_action" model="ir.actions.act_window">
        <field name="name">Capture Loss Details</field>
        <field name="res_model">commercial.job.loss.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

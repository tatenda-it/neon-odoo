<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commercial_job_crew_view_tree" model="ir.ui.view">
        <field name="name">commercial.job.crew.tree</field>
        <field name="model">commercial.job.crew</field>
        <field name="arch" type="xml">
            <tree string="Crew Assignments" decoration-warning="state == 'pending'" decoration-success="state == 'confirmed'" decoration-danger="state == 'declined'">
                <field name="job_id"/>
                <field name="job_event_date"/>
                <field name="job_partner_id"/>
                <field name="user_id"/>
                <field name="role"/>
                <field name="state" widget="badge"/>
                <field name="assigned_on"/>
                <field name="responded_on"/>
            </tree>
        </field>
    </record>

    <record id="commercial_job_crew_view_form" model="ir.ui.view">
        <field name="name">commercial.job.crew.form</field>
        <field name="model">commercial.job.crew</field>
        <field name="arch" type="xml">
            <form string="Crew Assignment">
                <sheet>
                    <group>
                        <group>
                            <field name="job_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                        </group>
                        <group>
                            <field name="state" widget="statusbar"/>
                            <field name="assigned_on" readonly="1"/>
                            <field name="responded_on" readonly="1"/>
                            <field name="notification_sent" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="state != 'declined'">
                        <field name="decline_reason" required="state == 'declined'"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="commercial_job_crew_action" model="ir.actions.act_window">
        <field name="name">Crew Assignments</field>
        <field name="res_model">commercial.job.crew</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

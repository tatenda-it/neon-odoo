<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_equipment_allocate_wizard_view_form" model="ir.ui.view">
        <field name="name">neon.equipment.allocate.wizard.form</field>
        <field name="model">neon.equipment.allocate.wizard</field>
        <field name="arch" type="xml">
            <form string="Allocate Equipment Units">
                <group>
                    <group string="Line">
                        <field name="equipment_line_id" readonly="1"/>
                        <field name="event_job_id" readonly="1"/>
                        <field name="product_template_id" readonly="1"/>
                    </group>
                    <group string="Quantity">
                        <field name="quantity_remaining" readonly="1"/>
                    </group>
                </group>
                <separator string="Selection"/>
                <field name="selected_unit_ids"
                       domain="[('id', 'in', available_unit_ids)]"
                       options="{'no_create': True}">
                    <tree>
                        <field name="name"/>
                        <field name="serial_number"/>
                        <field name="asset_tag"/>
                        <field name="workshop_location"/>
                        <field name="state" widget="badge"/>
                    </tree>
                </field>
                <field name="available_unit_ids" invisible="1"/>
                <footer>
                    <button name="action_confirm"
                            string="Allocate"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

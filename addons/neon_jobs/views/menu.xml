<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_operations_root"
              name="Operations"
              sequence="40"/>

    <menuitem id="menu_operations_dashboard"
              name="Operations Dashboard"
              parent="menu_operations_root"
              action="operations_dashboard_action"
              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader"
              sequence="1"/>

    <!-- P2.M9.4 — My Schedule scoped to crew only. Management oversight
         of crew activity is a Phase 8 analytics concern, not an
         operational dashboard for User/Manager/Crew Leader. -->
    <menuitem id="menu_my_schedule"
              name="My Schedule"
              parent="menu_operations_root"
              action="my_schedule_action"
              groups="neon_jobs.group_neon_jobs_crew"
              sequence="2"/>

    <menuitem id="menu_my_calendar"
              name="My Calendar"
              parent="menu_operations_root"
              action="commercial_job_calendar_my_calendar_action"
              groups="neon_jobs.group_neon_jobs_crew"
              sequence="3"/>

    <menuitem id="menu_calendar_live_pipeline"
              name="Calendar — Live Pipeline"
              parent="menu_operations_root"
              action="commercial_job_calendar_live_pipeline_action"
              sequence="5"/>

    <menuitem id="menu_calendar_all_events"
              name="Calendar — All Events"
              parent="menu_operations_root"
              action="commercial_job_calendar_all_events_action"
              sequence="7"/>

    <menuitem id="menu_commercial_job"
              name="Commercial Jobs"
              parent="menu_operations_root"
              action="commercial_job_action"
              sequence="10"/>

    <!-- P3.M1 — Event Jobs (operational execution layer). Gated to
         user/manager/crew_leader; crew tier reaches event_jobs only
         via deep-link from their My Schedule path (P3.M8). -->
    <menuitem id="menu_event_job"
              name="Event Jobs"
              parent="menu_operations_root"
              action="commercial_event_job_action"
              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader"
              sequence="15"/>

    <menuitem id="menu_master_contract"
              name="Master Contracts"
              parent="menu_operations_root"
              action="commercial_job_master_action"
              sequence="20"/>

    <menuitem id="menu_crew_assignments"
              name="Crew Assignments"
              parent="menu_operations_root"
              action="commercial_job_crew_action"
              sequence="30"/>

    <!-- P3.M6 — Scope Changes (Sales Review queue + analytics).
         Gated to user/manager/crew_leader; crew tier reaches scope
         changes via the event_job Scope Changes tab if they're on
         the event, scoped by the ir.rule. -->
    <menuitem id="menu_scope_changes"
              name="Scope Changes"
              parent="menu_operations_root"
              action="commercial_scope_change_action"
              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader"
              sequence="35"/>

    <!-- P3.M8 — Closeout Queue (dashboard for stuck events).
         Menu binds to a server action that calls the role-aware
         Python method action_open_closeout_queue, dispatching to
         the default filter that matches the logged-in user's
         group (manager / lead / sales). Gated to user/lead/mgr;
         crew tier does not see this entry. -->
    <menuitem id="menu_closeout_queue"
              name="Closeout Queue"
              parent="menu_operations_root"
              action="commercial_event_job_closeout_queue_server_action"
              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader"
              sequence="37"/>

    <!-- P4.M1 — Action Centre (proactive task + alert engine).
         Gated to user/manager/crew_leader; crew tier is filtered by
         ir.rule (own assignments) on the model when reached via
         deep-link. -->
    <menuitem id="menu_action_centre"
              name="Action Centre"
              parent="menu_operations_root"
              action="action_centre_item_action"
              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader"
              sequence="38"/>

    <menuitem id="menu_operations_config"
              name="Configuration"
              parent="menu_operations_root"
              sequence="90"
              groups="base.group_system,neon_jobs.group_neon_jobs_manager"/>

    <menuitem id="menu_venues"
              name="Venues"
              parent="menu_operations_config"
              action="res_partner_action_venues"
              sequence="10"/>

    <menuitem id="menu_venue_rooms"
              name="Venue Rooms"
              parent="menu_operations_config"
              action="venue_room_action"
              sequence="20"/>

    <menuitem id="menu_checklist_templates"
              name="Checklist Templates"
              parent="menu_operations_config"
              action="commercial_checklist_template_action"
              groups="neon_jobs.group_neon_jobs_manager"
              sequence="30"/>

    <menuitem id="menu_action_centre_tags"
              name="Action Centre Tags"
              parent="menu_operations_config"
              action="action_centre_item_tag_action"
              groups="neon_jobs.group_neon_jobs_manager"
              sequence="40"/>

    <menuitem id="menu_action_centre_triggers"
              name="Action Centre Triggers"
              parent="menu_operations_config"
              action="action_centre_trigger_config_action"
              groups="neon_jobs.group_neon_jobs_manager"
              sequence="50"/>

</odoo>

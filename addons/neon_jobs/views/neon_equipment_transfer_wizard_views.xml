<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_equipment_transfer_wizard_view_form" model="ir.ui.view">
        <field name="name">neon.equipment.transfer.wizard.form</field>
        <field name="model">neon.equipment.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Initiate Equipment Transfer">
                <group>
                    <group string="From / To">
                        <field name="source_event_job_id" readonly="1"/>
                        <field name="destination_event_job_id"
                               options="{'no_create': True}"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </group>
                <separator string="Units to Transfer"/>
                <field name="unit_ids"
                       domain="[('id', 'in', candidate_unit_ids)]"
                       options="{'no_create': True}">
                    <tree>
                        <field name="name"/>
                        <field name="serial_number"/>
                        <field name="asset_tag"/>
                        <field name="workshop_location"/>
                        <field name="state" widget="badge"/>
                    </tree>
                </field>
                <field name="candidate_unit_ids" invisible="1"/>
                <footer>
                    <button name="action_confirm"
                            string="Initiate Transfer"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_equipment_checkin_wizard_view_form" model="ir.ui.view">
        <field name="name">neon.equipment.checkin.wizard.form</field>
        <field name="model">neon.equipment.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check In Equipment">
                <group>
                    <group string="Event">
                        <field name="event_job_id" readonly="1"/>
                        <field name="line_id" readonly="1"
                               invisible="not line_id"/>
                    </group>
                    <group string="Return Location">
                        <field name="to_location_text"/>
                    </group>
                </group>
                <separator string="Units to Check In"/>
                <field name="checkin_line_ids">
                    <tree editable="bottom">
                        <field name="unit_id" readonly="1"
                               force_save="1"/>
                        <field name="product_template_id"
                               readonly="1" optional="hide"/>
                        <field name="current_state" readonly="1"
                               widget="badge"/>
                        <field name="condition_at_event"/>
                        <field name="send_to_maintenance"
                               invisible="condition_at_event != 'poor'"/>
                        <field name="requires_photo" invisible="1"/>
                        <field name="requires_resolution" invisible="1"/>
                        <field name="photo" widget="image"
                               invisible="not requires_photo"
                               required="requires_photo"/>
                        <field name="resolution_path"
                               invisible="not requires_resolution"
                               required="requires_resolution"/>
                        <field name="resolution_notes"
                               invisible="condition_at_event != 'missing'"/>
                        <field name="notes"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm"
                            string="Check In"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

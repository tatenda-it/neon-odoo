<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_centre_item_cancel_wizard_view_form" model="ir.ui.view">
        <field name="name">action.centre.item.cancel.wizard.form</field>
        <field name="model">action.centre.item.cancel.wizard</field>
        <field name="arch" type="xml">
            <!-- P3.M8.5 Option A — no <sheet>, bare Text field, no
                 <group col=1> wrapper around the textarea so it
                 renders full-width. -->
            <form string="Cancel Action Centre Item">
                <div class="alert alert-warning" role="alert">
                    <strong>Cancelling this Action Centre item.</strong>
                    A written reason is required and will be logged
                    to the item's audit trail.
                </div>
                <group>
                    <field name="item_id" readonly="1"/>
                </group>
                <separator string="Closure Reason"/>
                <field name="closure_reason" nolabel="1"
                       placeholder="e.g. 'No longer applicable — client moved event to a different supplier.'"/>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Cancellation"
                            class="btn-primary"/>
                    <button string="Back" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

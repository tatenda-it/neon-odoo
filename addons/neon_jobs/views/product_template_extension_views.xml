<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- P5.M1 — extend the standard product.template form with a
         Workshop tab. The tab is invisible by default; ticking
         "Workshop Item" on the General Information page surfaces
         it. This keeps the standard sale/CRM product form clean
         for SKUs that have nothing to do with workshop inventory. -->
    <record id="product_template_view_form_inherit_workshop"
            model="ir.ui.view">
        <field name="name">product.template.form.workshop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Workshop" name="workshop">
                    <group>
                        <group>
                            <field name="is_workshop_item"/>
                            <field name="equipment_category_id"
                                   invisible="not is_workshop_item"
                                   required="is_workshop_item"/>
                            <field name="tracking_mode"
                                   invisible="not is_workshop_item"/>
                        </group>
                        <group>
                            <field name="workshop_name"
                                   invisible="not is_workshop_item"/>
                            <field name="total_units"
                                   invisible="not is_workshop_item"
                                   readonly="1"/>
                            <field name="available_units"
                                   invisible="not is_workshop_item"
                                   readonly="1"/>
                        </group>
                    </group>
                    <separator string="Units"
                               invisible="not is_workshop_item"/>
                    <field name="equipment_unit_ids"
                           invisible="not is_workshop_item"
                           context="{'default_product_template_id': id}">
                        <tree>
                            <field name="serial_number"/>
                            <field name="asset_tag"/>
                            <field name="workshop_location"/>
                            <field name="state" widget="badge"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

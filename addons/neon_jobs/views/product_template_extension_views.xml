<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- P5.M1 — extend the standard product.template form with a
         Workshop tab. The tab is invisible by default; ticking
         "Workshop Item" on the General Information page surfaces
         it. This keeps the standard sale/CRM product form clean
         for SKUs that have nothing to do with workshop inventory. -->
    <record id="product_template_view_form_inherit_workshop"
            model="ir.ui.view">
        <field name="name">product.template.form.workshop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Workshop" name="workshop">
                    <group>
                        <group>
                            <field name="is_workshop_item"/>
                            <field name="equipment_category_id"
                                   invisible="not is_workshop_item"
                                   required="is_workshop_item"/>
                            <field name="tracking_mode"
                                   invisible="not is_workshop_item"/>
                        </group>
                        <group>
                            <field name="workshop_name"
                                   invisible="not is_workshop_item"/>
                            <field name="total_units"
                                   invisible="not is_workshop_item"
                                   readonly="1"/>
                            <field name="available_units"
                                   invisible="not is_workshop_item"
                                   readonly="1"/>
                        </group>
                    </group>
                    <separator string="Units"
                               invisible="not is_workshop_item"/>
                    <field name="equipment_unit_ids"
                           invisible="not is_workshop_item"
                           context="{'default_product_template_id': id}">
                        <tree>
                            <field name="serial_number"/>
                            <field name="asset_tag"/>
                            <field name="workshop_location"/>
                            <field name="state" widget="badge"/>
                        </tree>
                    </field>
                </page>
            </xpath>

            <!-- SOLUTION B (a): the engine prices hire items via the pricing
                 rules (base_rate), NOT product.list_price, which sits at the
                 misleading default $1 on workshop items. Hide the stock "Sales
                 Price" for workshop items (gated on is_workshop_item so genuine
                 non-workshop SKUs keep their price) and point users at where the
                 real rate lives. Display-only: list_price values and the engine
                 are untouched; nothing functionally reads list_price (the only
                 reader, the ZWG pricelist, was deactivated in QUOTE-UX-2). -->
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="invisible">is_workshop_item</attribute>
            </xpath>
            <xpath expr="//label[@for='list_price']" position="attributes">
                <attribute name="invisible">is_workshop_item</attribute>
            </xpath>
            <!-- UX-B-RATE: show the engine-resolved day-1 USD hire rate where
                 the misleading $1 list_price is hidden. Field shows for a
                 workshop item with a resolvable rule; the hint shows when no
                 rule covers the product yet. Display-only. -->
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="neon_unit_rate_currency_id" invisible="1"/>
                <field name="neon_unit_rate_has_rule" invisible="1"/>
                <field name="neon_unit_rate" widget="monetary"
                       options="{'currency_field': 'neon_unit_rate_currency_id'}"
                       invisible="not is_workshop_item or not neon_unit_rate_has_rule"/>
                <div class="text-muted"
                     invisible="not is_workshop_item or neon_unit_rate_has_rule"
                     style="font-size:0.85em;">
                    Hire rate is set in Finance &#8594; Pricing Rules.
                </div>
            </xpath>
        </field>
    </record>

    <!-- SOLUTION B (a): hide the misleading $1 "Price:" block on the product
         KANBAN card for workshop (hire) items; non-workshop SKUs keep it.
         is_workshop_item is not in the stock kanban field-list, so declare it
         (invisible) to make the per-card condition evaluable. -->
    <record id="product_template_view_kanban_hide_saleprice_workshop"
            model="ir.ui.view">
        <field name="name">product.template.kanban.hide-saleprice-workshop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//templates" position="before">
                <field name="is_workshop_item"/>
                <field name="neon_unit_rate_currency_id"/>
                <field name="neon_unit_rate_has_rule"/>
            </xpath>
            <xpath expr="//div[@name='product_lst_price']" position="attributes">
                <attribute name="invisible">is_workshop_item</attribute>
            </xpath>
            <!-- UX-B-RATE: show the resolved hire rate on the card for workshop
                 items that have a rule (where the $1 list_price block is now
                 hidden). -->
            <xpath expr="//div[@name='product_lst_price']" position="after">
                <div name="neon_unit_rate_kanban" class="mt-1"
                     invisible="not is_workshop_item or not neon_unit_rate_has_rule">
                    Hire rate: <field name="neon_unit_rate" widget="monetary"
                        options="{'currency_field': 'neon_unit_rate_currency_id'}"/>/day
                </div>
            </xpath>
        </field>
    </record>

    <!-- SOLUTION B (a): the $1 "Sales Price" column is misleading on the
         workshop-dominated products LIST, and a list column cannot be hidden
         per-row, so make it optional + hidden-by-default (recoverable via the
         column toggle). Non-workshop prices remain on the form + kanban. -->
    <record id="product_template_view_tree_hide_saleprice"
            model="ir.ui.view">
        <field name="name">product.template.tree.hide-saleprice</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <!-- UX-B-RATE: the real day-1 USD hire rate as a (default-visible)
                 column in place of the hidden $1 Sales Price. Non-stored, so
                 not sortable; a display column. -->
            <xpath expr="//field[@name='list_price']" position="after">
                <field name="neon_unit_rate_currency_id" column_invisible="1"/>
                <field name="neon_unit_rate" widget="monetary"
                       options="{'currency_field': 'neon_unit_rate_currency_id'}"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_deployment_plan_call_time_config_form"
            model="ir.ui.view">
        <field name="name">neon.deployment.plan.call.time.config.form</field>
        <field name="model">neon.deployment.plan.call.time.config</field>
        <field name="arch" type="xml">
            <form string="Call-Time Policy">
                <sheet>
                    <div class="alert alert-warning"
                         role="alert"
                         invisible="is_ops_signed_off">
                        <strong>Pending ops sign-off.</strong>
                        The defaults below are sensible but Lisa
                        (Operations) should review the policy and
                        tick "Ops signed off" once approved.
                    </div>
                    <div class="alert alert-success"
                         role="alert"
                         invisible="not is_ops_signed_off">
                        <strong>Signed off by Operations.</strong>
                    </div>
                    <div class="oe_title">
                        <h1>Call-Time Policy</h1>
                        <p class="text-muted">
                            How early each crew tier is called
                            relative to the prep / dispatch
                            anchor.
                        </p>
                    </div>
                    <group>
                        <group string="Offsets (minutes BEFORE
                                       anchor)">
                            <field name="crew_chief_offset_minutes"
                                   string="Crew Chief"/>
                            <field name="lead_tech_offset_minutes"
                                   string="Lead Tech"/>
                            <field name="rest_offset_minutes"
                                   string="Rest of Crew"/>
                        </group>
                        <group string="Anchor + sign-off">
                            <field name="anchor_policy"/>
                            <field name="is_ops_signed_off"
                                   widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_deployment_plan_call_time_config"
            model="ir.actions.act_window">
        <field name="name">Call-Time Policy</field>
        <field name="res_model">neon.deployment.plan.call.time.config</field>
        <field name="view_mode">form</field>
        <field name="view_id"
               ref="view_deployment_plan_call_time_config_form"/>
        <field name="context">
            {'form_view_initial_mode': 'edit'}
        </field>
        <!-- Singleton: route the action to the lazy-created row. -->
        <field name="domain">[]</field>
        <field name="target">current</field>
    </record>

    <!-- Server action that resolves the singleton + opens it. -->
    <record id="server_action_deployment_plan_call_time_config"
            model="ir.actions.server">
        <field name="name">Open Call-Time Policy (singleton)</field>
        <field name="model_id"
               ref="model_neon_deployment_plan_call_time_config"/>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'neon.deployment.plan.call.time.config',
    'view_mode': 'form',
    'res_id': env['neon.deployment.plan.call.time.config']
                  .sudo().get_singleton().id,
    'target': 'current',
}
        </field>
        <field name="groups_id" eval="[
            (4, ref('neon_jobs.group_neon_jobs_manager')),
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

</odoo>

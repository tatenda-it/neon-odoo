<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_neon_deployment_plan_tree" model="ir.ui.view">
        <field name="name">neon.deployment.plan.tree</field>
        <field name="model">neon.deployment.plan</field>
        <field name="arch" type="xml">
            <tree string="Deployment Plans"
                  default_order="event_job_id, revision desc"
                  decoration-success="status == 'final'"
                  decoration-info="status == 'reviewed'"
                  decoration-warning="status == 'generated'"
                  decoration-muted="status in ('draft','superseded')">
                <field name="name"/>
                <field name="event_job_id"/>
                <field name="revision"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'final'"
                       decoration-info="status == 'reviewed'"
                       decoration-warning="status == 'generated'"
                       decoration-muted="status in ('draft','superseded')"/>
                <field name="deficit_count" optional="show"/>
                <field name="model_used" optional="hide"/>
                <field name="generated_at" optional="show"/>
                <field name="generated_by_id" optional="show"/>
                <field name="finalised_at" optional="hide"/>
                <field name="latency_ms" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_deployment_plan_form" model="ir.ui.view">
        <field name="name">neon.deployment.plan.form</field>
        <field name="model">neon.deployment.plan</field>
        <field name="arch" type="xml">
            <form string="Deployment Plan">
                <header>
                    <button name="action_mark_reviewed"
                            type="object"
                            string="Mark Reviewed"
                            class="oe_highlight"
                            invisible="status != 'generated'"/>
                    <button name="action_mark_final"
                            type="object"
                            string="Mark Final"
                            class="oe_highlight"
                            invisible="status != 'reviewed'"
                            confirm="Lock this plan as Final? Regenerate will be blocked until un-finalised."/>
                    <button name="action_unfinalise"
                            type="object"
                            string="Un-finalise"
                            class="btn-warning"
                            invisible="status != 'final'"
                            groups="neon_jobs.group_neon_jobs_manager"/>
                    <button name="action_regenerate"
                            type="object"
                            string="Regenerate"
                            class="btn-secondary"
                            invisible="status in ('final','superseded')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,generated,reviewed,final"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Source">
                            <field name="event_job_id" readonly="1"/>
                            <field name="revision" readonly="1"/>
                            <field name="source_conflict_id"
                                   readonly="1"/>
                            <field name="source_conflict_window_start"
                                   readonly="1" optional="hide"/>
                            <field name="source_conflict_window_end"
                                   readonly="1" optional="hide"/>
                        </group>
                        <group string="Generation metadata">
                            <field name="generated_at" readonly="1"/>
                            <field name="generated_by_id"
                                   readonly="1"/>
                            <field name="reviewed_at" readonly="1"
                                   invisible="not reviewed_at"/>
                            <field name="reviewed_by_id"
                                   readonly="1"
                                   invisible="not reviewed_by_id"/>
                            <field name="finalised_at" readonly="1"
                                   invisible="not finalised_at"/>
                            <field name="finalised_by_id"
                                   readonly="1"
                                   invisible="not finalised_by_id"/>
                            <field name="model_used" readonly="1"/>
                            <field name="prompt_tokens" readonly="1"/>
                            <field name="completion_tokens"
                                   readonly="1"/>
                            <field name="latency_ms" readonly="1"/>
                        </group>
                    </group>

                    <div invisible="not error_message"
                         class="alert alert-danger" role="alert">
                        <strong>Last error:</strong>
                        <field name="error_message" readonly="1"
                               nolabel="1"/>
                    </div>

                    <notebook>
                        <page string="Plan" name="page_plan">
                            <field name="plan_summary_html"
                                   nolabel="1" readonly="1"
                                   widget="html"/>
                        </page>
                        <page string="Raw JSON"
                              name="page_raw"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <field name="plan_json"
                                   nolabel="1" readonly="1"
                                   widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                        <page string="Quarantine"
                              name="page_quarantine"
                              invisible="not quarantine_json"
                              groups="neon_jobs.group_neon_jobs_manager">
                            <p class="text-muted">
                                Validator-rejected output kept here
                                for debugging. NOT rendered to
                                users.
                            </p>
                            <field name="quarantine_json"
                                   nolabel="1" readonly="1"
                                   widget="ace"
                                   options="{'mode': 'json'}"/>
                        </page>
                    </notebook>

                    <div invisible="not superseded_by_plan_id"
                         class="alert alert-info" role="alert">
                        Superseded by
                        <field name="superseded_by_plan_id"
                               readonly="1" nolabel="1"/>
                        at <field name="superseded_at"
                                  readonly="1" nolabel="1"/>.
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_neon_deployment_plan_search" model="ir.ui.view">
        <field name="name">neon.deployment.plan.search</field>
        <field name="model">neon.deployment.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="event_job_id"/>
                <separator/>
                <filter name="filter_active"
                        string="Active"
                        domain="[('status','not in',('superseded',))]"/>
                <filter name="filter_pending_review"
                        string="Pending review"
                        domain="[('status','=','generated')]"/>
                <filter name="filter_final"
                        string="Final"
                        domain="[('status','=','final')]"/>
                <filter name="filter_with_deficits"
                        string="With deficits"
                        domain="[('deficit_count','>',0)]"/>
                <group expand="0" string="Group by">
                    <filter name="group_status"
                            string="Status"
                            context="{'group_by':'status'}"/>
                    <filter name="group_event"
                            string="Event"
                            context="{'group_by':'event_job_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_neon_deployment_plan"
            model="ir.actions.act_window">
        <field name="name">Deployment Plans</field>
        <field name="res_model">neon.deployment.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No deployment plans yet
            </p>
            <p>
                Open an event job and click "Generate Plan" to
                produce one. Plans walk
                draft -> generated -> reviewed -> final.
            </p>
        </field>
    </record>

    <!-- Server-action wrapper for the "Generate Plan" button
         placed on the event_job form. Inline-return ir.actions
         per the Owl-dashboard pattern (no persisted action). -->
    <record id="server_action_generate_deployment_plan"
            model="ir.actions.server">
        <field name="name">Generate Deployment Plan</field>
        <field name="model_id"
               ref="model_neon_deployment_plan"/>
        <field name="state">code</field>
        <field name="binding_model_id"
               ref="model_commercial_event_job"/>
        <field name="binding_view_types">form</field>
        <field name="code">
ev_ids = env.context.get('active_ids') or (
    [env.context.get('active_id')] if env.context.get('active_id') else [])
if not ev_ids:
    raise UserError("Open an event job first.")
action = env['neon.deployment.plan'].sudo() \
    .action_generate_for_event(ev_ids[0])
        </field>
        <field name="groups_id" eval="[
            (4, ref('neon_jobs.group_neon_jobs_manager')),
            (4, ref('neon_jobs.group_neon_jobs_crew_leader')),
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

    <menuitem id="menu_neon_deployment_plan"
              name="Deployment Plans"
              parent="menu_operations_root"
              action="action_neon_deployment_plan"
              sequence="40"
              groups="neon_jobs.group_neon_jobs_manager,neon_jobs.group_neon_jobs_crew_leader,neon_core.group_neon_superuser"/>

    <menuitem id="menu_neon_deployment_plan_call_time_config"
              name="Call-Time Policy"
              parent="menu_operations_root"
              action="server_action_deployment_plan_call_time_config"
              sequence="60"
              groups="neon_jobs.group_neon_jobs_manager,neon_core.group_neon_superuser"/>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commercial_event_job_readiness_override_wizard_view_form" model="ir.ui.view">
        <field name="name">commercial.event.job.readiness.override.wizard.form</field>
        <field name="model">commercial.event.job.readiness.override.wizard</field>
        <field name="arch" type="xml">
            <form string="Override Readiness Gate">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>Readiness Score below threshold.</strong>
                        Moving to Ready for Dispatch requires a written
                        justification. The acting user and reason will be
                        logged to the Event Job's audit trail.
                    </div>
                    <group>
                        <field name="event_job_id" readonly="1"/>
                        <field name="readiness_score" readonly="1"
                               widget="progressbar"/>
                    </group>
                    <separator string="Current Breakdown"/>
                    <group col="1">
                        <field name="readiness_breakdown" nolabel="1"
                               readonly="1"/>
                    </group>
                    <separator string="Override Reason"/>
                    <group col="1">
                        <field name="override_reason" nolabel="1"
                               placeholder="Why is the override justified? (recorded to the Event Job's chatter)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Override and Move to Ready"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

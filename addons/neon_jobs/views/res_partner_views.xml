<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_view_form_inherit_neon_jobs" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.neon_jobs</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_venue"/>
                <!-- P2.M8 Rapid Ops eligibility. Manual flag is
                     manager-only; the computed badge is read-only and
                     visible to everyone so Sales can see why the fast
                     path is (or isn't) available. -->
                <field name="is_rapid_ops_eligible_manual"
                       groups="neon_jobs.group_neon_jobs_manager"/>
                <field name="has_active_master_contract" invisible="1"/>
                <field name="is_rapid_ops_eligible" widget="boolean_toggle"
                       readonly="1"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Rooms" invisible="not is_venue">
                    <field name="room_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="capacity"/>
                            <field name="floor"/>
                            <field name="notes"/>
                            <field name="active" invisible="1"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <record id="res_partner_action_venues" model="ir.actions.act_window">
        <field name="name">Venues</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('is_venue', '=', True)]</field>
        <field name="context">{'default_is_venue': True, 'default_is_company': True}</field>
    </record>

</odoo>

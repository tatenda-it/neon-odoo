<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commercial_event_job_view_tree" model="ir.ui.view">
        <field name="name">commercial.event.job.tree</field>
        <field name="model">commercial.event.job</field>
        <field name="arch" type="xml">
            <tree string="Event Jobs"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('planning','prep')"
                  decoration-success="state in ('ready_for_dispatch','dispatched','in_progress')"
                  decoration-muted="state in ('completed','closed','cancelled','released')">
                <field name="name"/>
                <field name="commercial_job_id"/>
                <field name="partner_id"/>
                <field name="event_date"/>
                <field name="venue_id"/>
                <field name="venue_room_id" optional="show"/>
                <field name="lead_tech_id"/>
                <field name="crew_chief_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('planning','prep')"
                       decoration-success="state in ('ready_for_dispatch','dispatched','in_progress','completed','closed')"
                       decoration-danger="state in ('cancelled','released')"/>
                <field name="readiness_score" optional="show"/>
                <field name="has_operational_scope" widget="boolean_toggle" optional="hide"/>
                <field name="sub_hire_required" optional="hide"/>
                <field name="logistics_flag" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="commercial_event_job_view_search" model="ir.ui.view">
        <field name="name">commercial.event.job.search</field>
        <field name="model">commercial.event.job</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="commercial_job_id"/>
                <field name="partner_id"/>
                <field name="venue_id"/>
                <field name="lead_tech_id"/>
                <field name="crew_chief_id"/>
                <separator/>
                <filter string="Open"
                        name="filter_open"
                        domain="[('state', 'not in', ('completed','closed','cancelled','released'))]"/>
                <filter string="In Progress"
                        name="filter_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed (not closed)"
                        name="filter_completed_not_closed"
                        domain="[('state', '=', 'completed')]"/>
                <filter string="No Operational Scope"
                        name="filter_no_scope"
                        domain="[('has_operational_scope', '=', False)]"/>
                <separator/>
                <filter string="Event date this month"
                        name="filter_this_month"
                        domain="[('event_date', '&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="State"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Lead Tech"
                            name="group_lead_tech"
                            context="{'group_by': 'lead_tech_id'}"/>
                    <filter string="Client"
                            name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Venue"
                            name="group_venue"
                            context="{'group_by': 'venue_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--
        P3.M2 — Event Job form organised per v4.1 §6 into 10 named
        tabs. Top summary section stays visible across tabs; tabs
        themselves cluster by operational concern. FINANCE tab is
        gated to user/manager (Lead Tech and Crew Leader don't see
        the money fields).
    -->
    <record id="commercial_event_job_view_form" model="ir.ui.view">
        <field name="name">commercial.event.job.form</field>
        <field name="model">commercial.event.job</field>
        <field name="arch" type="xml">
            <form string="Event Job">
                <header>
                    <!-- P3.M3 — state-machine transition buttons. Each
                         is gated by the matching can_move_to_* /
                         can_cancel / can_release computed Boolean, so
                         only the legal "next moves" for the current
                         state + role + gating fields surface. -->
                    <button name="action_move_to_planning" type="object"
                            string="Start Planning"
                            class="oe_highlight"
                            invisible="not can_move_to_planning"/>
                    <button name="action_move_to_prep" type="object"
                            string="Move to Prep"
                            class="oe_highlight"
                            invisible="not can_move_to_prep"/>
                    <button name="action_move_to_ready_for_dispatch" type="object"
                            string="Mark Ready for Dispatch"
                            class="oe_highlight"
                            invisible="not can_move_to_ready_for_dispatch"/>
                    <button name="action_move_to_dispatched" type="object"
                            string="Dispatch"
                            class="oe_highlight"
                            invisible="not can_move_to_dispatched"/>
                    <button name="action_move_to_in_progress" type="object"
                            string="Event Started"
                            class="oe_highlight"
                            invisible="not can_move_to_in_progress"/>
                    <button name="action_move_to_strike" type="object"
                            string="Begin Strike"
                            class="oe_highlight"
                            invisible="not can_move_to_strike"/>
                    <button name="action_move_to_returned" type="object"
                            string="Gear Returned"
                            class="oe_highlight"
                            invisible="not can_move_to_returned"/>
                    <button name="action_move_to_completed" type="object"
                            string="Mark Completed"
                            class="oe_highlight"
                            invisible="not can_move_to_completed"/>
                    <button name="action_move_to_closed" type="object"
                            string="Close Event"
                            class="oe_highlight"
                            invisible="not can_move_to_closed"
                            confirm="Close this Event Job? Closeout finalises the operational record."/>
                    <button name="action_cancel_event_job" type="object"
                            string="Cancel"
                            class="btn-danger"
                            invisible="not can_cancel"
                            confirm="Cancel this Event Job? This is a manager-only terminal action."/>
                    <button name="action_release_event_job" type="object"
                            string="Release"
                            class="btn-secondary"
                            invisible="not can_release"
                            confirm="Release this Event Job from active operations?"/>
                    <field name="can_move_to_planning" invisible="1"/>
                    <field name="can_move_to_prep" invisible="1"/>
                    <field name="can_move_to_ready_for_dispatch" invisible="1"/>
                    <field name="can_move_to_dispatched" invisible="1"/>
                    <field name="can_move_to_in_progress" invisible="1"/>
                    <field name="can_move_to_strike" invisible="1"/>
                    <field name="can_move_to_returned" invisible="1"/>
                    <field name="can_move_to_completed" invisible="1"/>
                    <field name="can_move_to_closed" invisible="1"/>
                    <field name="can_cancel" invisible="1"/>
                    <field name="can_release" invisible="1"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,planning,prep,ready_for_dispatch,dispatched,in_progress,strike,returned,completed,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_commercial_job" type="object"
                                class="oe_stat_button" icon="fa-folder-open">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Commercial Job</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Top summary: always visible above the tabs -->
                    <group>
                        <group>
                            <field name="commercial_job_id" readonly="1"
                                   options="{'no_create': True}"/>
                            <field name="has_operational_scope"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="event_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1 — Identity -->
                        <page string="Identity" name="page_identity">
                            <group>
                                <group string="Reference">
                                    <field name="name" readonly="1"/>
                                    <field name="commercial_job_id" readonly="1"/>
                                    <field name="has_operational_scope"/>
                                </group>
                                <group string="Where &amp; When">
                                    <field name="partner_id" readonly="1"/>
                                    <field name="event_date" readonly="1"/>
                                    <field name="event_end_date" readonly="1"/>
                                    <field name="venue_id" readonly="1"/>
                                    <field name="venue_room_id" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2 — Client -->
                        <page string="Client" name="page_client">
                            <group>
                                <group string="Contact">
                                    <field name="partner_id" readonly="1"/>
                                    <field name="partner_email" readonly="1"/>
                                    <field name="partner_phone" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Client Notes"/>
                            <field name="client_notes" nolabel="1" colspan="2"
                                   placeholder="VIP notes, preferences, sensitivities, brand standards…"/>
                        </page>

                        <!-- Tab 3 — Venue -->
                        <page string="Venue" name="page_venue">
                            <group>
                                <group string="Location">
                                    <field name="venue_id" readonly="1"/>
                                    <field name="venue_room_id" readonly="1"/>
                                    <field name="on_site_contact_id"
                                           options="{'no_create': True}"/>
                                </group>
                            </group>
                            <separator string="Access Notes"/>
                            <field name="venue_access_notes" nolabel="1" colspan="2"
                                   placeholder="Loading dock location, lift dimensions, security desk, time restrictions…"/>
                            <separator string="Parking"/>
                            <field name="parking_arrangements" nolabel="1" colspan="2"
                                   placeholder="Crew parking, gear-truck parking, permits required…"/>
                        </page>

                        <!-- Tab 4 — Schedule -->
                        <page string="Schedule" name="page_schedule">
                            <group>
                                <group string="Event Window">
                                    <field name="event_date" readonly="1"/>
                                    <field name="event_end_date" readonly="1"/>
                                </group>
                                <group string="Operational Timing">
                                    <field name="prep_start_datetime"/>
                                    <field name="dispatch_datetime"/>
                                    <field name="strike_start_datetime"/>
                                    <field name="return_eta_datetime"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 5 — Scope -->
                        <page string="Scope" name="page_scope">
                            <group>
                                <group string="Footprint">
                                    <field name="expected_attendee_count"/>
                                    <field name="scope_complexity"/>
                                </group>
                            </group>
                            <separator string="Equipment Summary"/>
                            <field name="equipment_summary" nolabel="1" colspan="2"
                                   placeholder="High-level kit list, sub-hire notes, special requirements…"/>
                        </page>

                        <!-- Tab 6 — Finance (manager / sales only) -->
                        <page string="Finance" name="page_finance"
                              groups="neon_jobs.group_neon_jobs_user,neon_jobs.group_neon_jobs_manager">
                            <group>
                                <group string="Quotation">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="quoted_value" widget="monetary"/>
                                    <field name="deposit_received" widget="monetary"/>
                                </group>
                                <group string="Status">
                                    <field name="finance_status" widget="badge"/>
                                </group>
                            </group>
                            <div class="text-muted" role="alert">
                                Read-only mirror of the Commercial Job's
                                finance fields. Edit on the source job;
                                changes propagate here.
                            </div>
                        </page>

                        <!-- Tab 7 — People -->
                        <page string="People" name="page_people">
                            <group>
                                <group string="Operational Owners">
                                    <field name="lead_tech_id"
                                           options="{'no_create': True}"/>
                                    <field name="crew_chief_id" readonly="1"/>
                                </group>
                                <group string="Crew Coverage">
                                    <field name="crew_total_count" readonly="1"/>
                                    <field name="crew_confirmed_count" readonly="1"/>
                                </group>
                            </group>
                            <div class="text-muted" role="alert">
                                Crew assignments are managed on the
                                Commercial Job's Crew tab. The Crew
                                Chief is the assignment flagged
                                "Crew Chief" there.
                            </div>
                        </page>

                        <!-- Tab 8 — Equipment -->
                        <page string="Equipment" name="page_equipment">
                            <group>
                                <group>
                                    <field name="equipment_count" readonly="1"/>
                                    <field name="sub_hire_required" readonly="1"/>
                                    <field name="logistics_flag" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Equipment Summary"/>
                            <field name="equipment_summary" nolabel="1" colspan="2"
                                   placeholder="Main items: line array PA, monitor mix, moving heads, dimmer packs, sub-hire…"/>
                            <div class="text-muted" role="alert">
                                Phase 5 replaces this free-form summary
                                with per-item equipment movement
                                records linked to event_job.
                            </div>
                        </page>

                        <!-- Tab 9 — Quality (Readiness) -->
                        <page string="Quality" name="page_quality">
                            <group>
                                <group string="Aggregate">
                                    <field name="readiness_score" readonly="1"/>
                                </group>
                                <group string="Dimensions">
                                    <field name="readiness_dimension_finance" readonly="1"/>
                                    <field name="readiness_dimension_equipment" readonly="1"/>
                                    <field name="readiness_dimension_crew" readonly="1"/>
                                    <field name="readiness_dimension_schedule_venue" readonly="1"/>
                                    <field name="readiness_dimension_checklist" readonly="1"/>
                                    <field name="readiness_dimension_risk" readonly="1"/>
                                </group>
                            </group>
                            <div class="text-muted" role="alert">
                                Readiness Score and its six dimensions
                                are placeholders. P3.M4 wires the
                                compute against checklist completeness,
                                crew coverage, gear staging, etc.
                            </div>
                        </page>

                        <!-- Tab 10 — Closeout -->
                        <page string="Closeout" name="page_closeout">
                            <group>
                                <group string="Checkpoints">
                                    <field name="gear_reconciled"/>
                                    <field name="finance_handoff_complete"/>
                                </group>
                                <group string="Closed At">
                                    <field name="closeout_completed_at" readonly="1"/>
                                </group>
                            </group>
                            <separator string="Lead Tech Notes"/>
                            <field name="lead_tech_notes" nolabel="1" colspan="2"
                                   placeholder="Prep notes, briefing points, on-the-day decisions…"/>
                            <separator string="Crew Observations"/>
                            <field name="crew_observations" nolabel="1" colspan="2"
                                   placeholder="What the crew saw on site — what worked, what didn't…"/>
                            <separator string="Client Feedback"/>
                            <field name="client_feedback" nolabel="1" colspan="2"
                                   placeholder="What the client said on the day, post-event feedback…"/>
                            <separator string="Incidents Log"/>
                            <field name="incidents_log" nolabel="1" colspan="2"
                                   placeholder="Free-form incident notes. Phase 4 introduces a structured incident model."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="commercial_event_job_action" model="ir.actions.act_window">
        <field name="name">Event Jobs</field>
        <field name="res_model">commercial.event.job</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="commercial_event_job_view_search"/>
        <field name="context">{'search_default_filter_open': 1}</field>
        <!-- P3.M1 — action gated to user/manager/crew_leader. Crew tier
             reaches event_jobs only via the My Schedule action path
             (P3.M8 will add this); the ir.rule above scopes them to
             own crewed events when they get there. -->
        <field name="groups_id" eval="[(6, 0, [
            ref('neon_jobs.group_neon_jobs_user'),
            ref('neon_jobs.group_neon_jobs_manager'),
            ref('neon_jobs.group_neon_jobs_crew_leader'),
        ])]"/>
    </record>

</odoo>

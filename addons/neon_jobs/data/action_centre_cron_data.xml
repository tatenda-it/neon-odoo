<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        P4.M4 — Action Centre cron jobs.

        Two crons:

          1. Hourly escalation check — iterates open items past
             their escalation window and bumps them to the next
             tier per trigger_config.escalated_to_role.

          2. Daily time-based trigger evaluation — scaffolding for
             P4.M5+ to plug in sla_passed / closeout_overdue /
             feedback_followup evaluators. Today it just logs the
             count of enabled time-based configs.

        noupdate="1" so director toggles (active flag, schedule
        adjustments) survive module upgrades — same pattern as the
        existing ir_cron_soft_hold_expiry record.
    -->
    <data noupdate="1">

        <record id="ir_cron_action_centre_escalations" model="ir.cron">
            <field name="name">Action Centre: Check Escalations</field>
            <field name="model_id" ref="model_action_centre_item"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_escalations()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

        <record id="ir_cron_action_centre_time_based_triggers" model="ir.cron">
            <field name="name">Action Centre: Time-based Triggers</field>
            <field name="model_id" ref="model_action_centre_item"/>
            <field name="state">code</field>
            <field name="code">model._cron_evaluate_time_based_triggers()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall"
                   eval="(DateTime.now().replace(hour=0, minute=30, second=0, microsecond=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>

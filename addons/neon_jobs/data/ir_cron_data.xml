<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_soft_hold_expiry" model="ir.cron">
            <field name="name">Neon Jobs: Soft Hold Expiry Notifications</field>
            <field name="model_id" ref="model_commercial_job"/>
            <field name="state">code</field>
            <field name="code">model.cron_process_soft_hold_expiry()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>

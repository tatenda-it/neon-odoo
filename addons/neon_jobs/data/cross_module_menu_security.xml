<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        P2.M7.6 D2 — gate the top-level menus of Sales, CRM, and
        Accounting/Invoicing to neon_jobs_user + neon_jobs_manager.

        Users with ONLY crew or crew_leader (no user/manager) lose
        visibility on these standard-module menus. Sales reps and
        managers — who explicitly carry neon_jobs_user/manager — are
        unaffected.

        These records overlay each module's existing menu definition.
        groups_id semantics on ir.ui.menu: empty = anyone with model
        access; non-empty = membership in at least one listed group.
        We REPLACE rather than append so the gate is unambiguous.

        Edge case (flagged in spec): an Odoo Salesperson without any
        neon_jobs_* group would lose access. The 17.0.1.7.1 post-
        migrate logs a warning if this occurs.

        noupdate is off so the gate re-applies on every -u in case a
        future Odoo upgrade resets the upstream groups_id.
    -->
    <data>

        <record id="sale.sale_menu_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('neon_jobs.group_neon_jobs_user'),
                ref('neon_jobs.group_neon_jobs_manager'),
            ])]"/>
        </record>

        <record id="crm.crm_menu_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('neon_jobs.group_neon_jobs_user'),
                ref('neon_jobs.group_neon_jobs_manager'),
            ])]"/>
        </record>

        <!-- P2.M7.7 D4: Invoicing tightened to manager only. Sales reps
             see invoice status via sale.order smart buttons; they don't
             need direct Accounting/Invoicing menu access. -->
        <record id="account.menu_finance" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('neon_jobs.group_neon_jobs_manager'),
            ])]"/>
        </record>

        <!-- P2.M7.7 D3: Spreadsheet Dashboards top-level menu was
             unrestricted — visible to crew. Gate to manager + admin
             only. -->
        <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('neon_jobs.group_neon_jobs_manager'),
                ref('base.group_system'),
            ])]"/>
        </record>

        <!-- P2.M7.7.3: standard Odoo Apps menus carry NO groups_id
             out of the box in this build, so any internal user can
             reach the module installer. Lock both Apps top-level
             menus down to admin only. -->
        <record id="base.menu_management" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('base.group_system'),
            ])]"/>
        </record>

        <record id="base.menu_apps" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('base.group_system'),
            ])]"/>
        </record>

        <!-- P2.M7.7.3: utm.menu_link_tracker_root is gated to
             base.group_no_one ("Technical Features"), which in this
             DB is implied by base.group_user thanks to a third-party
             module — so every internal user sees Link Tracker. Tighten
             to manager + admin without unwinding the upstream
             implication. -->
        <record id="utm.menu_link_tracker_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('neon_jobs.group_neon_jobs_manager'),
                ref('base.group_system'),
            ])]"/>
        </record>

    </data>
</odoo>

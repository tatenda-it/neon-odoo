    </record>

    <!-- 8 — Equipment Return (post-event, Lead Tech + Finance) -->
    <record id="checklist_template_returned" model="commercial.checklist.template">
        <field name="type">returned</field>
        <field name="sequence">80</field>
    </record>
    <record id="checklist_item_rt_1" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_returned"/>
        <field name="sequence">10</field>
        <field name="name">All items returned to workshop and signed in</field>
    </record>
    <record id="checklist_item_rt_2" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_returned"/>
        <field name="sequence">20</field>
        <field name="name">Inventory reconciled against event manifest</field>
    </record>
    <record id="checklist_item_rt_3" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_returned"/>
        <field name="sequence">30</field>

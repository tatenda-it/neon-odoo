        <field name="type">closeout</field>
        <field name="sequence">90</field>
    </record>
    <record id="checklist_item_co_1" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_closeout"/>
        <field name="sequence">10</field>
        <field name="name">Final invoice issued and dispatched to client</field>
    </record>
    <record id="checklist_item_co_2" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_closeout"/>
        <field name="sequence">20</field>
        <field name="name">Outstanding balance status confirmed with Finance</field>
    </record>
    <record id="checklist_item_co_3" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_closeout"/>
        <field name="sequence">30</field>
        <field name="name">Post-event debrief completed with crew</field>
    </record>
    <record id="checklist_item_co_4" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_closeout"/>
        <field name="sequence">40</field>
        <field name="name">Client feedback captured</field>
    </record>
    <record id="checklist_item_co_5" model="commercial.checklist.template.item">
        <field name="template_id" ref="checklist_template_closeout"/>
        <field name="sequence">50</field>
        <field name="name">Incidents log reviewed; follow-ups assigned</field>
    </record>

</odoo>

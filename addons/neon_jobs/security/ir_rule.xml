<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Crew tier (group_neon_jobs_crew) can read and write only
            their own commercial.job.crew assignments. Combined with
            the read+write (no create/unlink) CSV grant, this lets
            crew confirm or decline their own assignments and surfaces
            nothing else from the model.

            Managers and Crew Leaders bypass this rule via their own
            unrestricted CSV access (rules are OR-combined per group).
        -->
        <record id="rule_commercial_job_crew_own_only" model="ir.rule">
            <field name="name">Crew: read+write own assignments only</field>
            <field name="model_id" ref="model_commercial_job_crew"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P2.M7.7.3 — deep-link defense for crew tier on
            commercial.job. The action_window gate above blocks the
            "Commercial Jobs" navigation entry, but a crew user could
            still reach the model via constructed URLs. This rule
            constrains crew reads to records where they are a confirmed
            or pending crew member. Without this, crew tier could see
            the full client roster, venues, and event metadata for
            every job in the system — a real concern given Neon's mix
            of permanent and freelance technicians.

            Managers, sales reps, and crew leaders bypass via their
            unrestricted CSV access (rules OR-combine per group).
        -->
        <record id="commercial_job_rule_crew_own" model="ir.rule">
            <field name="name">Crew: own crewed jobs only</field>
            <field name="model_id" ref="model_commercial_job"/>
            <field name="domain_force">[('crew_assignment_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P3.M1 — Event Job visibility for crew tier. Crew sees only
            event_jobs whose parent commercial.job has them in
            crew_assignment_ids. Other roles (user, manager,
            crew_leader) get unrestricted access via their CSV grants.
        -->
        <record id="commercial_event_job_rule_crew_own" model="ir.rule">
            <field name="name">Event Job: crew sees own events only</field>
            <field name="model_id" ref="model_commercial_event_job"/>
            <field name="domain_force">[('commercial_job_id.crew_assignment_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Neon Operations module category.

            Houses the access-rights dropdown that exposes the
            two neon_jobs groups in the user form. Sequence 40
            keeps it adjacent to the existing Operations cluster
            in the Odoo settings layout.
        -->
        <record id="module_category_neon_operations" model="ir.module.category">
            <field name="name">Neon Operations</field>
            <field name="description">Access rights for the Neon Operations app — Commercial Jobs, Master Contracts, Crew, Venues.</field>
            <field name="sequence">40</field>
        </record>

        <!--
            Neon Operations: User.

            Default tier. Granted automatically to all internal
            users (base.group_user implies this group). Read /
            write / create on Commercial Jobs and related models;
            no unlink and no override authority on state
            transitions.
        -->
        <record id="group_neon_jobs_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_neon_operations"/>
            <field name="comment">Default Operations access — read/write/create Commercial Jobs and Master Contracts. Cannot delete records and cannot override state-transition rules.</field>
        </record>

        <!--
            Neon Operations: Manager.

            MD/OD tier. Implies User. Adds unlink rights and
            bypasses the state-transition matrix in commercial_job
            and commercial_job_master (e.g. archive without
            loss_reason, reopen completed jobs, jump non-linear
            status track moves). Per Robin Q3 — either MD or OD
            individually has override authority.
        -->
        <record id="group_neon_jobs_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_neon_operations"/>
            <field name="implied_ids" eval="[(4, ref('group_neon_jobs_user'))]"/>
            <field name="comment">Override authority on state transitions and full CRUD including delete. Intended for Managing Director and Operational Director.</field>
        </record>

        <!--
            base.group_user.implied_ids += group_neon_jobs_user is
            applied imperatively in __init__.py:_post_init_hook and
            in migrations/17.0.1.1.0/post-migrate.py — declarative
            XML cannot update base.group_user because its
            ir_model_data row carries noupdate=true from the base
            module install.
        -->

        <!--
            Neon Operations: Crew (P2.M7).

            Limited tier for crew members who have Odoo logins (most
            crew won't, but some will). Read-only access to their own
            Commercial Job and Crew Assignment records via the
            "My Schedule" dashboard. Independent of User and Manager —
            crew is not a subset of either, and neither implies it.
        -->
        <record id="group_neon_jobs_crew" model="res.groups">
            <field name="name">Crew Member (Limited Schedule View)</field>
            <field name="category_id" ref="module_category_neon_operations"/>
            <field name="comment">Read-only access to Commercial Jobs and Crew Assignments via "My Schedule". For crew members with Odoo logins. Independent of User/Manager — neither implies this group.</field>
        </record>

        <!--
            Neon Operations: Crew Leader / Lead Tech (P2.M7.5).

            Operational oversight tier: full CRUD on crew assignments,
            read/write on Commercial Jobs (no create/delete). Sees the
            Operations Dashboard MINUS the cash-flow section, plus the
            Commercial Job form MINUS finance fields (quoted_value,
            deposit_received, finance_status track). Sales reps cannot
            assign crew; that authority lives here and with Managers.

            Independent of User/Manager/Crew — none implies, none is
            implied. Granted manually to specific users (Lead Techs).
        -->
        <record id="group_neon_jobs_crew_leader" model="res.groups">
            <field name="name">Crew Leader / Lead Tech</field>
            <field name="category_id" ref="module_category_neon_operations"/>
            <field name="comment">Lead Tech / Crew Supervisor — operational oversight and crew assignment authority. No finance visibility.</field>
        </record>

    </data>
</odoo>

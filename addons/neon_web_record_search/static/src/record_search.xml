<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- The record-search widget: core AutoComplete, no chrome of its own
         (it blends into the native .o_searchview box; the native search icon
         sits to its left, the Filters button to its right). -->
    <t t-name="neon_web_record_search.NeonRecordSearch">
        <div class="o_neon_recsearch" t-if="resModel">
            <AutoComplete
                value="''"
                sources="sources"
                placeholder="'Search…'"
                onSelect.bind="onSelect"
                resetOnSelect="true"
                class="'o_neon_recsearch_ac'"
            />
        </div>
    </t>

    <!-- Make the record-search the PRIMARY visible search: inject it into the
         native SearchBar's input container. Facet chips (web.SearchBar.Facets)
         and the SearchBarMenu (Filters / Group By / Favorites / Saved searches)
         are KEPT; the native facet typing input is hidden via scss. Guarded to
         search views that have an active model. -->
    <t t-inherit="web.SearchBar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_searchview_input_container')]" position="inside">
            <NeonRecordSearch t-if="env.searchModel and env.searchModel.resModel"/>
        </xpath>
    </t>

</templates>

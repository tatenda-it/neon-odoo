<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bot_user_form" model="ir.ui.view">
        <field name="name">neon.bot.user.form</field>
        <field name="model">neon.bot.user</field>
        <field name="arch" type="xml">
            <form string="Bot User">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="phone_number"/>
                        <field name="user_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bot_user_tree" model="ir.ui.view">
        <field name="name">neon.bot.user.tree</field>
        <field name="model">neon.bot.user</field>
        <field name="arch" type="xml">
            <tree string="Bot Users">
                <field name="name"/>
                <field name="phone_number"/>
                <field name="user_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_bot_users" model="ir.actions.act_window">
        <field name="name">Bot Users</field>
        <field name="res_model">neon.bot.user</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <menuitem id="menu_bot_users"
        name="Bot Users"
        parent="menu_neon_whatsapp_root"
        action="action_bot_users"
        sequence="30"
        groups="base.group_system"/>
</odoo>

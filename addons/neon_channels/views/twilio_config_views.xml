<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_twilio_config_form" model="ir.ui.view">
        <field name="name">twilio.config.form</field>
        <field name="model">twilio.config</field>
        <field name="arch" type="xml">
            <form string="Twilio Configuration">
                <header>
                    <button name="test_connection" type="object" string="Test Connection" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Account Details">
                            <field name="name"/>
                            <field name="account_sid"/>
                            <field name="auth_token" password="True"/>
                        </group>
                        <group string="Phone Numbers">
                            <field name="phone_number"/>
                            <field name="whatsapp_number"/>
                        </group>
                    </group>
                    <group string="WhatsApp Bot — Authorised Numbers">
                        <field name="authorised_numbers" nolabel="1"
                            placeholder="+263771234567, +263772345678, +263773456789"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_twilio_config_list" model="ir.ui.view">
        <field name="name">twilio.config.list</field>
        <field name="model">twilio.config</field>
        <field name="arch" type="xml">
            <list string="Twilio Configuration">
                <field name="name"/>
                <field name="account_sid"/>
                <field name="phone_number"/>
                <field name="whatsapp_number"/>
            </list>
        </field>
    </record>

    <record id="action_twilio_config" model="ir.actions.act_window">
        <field name="name">Twilio Configuration</field>
        <field name="res_model">twilio.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_twilio_config"
        name="Twilio"
        parent="menu_neon_channels_root"
        action="action_twilio_config"
        sequence="20"/>
</odoo>

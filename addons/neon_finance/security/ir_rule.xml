<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            P6.M2 — quote record rules. Sales see only their own
            quotes; Bookkeeper and Approver see all. The CSV grants
            both Bookkeeper and Approver unrestricted R/W/C on the
            model; an unconditional rule on each group is required so
            those grants survive the OR-combine with the sales-tier
            restriction (Odoo evaluates all rules for a user; a
            restrictive rule on one group still applies unless an
            unconditional rule on another group lifts it).

            Unlink: quote-LEVEL rules stay perm_unlink=False (CSV
            perm_unlink=0 blocks quote deletion — append-only). Quote
            LINES were amended 2026-07-02 (director approval, Robin):
            lines ARE deletable while the parent quote is DRAFT — a
            draft is not yet an approved financial record. The three
            quote.line group rules below carry perm_unlink=True so
            their visibility domains also govern unlink (sales =
            own-quote only), and the GLOBAL rule
            quote_line_rule_unlink_draft_only hard-ANDs the draft-state
            scope for everyone. From submission onward lines are
            immutable as before. NOTE noupdate="1": the perm_unlink
            flips on the three existing rules reach existing installs
            via the 17.0.7.17.6 migration, not -u.
        -->

        <record id="quote_rule_sales_own_only" model="ir.rule">
            <field name="name">Quote: Sales see own only</field>
            <field name="model_id" ref="model_neon_finance_quote"/>
            <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_sales'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="quote_rule_bookkeeper_all" model="ir.rule">
            <field name="name">Quote: Bookkeeper sees all</field>
            <field name="model_id" ref="model_neon_finance_quote"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="quote_rule_approver_all" model="ir.rule">
            <field name="name">Quote: Approver sees all</field>
            <field name="model_id" ref="model_neon_finance_quote"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P6.M2 — quote.line follows the same triangle scoped via
            the line's parent quote_id. Sales reps can only see /
            edit lines whose quote they own.
        -->
        <record id="quote_line_rule_sales_own_only" model="ir.rule">
            <field name="name">Quote Line: Sales see own quote's lines only</field>
            <field name="model_id" ref="model_neon_finance_quote_line"/>
            <field name="domain_force">[('quote_id.salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_sales'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="quote_line_rule_bookkeeper_all" model="ir.rule">
            <field name="name">Quote Line: Bookkeeper sees all</field>
            <field name="model_id" ref="model_neon_finance_quote_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="quote_line_rule_approver_all" model="ir.rule">
            <field name="name">Quote Line: Approver sees all</field>
            <field name="model_id" ref="model_neon_finance_quote_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!--
            2026-07-02 (director approval, Robin) — draft-only line
            delete. GLOBAL rule (no groups) = hard AND for every
            non-superuser: quote LINES may be unlinked ONLY while the
            parent quote is still a draft. From submit_for_approval
            onward lines are immutable (append-only), matching the
            form view which already locks line_ids post-draft. Applies
            only to unlink; read/write/create are untouched.
        -->
        <record id="quote_line_rule_unlink_draft_only" model="ir.rule">
            <field name="name">Quote Line: unlink only while quote is draft</field>
            <field name="model_id" ref="model_neon_finance_quote_line"/>
            <field name="domain_force">[('quote_id.state', '=', 'draft')]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!--
            P6.M4 — approval queue scoping. Sales reps see only
            approvals attached to their own quotes (read-only); both
            bookkeeper and approver see all. Approver has the write
            grant from the CSV; bookkeeper is read-only on workflow.
            No unlink for any group — append-only audit trail.
        -->
        <record id="approval_rule_sales_own_only" model="ir.rule">
            <field name="name">Approval: Sales see own quote approvals only</field>
            <field name="model_id" ref="model_neon_finance_approval"/>
            <field name="domain_force">[('quote_id.salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_sales'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="approval_rule_bookkeeper_all" model="ir.rule">
            <field name="name">Approval: Bookkeeper sees all</field>
            <field name="model_id" ref="model_neon_finance_approval"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="approval_rule_approver_all" model="ir.rule">
            <field name="name">Approval: Approver sees all</field>
            <field name="model_id" ref="model_neon_finance_approval"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P6.M5 — cost.line scoping. Crew leader (Ranganai) sees +
            records cost on event_jobs where they are the lead_tech.
            Bookkeeper + Approver see all. perm_unlink=False on every
            rule: append-only audit trail.

            Sales-tier scoping is INTENTIONALLY ABSENT (Option A from
            P6.M5 design pause). event_job has no salesperson_id and
            adding a derived one is M6+ polish work. Sales reps see
            the P&L mini-statement on the event_job form via the
            standard neon_jobs ACL on commercial.event.job.
        -->
        <record id="cost_line_rule_crew_leader_own" model="ir.rule">
            <field name="name">Cost Line: Crew Leader sees own event_jobs only</field>
            <field name="model_id" ref="model_neon_finance_cost_line"/>
            <field name="domain_force">[('event_job_id.lead_tech_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew_leader'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="cost_line_rule_bookkeeper_all" model="ir.rule">
            <field name="name">Cost Line: Bookkeeper sees all</field>
            <field name="model_id" ref="model_neon_finance_cost_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="cost_line_rule_approver_all" model="ir.rule">
            <field name="name">Cost Line: Approver sees all</field>
            <field name="model_id" ref="model_neon_finance_cost_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="cost_line_rule_jobs_manager_all" model="ir.rule">
            <field name="name">Cost Line: Jobs Manager sees all</field>
            <field name="model_id" ref="model_neon_finance_cost_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P6.M7 — invoice schedule scoping. Sales reps see only
            schedules attached to their own quotes; bookkeeper +
            approver see all. perm_unlink=False on every rule:
            append-only financial record.
        -->
        <record id="invoice_schedule_rule_sales_own_only"
                model="ir.rule">
            <field name="name">Invoice Schedule: Sales see own quotes only</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule"/>
            <field name="domain_force">[('quote_id.salesperson_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_sales'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="invoice_schedule_rule_bookkeeper_all"
                model="ir.rule">
            <field name="name">Invoice Schedule: Bookkeeper sees all</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="invoice_schedule_rule_approver_all"
                model="ir.rule">
            <field name="name">Invoice Schedule: Approver sees all</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            P6.M7 — schedule template scoping. Sales reps see + manage
            templates for clients on quotes they own (via partner_id
            chain through any quote). Bookkeeper + approver see all.
        -->
        <record id="invoice_schedule_template_rule_sales_own_clients"
                model="ir.rule">
            <field name="name">Schedule Template: Sales see own clients only</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule_template"/>
            <field name="domain_force">[
                ('partner_id', 'in',
                 user.env['neon.finance.quote'].sudo().search(
                     [('salesperson_id', '=', user.id)]
                 ).mapped('partner_id').ids
                )
            ]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_sales'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="invoice_schedule_template_rule_bookkeeper_all"
                model="ir.rule">
            <field name="name">Schedule Template: Bookkeeper sees all</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule_template"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_bookkeeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="invoice_schedule_template_rule_approver_all"
                model="ir.rule">
            <field name="name">Schedule Template: Approver sees all</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule_template"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('neon_finance.group_neon_finance_approver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

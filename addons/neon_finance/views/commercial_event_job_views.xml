<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        P6.M5 — extend commercial.event.job form with two new tabs:
        Cost Lines (embedded list of neon.finance.cost.line) and
        Financial Summary (rendered P&L mini-statement HTML).

        Insertion point: right after the existing "Finance" page (which
        mirrors commercial.job financials, see addons/neon_jobs/views/
        commercial_event_job_views.xml). Keeping cost/P&L visually
        adjacent to the existing finance summary makes the form read
        naturally for the operational + finance audience.
    -->
    <record id="commercial_event_job_view_form_neon_finance_extension"
            model="ir.ui.view">
        <field name="name">commercial.event.job.form.neon_finance.cost</field>
        <field name="model">commercial.event.job</field>
        <field name="inherit_id"
               ref="neon_jobs.commercial_event_job_view_form"/>
        <field name="arch" type="xml">
            <!--
                P6.M6 banner. Sits above the sheet so it's visible
                regardless of which notebook tab is active. Only
                renders when suggest_reapproval=True (set by the
                _dispatch_budget_alert helper on severe escalation,
                or manually flipped by an approver). The Acknowledge
                button clears the flag without touching
                budget_alert_level (the level is data-derived; the
                flag is action-required).
            -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning"
                     role="alert"
                     invisible="not suggest_reapproval"
                     style="margin: 8px 16px;">
                    <strong>Severely over budget.</strong>
                    Cost vs quoted budget has exceeded the severe
                    threshold. Consider re-quoting and re-approving
                    via the standard quote workflow. Acknowledge to
                    clear the banner (the level stays, only the
                    action-required flag is reset.
                    <button name="action_acknowledge_over_budget"
                            type="object"
                            string="Acknowledge over-budget"
                            class="btn btn-warning btn-sm"
                            groups="neon_finance.group_neon_finance_approver"/>
                </div>
                <!--
                    P6.M11 banner. Visible to ALL roles (sales sees
                    it too, per design pause) so client-relationship
                    awareness is in place. The Create Cost Recovery
                    Invoice button is approver-only via groups
                    attribute; sales sees the banner but no action.
                    The invisible field below makes pending_cost_recovery
                    available to the modifier without rendering it.
                -->
                <field name="pending_cost_recovery" invisible="1"/>
                <div class="alert alert-info"
                     role="alert"
                     invisible="not pending_cost_recovery"
                     style="margin: 8px 16px;">
                    <strong>Cost recovery pending.</strong>
                    A client-caused write-off has been recorded on
                    this event. Bookkeeper / Approver review needed
                    before invoicing the client.
                    <button name="action_open_cost_recovery_wizard"
                            type="object"
                            string="Create Cost Recovery Invoice"
                            class="btn btn-info btn-sm"
                            groups="neon_finance.group_neon_finance_approver"/>
                </div>
            </xpath>
            <xpath expr="//page[@name='page_finance']"
                   position="after">
                <page string="Budgets" name="page_neon_finance_budgets">
                    <group>
                        <group string="Initial budget (salesperson)">
                            <field name="initial_budget"
                                   widget="monetary"/>
                            <field name="initial_budget_currency_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Quoted budget (auto-stamped)">
                            <field name="quoted_budget"
                                   widget="monetary"
                                   readonly="1"/>
                            <field name="quoted_budget_currency_id"
                                   readonly="1"/>
                        </group>
                    </group>
                    <p class="text-muted">
                        Initial budget is salesperson-entered at
                        event_job creation. Quoted budget auto-stamps
                        from the linked quote.amount_total when that
                        quote transitions to 'accepted'.
                    </p>
                </page>
                <page string="Cost Lines" name="page_neon_finance_costs">
                    <field name="cost_line_ids"
                           context="{'default_event_job_id': id}">
                        <tree string="Cost Lines" editable="bottom">
                            <field name="date_incurred"/>
                            <field name="cost_type"/>
                            <field name="name"/>
                            <field name="vendor_id"
                                   options="{'no_create': True}"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id"
                                   options="{'no_create': True}"/>
                            <field name="payment_state"
                                   widget="badge"/>
                            <field name="recorded_by_id"
                                   readonly="1"
                                   optional="show"/>
                        </tree>
                    </field>
                    <group>
                        <group>
                            <field name="cost_total_usd"
                                   widget="monetary"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="cost_total_zig"
                                   widget="monetary"
                                   readonly="1"/>
                        </group>
                    </group>
                </page>
                <page string="Financial Summary"
                      name="page_neon_finance_pnl">
                    <group>
                        <group string="Budget Status">
                            <field name="budget_alert_level"
                                   widget="badge"
                                   decoration-success="budget_alert_level == 'ok'"
                                   decoration-warning="budget_alert_level == 'warn'"
                                   decoration-danger="budget_alert_level in ('breach','severe')"
                                   readonly="1"/>
                            <field name="last_alert_dispatched_at"
                                   readonly="1"/>
                            <field name="suggest_reapproval"
                                   readonly="1"/>
                        </group>
                    </group>
                    <field name="pnl_html"
                           widget="html"
                           readonly="1"
                           nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

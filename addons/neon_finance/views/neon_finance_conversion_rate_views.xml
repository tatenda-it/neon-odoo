<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_finance_conversion_rate_view_tree"
            model="ir.ui.view">
        <field name="name">neon.finance.conversion.rate.tree</field>
        <field name="model">neon.finance.conversion.rate</field>
        <field name="arch" type="xml">
            <tree string="Conversion Rates" default_order="effective_date desc">
                <field name="name"/>
                <field name="effective_date"/>
                <field name="usd_per_zig"/>
                <field name="zig_per_usd"/>
                <field name="source_note" optional="show"/>
                <field name="set_by_id"/>
                <field name="set_at"/>
            </tree>
        </field>
    </record>

    <record id="neon_finance_conversion_rate_view_form"
            model="ir.ui.view">
        <field name="name">neon.finance.conversion.rate.form</field>
        <field name="model">neon.finance.conversion.rate</field>
        <field name="arch" type="xml">
            <form string="Conversion Rate">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Effective">
                            <field name="effective_date"/>
                            <field name="source_note"/>
                        </group>
                        <group string="Rate">
                            <field name="usd_per_zig"/>
                            <field name="zig_per_usd"/>
                        </group>
                    </group>
                    <group string="Audit">
                        <field name="set_by_id" readonly="1"/>
                        <field name="set_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neon_finance_conversion_rate_action"
            model="ir.actions.act_window">
        <field name="name">Conversion Rates</field>
        <field name="res_model">neon.finance.conversion.rate</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No conversion rates yet
            </p>
            <p>
                Kudzi or an approver records the active USD/ZiG rate
                here. One row per effective_date — rates are dated
                so historical quotes reconcile against the rate that
                applied on the quote date.
            </p>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_finance_quote_view_tree" model="ir.ui.view">
        <field name="name">neon.finance.quote.tree</field>
        <field name="model">neon.finance.quote</field>
        <field name="arch" type="xml">
            <tree string="Quotes"
                  decoration-muted="state in ('cancelled','expired','rejected')"
                  decoration-success="state == 'accepted'"
                  decoration-info="state == 'sent'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="event_job_id"/>
                <field name="currency_id"/>
                <field name="amount_total" widget="monetary"
                       sum="Total"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'accepted'"
                       decoration-info="state == 'sent'"
                       decoration-warning="state == 'pending_approval'"
                       decoration-danger="state in ('rejected','expired')"
                       decoration-muted="state == 'cancelled'"/>
                <field name="salesperson_id"/>
                <field name="quotation_date"/>
                <field name="expires_at"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="neon_finance_quote_view_form" model="ir.ui.view">
        <field name="name">neon.finance.quote.form</field>
        <field name="model">neon.finance.quote</field>
        <field name="arch" type="xml">
            <form string="Quote">
                <header>
                    <!-- QUOTE-UX-1b: the Preview is PERSISTENT across every
                         ACTIVE pipeline stage (draft through accepted), not
                         just draft &#8212; mirroring the stock sale.order
                         always-visible btn-secondary Preview that sits next to
                         the action cluster. It stays leftmost in the header, so
                         at every stage "see the document" is one click left of
                         the stage's primary action (Submit / Approve / Send).
                         ONE button: action_preview_quote renders the
                         state-correct face of the SAME report &#8212; the DRAFT
                         banner shows while draft/pending_approval, and the
                         final client document once approved/sent/accepted (the
                         report is already state-aware, report lines 57-62).
                         Hidden only in the terminal states (rejected /
                         expired / cancelled) where there is no client document
                         to show. Not a forced gate &#8212; always available,
                         never mandatory. config=False is inherited from the
                         method so admins/directors get the PDF, not the layout
                         wizard. -->
                    <button name="action_preview_quote"
                            type="object"
                            string="Preview"
                            class="btn-secondary"
                            invisible="state not in ('draft','pending_approval','approved','sent','accepted')"
                            help="Review the full quote (lines, rates, qty, duration, VAT, total) as the client-facing PDF. Available at every active stage: shows the DRAFT-stamped document while the quote is a draft or pending approval, and the final client document once it is approved, sent, or accepted."/>
                    <button name="action_submit_for_approval"
                            type="object"
                            string="Submit for Approval"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'pending_approval'"
                            groups="neon_finance.group_neon_finance_approver"/>
                    <button name="action_reject"
                            type="object"
                            string="Reject"
                            invisible="state != 'pending_approval'"
                            groups="neon_finance.group_neon_finance_approver"
                            context="{'rejection_reason': 'Rejected via form'}"/>
                    <button name="action_send"
                            type="object"
                            string="Send to Client"
                            class="oe_highlight"
                            invisible="state != 'approved'"/>
                    <button name="action_accept"
                            type="object"
                            string="Mark Accepted"
                            class="oe_highlight"
                            invisible="state != 'sent'"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            invisible="state in ('accepted','rejected','expired','cancelled')"
                            context="{'cancelled_reason': 'Cancelled via form'}"/>
                    <button name="action_open_payment_term_wizard"
                            type="object"
                            string="Set Payment Terms"
                            invisible="state != 'draft'"/>
                    <!-- QUOTE-UX-3b: whole-quote discount, the form face of the
                         shared neon.finance.quote.apply_whole_quote_discount
                         (same method WhatsApp uses). Distributes a uniform
                         per-line discount_pct + sets wa12_discount_note.
                         Draft-only. NOT the stock account global discount. -->
                    <button name="action_open_whole_quote_discount_wizard"
                            type="object"
                            string="Apply Whole-Quote Discount"
                            invisible="state != 'draft'"
                            help="Take a single discount off the whole quote (a fixed amount or a target total, VAT-inclusive or ex-VAT). It is distributed across the line discounts; the achieved drop is labelled on the summary and the PDF."/>
                    <button name="action_recalculate_pricing"
                            type="object"
                            string="Recalculate Pricing"
                            invisible="state != 'draft'"
                            help="Refresh all equipment line rates against the current pricing.rule + day.multiplier tables. Pricing is otherwise snapshotted at line creation."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_approval,approved,sent,accepted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="event_job_id"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id"/>
                            <field name="salesperson_id"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id"
                                   readonly="id"/>
                        </group>
                        <group string="Schedule">
                            <field name="quotation_date"
                                   readonly="state != 'draft'"/>
                            <field name="expires_at"
                                   readonly="state != 'draft'"/>
                            <field name="crew_display_mode"
                                   readonly="state != 'draft'"/>
                            <field name="payment_term_id"
                                   readonly="state != 'draft'"/>
                            <field name="conversion_rate_id"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines" name="lines">
                            <field name="line_ids"
                                   readonly="state not in ('draft',)"
                                   context="{'default_quote_id': id}">
                                <tree string="Quote Lines"
                                      editable="bottom">
                                    <field name="sequence"
                                           widget="handle"/>
                                    <field name="line_type"/>
                                    <!-- FIX-S1: catalogue picker. Selecting a
                                         product fires the pricing engine via
                                         the line's _onchange_product_template_id
                                         (sets line_type='equipment', stamps
                                         unit_rate from rule x bracket x day-
                                         multiplier). no_create: a rep picks
                                         existing catalogue items, never mints a
                                         product from the quote line. -->
                                    <field name="product_template_id"
                                           widget="neon_quote_item"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="duration_days"/>
                                    <field name="unit_rate"
                                           widget="monetary"/>
                                    <!-- QUOTE-UX-3: the ENGINE line discount.
                                         discount_pct / discount_amount fold into
                                         line_subtotal via _compute_subtotal (the
                                         engine unit_rate is never overwritten);
                                         they are mutually exclusive (the sibling
                                         auto-clears on edit, _check_discount
                                         blocks both/over-base). Default-VISIBLE
                                         (optional="show": shown, user may hide)
                                         so a WA-originated discount is never
                                         silently off-screen. This is NOT the
                                         stock account global discount. -->
                                    <field name="discount_pct"
                                           optional="show"/>
                                    <field name="discount_amount"
                                           widget="monetary"
                                           optional="show"/>
                                    <field name="line_subtotal"
                                           widget="monetary"
                                           sum="Subtotal"/>
                                    <field name="tax_id"/>
                                    <field name="line_total_taxed"
                                           widget="monetary"
                                           sum="Total"/>
                                    <field name="pricing_status"
                                           widget="badge"
                                           decoration-success="pricing_status == 'priced'"
                                           decoration-warning="pricing_status == 'manual'"
                                           decoration-danger="pricing_status == 'no_rule'"
                                           decoration-muted="pricing_status == 'not_yet'"/>
                                    <field name="bracket_multiplier"
                                           readonly="1"
                                           optional="show"/>
                                    <field name="currency_id"
                                           column_invisible="True"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer
                                          oe_right">
                                <!-- QUOTE-UX-3: read-only label for a whole-
                                     quote WhatsApp discount (the amount itself is
                                     distributed across the per-line discounts
                                     above; this just names the basis the rep
                                     chose). Shown only when set; display-only,
                                     mirrors the PDF summary label. -->
                                <field name="wa12_discount_note" readonly="1"
                                       invisible="not wa12_discount_note"/>
                                <field name="amount_untaxed"
                                       widget="monetary"/>
                                <field name="amount_tax"
                                       widget="monetary"/>
                                <field name="amount_total"
                                       widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Margin" name="margin">
                            <group>
                                <field name="margin_total"
                                       widget="monetary"/>
                                <field name="margin_pct"/>
                            </group>
                            <p class="text-muted">
                                P6.M2 placeholder values --
                                quote_line.line_cost defaults to 0
                                until P6.M5 wires the cost-strategy
                                compute. Margin currently equals
                                untaxed total.
                            </p>
                        </page>
                        <page string="Approval / Audit"
                              name="approval">
                            <group>
                                <group string="Approval">
                                    <field name="approved_by_id"/>
                                    <field name="approved_at"/>
                                    <field name="rejection_reason"
                                           invisible="state != 'rejected'"/>
                                    <field name="rejected_at"
                                           invisible="state != 'rejected'"/>
                                </group>
                                <group string="Lifecycle">
                                    <field name="sent_at"/>
                                    <field name="accepted_at"/>
                                    <field name="cancelled_at"
                                           invisible="state != 'cancelled'"/>
                                    <field name="cancelled_reason"
                                           invisible="state != 'cancelled'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Invoice Schedule"
                              name="invoice_schedule">
                            <div class="alert alert-warning"
                                 role="alert"
                                 invisible="state != 'draft' or invoice_schedule_pct_total == 100">
                                Stage percentages sum to
                                <field name="invoice_schedule_pct_total"
                                       nolabel="1" class="oe_inline"/>%
                                -- accept will be blocked unless this
                                equals 100. (Empty is also acceptable:
                                the default single-stage 100%
                                on-acceptance schedule will be
                                materialised at accept time.)
                            </div>
                            <field name="invoice_schedule_ids"
                                   readonly="state not in ('draft',)"
                                   context="{'default_quote_id': id,
                                             'default_currency_id':
                                                 currency_id}">
                                <tree string="Invoice Schedule"
                                      editable="bottom"
                                      decoration-success="state == 'paid'"
                                      decoration-info="state == 'invoiced'"
                                      decoration-warning="state == 'overdue'"
                                      decoration-muted="state in ('scheduled','cancelled')">
                                    <field name="sequence"
                                           widget="handle"/>
                                    <field name="stage"/>
                                    <field name="trigger"/>
                                    <field name="trigger_date"
                                           invisible="trigger != 'on_date'"
                                           required="trigger == 'on_date'"/>
                                    <field name="trigger_event_state"
                                           invisible="trigger != 'on_event_state'"
                                           required="trigger == 'on_event_state'"/>
                                    <field name="percentage"
                                           sum="Total"/>
                                    <field name="amount"
                                           widget="monetary"
                                           sum="Total"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-success="state == 'paid'"
                                           decoration-info="state == 'invoiced'"
                                           decoration-warning="state == 'overdue'"/>
                                    <field name="invoice_id"
                                           readonly="1"/>
                                    <field name="currency_id"
                                           column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neon_finance_quote_view_search" model="ir.ui.view">
        <field name="name">neon.finance.quote.search</field>
        <field name="model">neon.finance.quote</field>
        <field name="arch" type="xml">
            <search string="Quotes">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="event_job_id"/>
                <field name="salesperson_id"/>
                <separator/>
                <filter name="my_quotes" string="My Quotes"
                        domain="[('salesperson_id', '=', uid)]"/>
                <separator/>
                <filter name="state_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="state_pending" string="Pending Approval"
                        domain="[('state', '=', 'pending_approval')]"/>
                <filter name="state_approved" string="Approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter name="state_sent" string="Sent"
                        domain="[('state', '=', 'sent')]"/>
                <filter name="state_accepted" string="Accepted"
                        domain="[('state', '=', 'accepted')]"/>
                <filter name="state_terminal" string="Terminal"
                        domain="[('state', 'in',
                            ('rejected','expired','cancelled'))]"/>
                <separator/>
                <filter name="currency_usd" string="USD"
                        domain="[('currency_id.name', '=', 'USD')]"/>
                <filter name="currency_zwg" string="ZiG"
                        domain="[('currency_id.name', '=', 'ZWG')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Stage"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_salesperson"
                            string="Salesperson"
                            context="{'group_by': 'salesperson_id'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_currency" string="Currency"
                            context="{'group_by': 'currency_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="neon_finance_quote_action"
            model="ir.actions.act_window">
        <field name="name">Quotes</field>
        <field name="res_model">neon.finance.quote</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id"
               ref="neon_finance_quote_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No quotes yet
            </p>
            <p>
                Quotes start in Draft. Add equipment lines and set
                payment terms, then submit for OD/MD approval.
                Robin / Munashe review submitted quotes; once
                approved, the quote can be sent to the client and
                accepted.
            </p>
        </field>
    </record>

</odoo>

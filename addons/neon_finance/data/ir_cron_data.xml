<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            P6.M2 — daily sweep that walks sent quotes past their
            expires_at date to the 'expired' terminal state. Daily
            cadence is sufficient (expiry is informational; nothing
            else hinges on the exact hour). Matches the existing
            neon_jobs.ir_cron_soft_hold_expiry pattern (daily,
            scheduler-picked time, no explicit nextcall).
        -->
        <record id="ir_cron_neon_finance_quote_expiry"
                model="ir.cron">
            <field name="name">Neon Finance: Quote Expiry Sweep</field>
            <field name="model_id" ref="model_neon_finance_quote"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_quotes()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

        <!--
            P6.M7 — daily sweep for on_date invoice schedules. Other
            trigger types fire elsewhere: on_acceptance inside
            quote.action_accept, on_event_state inside the
            commercial.event.job.write() override, manual via the
            action_trigger_now button.
        -->
        <record id="ir_cron_neon_finance_invoice_schedule"
                model="ir.cron">
            <field name="name">Neon Finance: Invoice Schedule On-Date Sweep</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_invoice_schedules()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

        <!--
            P6.M9: daily overdue payment sweep. Transitions
            schedules from 'invoiced' to 'overdue' when their
            account.move.invoice_date_due has elapsed without
            payment. Late-policy enforcement (reminder activity +
            account_hold credit flag) dispatches as a side-effect.
            Same daily cadence as the on_date sweep.
        -->
        <record id="ir_cron_neon_finance_overdue_payments"
                model="ir.cron">
            <field name="name">Neon Finance: Overdue Payment Sweep</field>
            <field name="model_id"
                   ref="model_neon_finance_invoice_schedule"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_overdue_payments()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>

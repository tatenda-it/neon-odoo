<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            P6.M1 — sequences for the Phase 6 finance models.

            PRC- pads 4 digits (max 9999 pricing rules). At one rule
            per category-currency pair, with 9 categories × 2
            currencies = 18 baseline rules and rare additions over
            time, 4 digits is comfortable headroom.

            FX- pads 6 digits (max 999999 conversion rates). High
            potential volume if Kudzi maintains daily rates; 6
            digits keeps padding stable across the deployment life.

            neon.finance.pricing.bracket and neon.finance.day.multiplier
            do not get sequences — brackets are child records and
            day multipliers are one-per-category (categories carry
            the human-readable identity).
        -->

        <record id="seq_neon_finance_pricing_rule" model="ir.sequence">
            <field name="name">Pricing Rule</field>
            <field name="code">neon.finance.pricing.rule</field>
            <field name="prefix">PRC-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <record id="seq_neon_finance_conversion_rate" model="ir.sequence">
            <field name="name">Conversion Rate</field>
            <field name="code">neon.finance.conversion.rate</field>
            <field name="prefix">FX-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!--
            P6.M2 — quote sequences. One per currency so the human-
            readable identifier carries the currency, matching the
            PRC- pattern. 6-digit padding follows the FX- precedent —
            quote volume grows steadily over the system's life and
            5-digit padding would roll over within 5 years at Neon's
            current pace.
        -->
        <record id="seq_neon_finance_quote_usd" model="ir.sequence">
            <field name="name">Quote (USD)</field>
            <field name="code">neon.finance.quote.usd</field>
            <field name="prefix">QUO-USD-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <record id="seq_neon_finance_quote_zwg" model="ir.sequence">
            <field name="name">Quote (ZiG)</field>
            <field name="code">neon.finance.quote.zwg</field>
            <field name="prefix">QUO-ZIG-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!--
            P6.M4 — approval queue. One record per quote submission,
            6-digit padding follows the QUO- / FX- precedent so
            identifiers stay stable across the system's lifetime.
        -->
        <record id="seq_neon_finance_approval" model="ir.sequence">
            <field name="name">Quote Approval</field>
            <field name="code">neon.finance.approval</field>
            <field name="prefix">APR-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!--
            P6.M5 — event cost lines. 6-pad matches the QUO- / APR- /
            FX- precedent.
        -->
        <record id="seq_neon_finance_cost_line" model="ir.sequence">
            <field name="name">Event Cost Line</field>
            <field name="code">neon.finance.cost.line</field>
            <field name="prefix">COST-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

        <!--
            P6.M7 — invoice schedule. SCH-NNNNNN, 6-pad matches the
            QUO- / APR- / COST- / FX- precedent.
        -->
        <record id="seq_neon_finance_invoice_schedule" model="ir.sequence">
            <field name="name">Invoice Schedule</field>
            <field name="code">neon.finance.invoice.schedule</field>
            <field name="prefix">SCH-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_neon_cockpit_info_form" model="ir.ui.view">
        <field name="name">neon.cockpit.info.form</field>
        <field name="model">neon.cockpit.info</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="name" readonly="1"/></h1>
                    <group>
                        <group string="VAT (single shared record)">
                            <field name="vat_tax_id" readonly="1"/>
                            <field name="vat_rate" readonly="1"/>
                            <field name="vat_group_id" readonly="1"/>
                        </group>
                        <group string="Currency">
                            <field name="currency_primary_id" readonly="1"/>
                            <field name="currency_mirror_label" readonly="1"/>
                            <field name="zar_note" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Terms / Compliance">
                            <field name="zimra_registration"/>
                            <field name="payment_terms_days" readonly="1"/>
                            <field name="append_only_note" readonly="1"/>
                        </group>
                        <group string="Deferred (no live figures)">
                            <field name="undeposited_funds_deferred" readonly="1"/>
                            <field name="restricted_sa_tier_deferred" readonly="1"/>
                            <field name="deferred_note" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_neon_cockpit_info_tree" model="ir.ui.view">
        <field name="name">neon.cockpit.info.tree</field>
        <field name="model">neon.cockpit.info</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="vat_rate"/>
                <field name="payment_terms_days"/>
                <field name="undeposited_funds_deferred"/>
                <field name="restricted_sa_tier_deferred"/>
            </tree>
        </field>
    </record>

    <record id="action_neon_cockpit_money_rules" model="ir.actions.act_window">
        <field name="name">Money Rules</field>
        <field name="res_model">neon.cockpit.info</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

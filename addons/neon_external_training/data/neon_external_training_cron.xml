<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Phase 7c M7 daily cron that finds bookings exactly
        3 days out (state='booked') and fires the
        _notify_reminder_3d stub on each. Phase 9 swaps the
        _notify_send override to route reminders via WhatsApp.

        noupdate=1 so admin tweaks to active / interval survive
        future -u of neon_external_training.
    -->
    <record id="cron_external_training_reminder_3d"
            model="ir.cron">
        <field name="name">External Training 3-Day Reminder</field>
        <field name="model_id"
               ref="model_neon_external_training_booking"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_3d_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>

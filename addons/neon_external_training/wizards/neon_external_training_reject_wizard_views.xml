<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_external_training_reject_wizard_form"
            model="ir.ui.view">
        <field name="name">neon.external.training.reject.wizard.form</field>
        <field name="model">neon.external.training.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Booking">
                <sheet>
                    <group>
                        <field name="booking_id"
                               readonly="1"/>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"
                               colspan="2"
                               placeholder="Why is this booking being rejected? The reason will be posted to the booking chatter so the requester can see + edit + resubmit."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>
                    <button special="cancel"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

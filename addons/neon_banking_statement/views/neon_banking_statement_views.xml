<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-account running-ledger statement (Neon's spreadsheet layout).
  READ-ONLY: create/edit off; reads existing account.move.line. Per-account
  actions share one tree view + the running-balance compute.
-->
<odoo>

    <!-- Shared statement tree: Date | Details | Acc Code | Dr | Cr | Balance -->
    <record id="view_neon_statement_tree" model="ir.ui.view">
        <field name="name">neon.banking.statement.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <tree string="Statement" create="0" edit="0" delete="0"
                  default_order="date, id">
                <field name="company_currency_id" column_invisible="1"/>
                <field name="date" string="Date"/>
                <field name="name" string="Details"/>
                <field name="neon_counterpart_code" string="Acc Code"/>
                <field name="debit" string="Dr" sum="Total Dr"/>
                <field name="credit" string="Cr" sum="Total Cr"/>
                <field name="neon_running_balance" string="Balance"/>
            </tree>
        </field>
    </record>

    <!-- Minimal search view: the DEFAULT account.move.line search has an
         account.root-based searchpanel/groupby that a plain bookkeeper (no
         Billing Administrator) cannot read -> Access Error. This minimal search
         (no searchpanel, no account.root groupby) avoids that entirely. -->
    <record id="view_neon_statement_search" model="ir.ui.view">
        <field name="name">neon.banking.statement.search</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Details"/>
                <field name="date"/>
                <filter name="posted" string="Posted"
                        domain="[('parent_state','=','posted')]"/>
            </search>
        </field>
    </record>

    <!-- Per-account actions (domain by account code -> no numeric/xml-id dep) -->
    <record id="action_statement_petty_cash" model="ir.actions.act_window">
        <field name="name">Petty Cash Statement</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_neon_statement_tree"/>
        <field name="search_view_id" ref="view_neon_statement_search"/>
        <field name="domain">[('account_id.code','=','101501'),('parent_state','=','posted')]</field>
        <field name="context">{'search_default_posted': 1, 'default_cash_account_code': '101501'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">No transactions yet</p>
            <p>This is the Petty Cash running ledger. It fills as entries post.</p>
        </field>
    </record>

    <record id="action_statement_cabs_usd" model="ir.actions.act_window">
        <field name="name">CABS (USD) Statement</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_neon_statement_tree"/>
        <field name="search_view_id" ref="view_neon_statement_search"/>
        <field name="domain">[('account_id.code','=','101401'),('parent_state','=','posted')]</field>
        <field name="context">{'search_default_posted': 1, 'default_cash_account_code': '101401'}</field>
    </record>

    <record id="action_statement_cabs_zwg" model="ir.actions.act_window">
        <field name="name">CABS (ZWG) Statement</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_neon_statement_tree"/>
        <field name="search_view_id" ref="view_neon_statement_search"/>
        <field name="domain">[('account_id.code','=','101405'),('parent_state','=','posted')]</field>
        <field name="context">{'search_default_posted': 1, 'default_cash_account_code': '101405'}</field>
    </record>

    <record id="action_statement_suspense" model="ir.actions.act_window">
        <field name="name">Suspense Statement</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_neon_statement_tree"/>
        <field name="search_view_id" ref="view_neon_statement_search"/>
        <field name="domain">[('account_id.code','=','101402'),('parent_state','=','posted')]</field>
    </record>

    <!-- ============================================================
         ACCOUNT LEDGERS LANDING INDEX (Build 2 + Build-1 Part 4 Option A).
         A parent action the statements DRILL FROM, so the breadcrumb reads
         "Account Ledgers > <X> Statement" with a clickable way back. Lists the
         three CASH statements; Suspense is NOT listed (its account 101402 stays
         for payments/reconcile + the cross-currency guard, only the statement
         view is dropped from the menu). Read-only; no posting/context change to
         the statement actions (each still carries its own default_cash_account_
         code, so the Add-Transaction dropdown works when drilled into).
         ============================================================ -->
    <record id="view_account_ledgers_index_search" model="ir.ui.view">
        <field name="name">neon.account.ledgers.index.search</field>
        <field name="model">account.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <record id="view_account_ledgers_index_kanban" model="ir.ui.view">
        <field name="name">neon.account.ledgers.index.kanban</field>
        <field name="model">account.account</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false" default_order="code">
                <field name="code"/>
                <templates>
                    <t t-name="kanban-box">
                        <!-- Friendly per-account label (the raw account names are
                             "Cash"/"Bank"/"CABS (ZWG) Bank"; show the bookkeeper's
                             statement names instead, matched by code). -->
                        <div class="oe_kanban_card p-3 m-2 text-center">
                            <t t-if="record.code.raw_value == '101501'">
                                <div class="h5 mb-2">Petty Cash</div>
                                <button name="%(action_statement_petty_cash)d" type="action"
                                        class="btn btn-primary"><i class="fa fa-book me-1"/>Open Statement</button>
                            </t>
                            <t t-if="record.code.raw_value == '101401'">
                                <div class="h5 mb-2">CABS (USD)</div>
                                <button name="%(action_statement_cabs_usd)d" type="action"
                                        class="btn btn-primary"><i class="fa fa-book me-1"/>Open Statement</button>
                            </t>
                            <t t-if="record.code.raw_value == '101405'">
                                <div class="h5 mb-2">CABS (ZWG)</div>
                                <button name="%(action_statement_cabs_zwg)d" type="action"
                                        class="btn btn-primary"><i class="fa fa-book me-1"/>Open Statement</button>
                            </t>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_account_ledgers_index" model="ir.actions.act_window">
        <field name="name">Account Ledgers</field>
        <field name="res_model">account.account</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_account_ledgers_index_kanban"/>
        <field name="search_view_id" ref="view_account_ledgers_index_search"/>
        <field name="domain">[('code','in',['101501','101401','101405'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Your cash &amp; bank statements</p>
            <p>Open a statement to view its running ledger and add transactions.</p>
        </field>
    </record>

    <!-- Nest under the finance-gated "Statements" menu; sequence=5 so Account
         Ledgers LEADS the Statements tree (front-door reorder, #3). The menu now
         opens the landing index above (no child leaf menuitems; statements are
         reached by drilling from the landing, which gives the clickable crumb). -->
    <menuitem id="menu_neon_account_ledgers"
              name="Account Ledgers"
              parent="neon_banking_labels.menu_neon_statements_root"
              action="action_account_ledgers_index"
              sequence="5"/>

</odoo>

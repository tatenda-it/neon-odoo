    <!-- ============================================================
         On-view "Add Transaction" launcher (Build 1): ONE consolidated OWL
         dropdown in the statement control panel (replaces the old row of
         <header display="always"> buttons, which collided with the search box).
         A single primary tree variant adds js_class="neon_statement_addtxn";
         the OWL controller (static/src/views/neon_statement_addtxn.js) reads
         default_cash_account_code off the action context and lists the
         applicable wizards per account. Per-account default now lives on each
         statement ACTION's context (neon_banking_statement_views.xml), not per
         button, so all three cash statements share this one variant.
         ============================================================ -->
    <record id="view_neon_statement_tree_addtxn" model="ir.ui.view">
        <field name="name">neon.banking.statement.tree.addtxn</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="view_neon_statement_tree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">neon_statement_addtxn</attribute>
            </xpath>
        </field>
    </record>

    <!-- Repoint the three CASH statement actions at the dropdown variant.
         Suspense keeps the plain base tree (no cash journal => no Add). -->
    <record id="action_statement_petty_cash" model="ir.actions.act_window">
        <field name="view_id" ref="view_neon_statement_tree_addtxn"/>
    </record>
    <record id="action_statement_cabs_usd" model="ir.actions.act_window">
        <field name="view_id" ref="view_neon_statement_tree_addtxn"/>
    </record>
    <record id="action_statement_cabs_zwg" model="ir.actions.act_window">
        <field name="view_id" ref="view_neon_statement_tree_addtxn"/>
    </record>


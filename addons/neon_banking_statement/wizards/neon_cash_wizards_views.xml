<?xml version="1.0" encoding="UTF-8"?>
<!--
  "Add Transaction" quick-entry wizards (Zoho-style). Short forms, Neon's words,
  NO debit/credit/journal/suspense jargon. Open as dialogs (target=new).

  The on-view launcher is a native list <header> button with display="always"
  (renders in the statement's control panel with no row selection needed) whose
  context defaults the cash account to the statement being viewed. Pure XML, no
  JS, no asset bundle; robust over a custom OWL controller patch.
-->
<odoo>

    <!-- ===== EXPENSE (money out) ===== -->
    <record id="view_cash_expense_wizard_form" model="ir.ui.view">
        <field name="name">neon.cash.expense.wizard.form</field>
        <field name="model">neon.cash.expense.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Expense">
                <sheet>
                    <group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="expense_account_id"
                                   options="{'no_create': True}"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="tax_treatment" widget="radio"
                                   options="{'horizontal': True}"/>
                            <field name="tax_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="cash_account_id"
                                   options="{'no_create': True}"/>
                            <field name="vendor_id"/>
                            <field name="customer_id"/>
                            <field name="reference"/>
                            <field name="receipt" filename="receipt_filename"
                                   widget="binary"/>
                            <field name="receipt_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"
                               placeholder="What was this for? (e.g. Fuel - crew run)"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" name="action_save" type="object"
                            class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cash_expense_wizard" model="ir.actions.act_window">
        <field name="name">Add Expense</field>
        <field name="res_model">neon.cash.expense.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cash_expense_wizard_form"/>
        <field name="target">new</field>
    </record>


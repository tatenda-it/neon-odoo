<?xml version="1.0" encoding="utf-8"?>
<!--
    Default visible widgets per dashboard_type. Loaded on -i ONLY
    (noupdate=1) so manual user-level customisation isn't clobbered
    by subsequent module upgrades.

    Schema sketch §5.2 + §8.1 lock the widget lists below:

    director:    all 7 KPI tiles + all 7 blocks
    sales:       6 KPI tiles (pipeline / leads / hot deals / aging
                 quotes / won-mtd / win-rate) + sales / hot deals /
                 aging quotes / alerts / tasks / ai      [P8B.M1]
    bookkeeper:  6 KPI tiles (cash / AR / overdue-60 / pending inv /
                 recent payments / recent costs) + finance / budget
                 alerts / invoice queue / zig-costs / alerts / tasks /
                 ai                                       [P8B.M2]
    lead_tech:   4 KPI tiles (jobs today / jobs week / crew gaps /
                 certs-30) + jobs / crew gaps / cert expiry /
                 crew_equipment / alerts / tasks / ai     [P8B.M3]
    tech:        1 KPI tile (today) + jobs / alerts / tasks

    P8B note: alerts + tasks are personal cross-cutting blocks kept on
    every variant for UX consistency; §5's "5 blocks" per variant
    enumerates the role-DISTINCTIVE blocks (these + AI). Equipment
    Booked/Available KPI tiles deferred to Phase 9+ (need a unit-level
    booking surface; carryover). noupdate=1 still holds: existing
    installs pick these up via the P8B.M1-M3 post-migrate scripts,
    which also reset already-seeded user layouts for each type.

    order_index convention: KPI tiles 1-7 (in mockup order), blocks
    10-16. Future widgets can slot between bands without renumbering.
-->
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Director (Robin / Munashe + Tatenda for dev) - everything.
             ============================================================ -->
        <record id="default_layout_director"
                model="neon.dashboard.default.layout">
            <field name="dashboard_type">director</field>
            <field name="layout_line_ids" eval="[
                (0, 0, {'widget_key': 'kpi_cash',          'order_index': 1}),
                (0, 0, {'widget_key': 'kpi_ar_overdue',    'order_index': 2}),
                (0, 0, {'widget_key': 'kpi_jobs_today',    'order_index': 3}),
                (0, 0, {'widget_key': 'kpi_jobs_week',     'order_index': 4}),
                (0, 0, {'widget_key': 'kpi_pipeline',      'order_index': 5}),
                (0, 0, {'widget_key': 'kpi_leads',         'order_index': 6}),
                (0, 0, {'widget_key': 'kpi_forecast',      'order_index': 7}),
                (0, 0, {'widget_key': 'block_jobs',        'order_index': 10, 'size': 'large'}),
                (0, 0, {'widget_key': 'block_sales',       'order_index': 11}),
                (0, 0, {'widget_key': 'block_finance',     'order_index': 12}),
                (0, 0, {'widget_key': 'block_alerts',      'order_index': 13}),
                (0, 0, {'widget_key': 'block_crew_equipment','order_index': 14}),
                (0, 0, {'widget_key': 'block_tasks',       'order_index': 15}),
                (0, 0, {'widget_key': 'block_ai_insights', 'order_index': 16, 'size': 'large'}),
                (0, 0, {'widget_key': 'kpi_hist_winrate',  'order_index': 50}),
                (0, 0, {'widget_key': 'kpi_hist_demand',   'order_index': 51}),
                (0, 0, {'widget_key': 'kpi_hist_quotes',   'order_index': 52}),
                (0, 0, {'widget_key': 'block_hist_intel',  'order_index': 60, 'size': 'large'}),
            ]"/>
        </record>
        <!-- Director Historical · Zoho import band = order_index 50-52 (KPI
             tiles, cosmetic) + 60 (block, 'large'). High band keeps it cleanly
             separate from the live KPI (1-7) + block (10-16) bands. Director
             ONLY. Existing installs pick these up via the 17.0.11.3.0
             post-migrate (this file is noupdate=1). -->


        <!-- ============================================================
             Sales (Lisa / Evrill - Tatenda when overriding via View-as).
             ============================================================ -->
        <record id="default_layout_sales"
                model="neon.dashboard.default.layout">
            <field name="dashboard_type">sales</field>
            <field name="layout_line_ids" eval="[
                (0, 0, {'widget_key': 'kpi_pipeline',      'order_index': 1}),
                (0, 0, {'widget_key': 'kpi_leads',         'order_index': 2}),
                (0, 0, {'widget_key': 'kpi_hot_deals',     'order_index': 3}),
                (0, 0, {'widget_key': 'kpi_aging_quotes',  'order_index': 4}),
                (0, 0, {'widget_key': 'kpi_won_mtd',       'order_index': 5}),
                (0, 0, {'widget_key': 'kpi_win_rate',      'order_index': 6}),
                (0, 0, {'widget_key': 'block_sales',       'order_index': 10, 'size': 'large'}),
                (0, 0, {'widget_key': 'block_hot_deals',   'order_index': 11}),
                (0, 0, {'widget_key': 'block_aging_quotes','order_index': 12}),
                (0, 0, {'widget_key': 'block_alerts',      'order_index': 13}),
                (0, 0, {'widget_key': 'block_tasks',       'order_index': 14}),
                (0, 0, {'widget_key': 'block_ai_insights', 'order_index': 15, 'size': 'large'}),

<?xml version="1.0" encoding="utf-8"?>
<!--
    M9 Weekly Digest PDF report.

    Bound to neon.dashboard.digest.log (concrete Model). The
    orchestrator renders with res_ids=[log.id]. The rich payload
    dict is passed via data= and stashed into context as
    'digest_payload' by the orchestrator's _render_and_attach_pdf
    helper.

    Mirrors the structure of neon_training.report_compliance_document
    (web.html_container + web.external_layout). Single-page report
    that wraps to multi-page only if AR aging or jobs lists overflow.

    Superuser-only via the report's groups_id.
-->
<odoo>

    <record id="report_weekly_digest" model="ir.actions.report">
        <field name="name">Neon Weekly Digest</field>
        <field name="model">neon.dashboard.digest.log</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">neon_dashboard.report_weekly_digest_document</field>
        <field name="report_file">neon_dashboard.report_weekly_digest_document</field>
        <field name="binding_type">report</field>
        <field name="groups_id" eval="[
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

    <template id="report_weekly_digest_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="log">
                <t t-set="payload"
                   t-value="(data and data.get('digest_payload')) or log._get_render_payload() or {}"/>
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 style="color:#7165AC;">Neon - Weekly digest</h2>
                        <p class="text-muted">
                            Window:
                            <span t-out="payload.get('window_label') or '-'"/>
                            ·
                            Generated
                            <span t-out="payload.get('anchor_today_label') or ''"/>
                        </p>

                        <!-- KPI snapshot - shared partial (M10 extract). -->
                        <t t-call="neon_dashboard.snapshot_section_kpis"/>

                        <!-- Last week activity -->
                        <h3>Last week</h3>
                        <ul>
                            <li>
                                Quotes won:
                                <span t-out="payload.get('last_week_quotes_won', 0)"/>
                            </li>
                            <li>
                                Quotes lost (rejected + expired):
                                <span t-out="payload.get('last_week_quotes_lost', 0)"/>
                            </li>
                            <li>
                                Invoices paid:
                                <span t-out="payload.get('last_week_invoices_paid', 0)"/>
                            </li>
                            <li>
                                Jobs completed:
                                <span t-out="payload.get('last_week_jobs_completed', 0)"/>
                            </li>
                        </ul>

                        <!-- Forward look - shared partial (M10 extract). -->
                        <t t-call="neon_dashboard.snapshot_section_jobs"/>

                        <!-- Outstanding items - shared partial (M10 extract). -->
                        <t t-call="neon_dashboard.snapshot_section_ar_aging"/>

                        <t t-set="ab"
                           t-value="payload.get('alerts_block', {})"/>
                        <t t-set="alerts"
                           t-value="(ab.get('alerts') or [])"/>
                        <t t-if="alerts">
                            <h4 style="margin-top:12px;">Open alerts</h4>
                            <ul>
                                <li t-foreach="alerts" t-as="a">
                                    <strong t-out="a.get('severity', '').upper()"/>
                                    ·
                                    <span t-out="a.get('title') or a.get('message') or '-'"/>
                                </li>
                            </ul>
                        </t>

                        <p class="text-muted small" style="margin-top:20px;">
                            Open the live dashboard:
                            <a t-att-href="payload.get('dashboard_url', '#')">
                                <span t-out="payload.get('dashboard_url', '')"/>
                            </a>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

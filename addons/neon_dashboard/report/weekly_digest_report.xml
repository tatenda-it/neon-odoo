<?xml version="1.0" encoding="utf-8"?>
<!--
    M9 Weekly Digest PDF report.

    Bound to neon.dashboard.digest.log (concrete Model). The
    orchestrator renders with res_ids=[log.id]. The rich payload
    dict is passed via data= and stashed into context as
    'digest_payload' by the orchestrator's _render_and_attach_pdf
    helper.

    Mirrors the structure of neon_training.report_compliance_document
    (web.html_container + web.external_layout). Single-page report
    that wraps to multi-page only if AR aging or jobs lists overflow.

    Superuser-only via the report's groups_id.
-->
<odoo>

    <record id="report_weekly_digest" model="ir.actions.report">
        <field name="name">Neon Weekly Digest</field>
        <field name="model">neon.dashboard.digest.log</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">neon_dashboard.report_weekly_digest_document</field>
        <field name="report_file">neon_dashboard.report_weekly_digest_document</field>
        <field name="binding_type">report</field>
        <field name="groups_id" eval="[
            (4, ref('neon_core.group_neon_superuser')),
        ]"/>
    </record>

    <template id="report_weekly_digest_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="log">
                <t t-set="payload"
                   t-value="(data and data.get('digest_payload')) or log._get_render_payload() or {}"/>
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 style="color:#7165AC;">Neon - Weekly digest</h2>
                        <p class="text-muted">
                            Window:
                            <span t-out="payload.get('window_label') or '-'"/>
                            ·
                            Generated
                            <span t-out="payload.get('anchor_today_label') or ''"/>
                        </p>

                        <!-- KPI snapshot -->
                        <h3>Current state</h3>
                        <table class="table table-sm">
                            <thead>
                                <tr><th>KPI</th><th>Value</th></tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Cash on hand</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_cash', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>AR overdue</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_ar_overdue', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Jobs today</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_jobs_today', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Jobs this week</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_jobs_week', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Pipeline value</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_pipeline', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>New leads</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_leads', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Forecast vs target</td>
                                    <td>
                                        <t t-set="k"
                                           t-value="payload.get('kpi_forecast', {})"/>
                                        <span t-out="k.get('display') or k.get('value') or '-'"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Last week activity -->
                        <h3>Last week</h3>
                        <ul>
                            <li>
                                Quotes won:
                                <span t-out="payload.get('last_week_quotes_won', 0)"/>
                            </li>
                            <li>
                                Quotes lost (rejected + expired):
                                <span t-out="payload.get('last_week_quotes_lost', 0)"/>
                            </li>
                            <li>
                                Invoices paid:
                                <span t-out="payload.get('last_week_invoices_paid', 0)"/>
                            </li>
                            <li>
                                Jobs completed:
                                <span t-out="payload.get('last_week_jobs_completed', 0)"/>
                            </li>
                        </ul>

                        <!-- Forward look -->
                        <h3>Coming up this week</h3>
                        <t t-set="jb"
                           t-value="payload.get('jobs_block', {})"/>
                        <t t-set="job_rows"
                           t-value="(jb.get('rows') or jb.get('jobs') or [])"/>
                        <t t-if="not job_rows">
                            <p><em>No upcoming jobs in the next 7 days.</em></p>
                        </t>
                        <t t-else="">
                            <ul>
                                <li t-foreach="job_rows" t-as="job">
                                    <span t-out="job.get('title') or job.get('name') or job.get('display_name') or '-'"/>
                                    ·
                                    <span t-out="job.get('date_display') or job.get('event_date') or ''"/>
                                    ·
                                    <span t-out="job.get('value_display') or job.get('value') or ''"/>
                                </li>
                            </ul>
                        </t>

                        <!-- Outstanding items -->
                        <h3>Needs attention</h3>
                        <t t-set="ar"
                           t-value="payload.get('ar_aging', {})"/>
                        <t t-set="buckets"
                           t-value="(ar.get('buckets') or [])"/>
                        <t t-if="ar.get('empty') or not buckets">
                            <p><em>No overdue invoices.</em></p>
                        </t>
                        <t t-else="">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Bucket</th>
                                        <th>Count</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="buckets" t-as="b">
                                        <td t-out="b.get('label') or '-'"/>
                                        <td t-out="b.get('count') or 0"/>
                                        <td t-out="b.get('amount_display') or b.get('amount') or '-'"/>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                        <t t-set="ab"
                           t-value="payload.get('alerts_block', {})"/>
                        <t t-set="alerts"
                           t-value="(ab.get('alerts') or [])"/>
                        <t t-if="alerts">
                            <h4 style="margin-top:12px;">Open alerts</h4>
                            <ul>
                                <li t-foreach="alerts" t-as="a">
                                    <strong t-out="a.get('severity', '').upper()"/>
                                    ·
                                    <span t-out="a.get('title') or a.get('message') or '-'"/>
                                </li>
                            </ul>
                        </t>

                        <p class="text-muted small" style="margin-top:20px;">
                            Open the live dashboard:
                            <a t-att-href="payload.get('dashboard_url', '#')">
                                <span t-out="payload.get('dashboard_url', '')"/>
                            </a>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

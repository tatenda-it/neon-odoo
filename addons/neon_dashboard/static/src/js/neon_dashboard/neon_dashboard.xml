<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="neon_dashboard.NeonDashboard">
        <div class="o_neon_dashboard"
             t-att-class="'o_neon_dashboard__filter_' + state.activeFilter">

            <!-- =====================================================
                 Header row - brand block on the left, user-line
                 + View-as dropdown + Edit Layout pencil on the right.
                 ===================================================== -->
            <div class="o_neon_dashboard_header">
                <div class="o_neon_dashboard_brand">
                    <h1>
                        Neon
                        <span class="o_neon_dashboard_sep">--</span>
                        <span t-esc="dashboardTypeLabel"/> Dashboard
                    </h1>
                    <p class="o_neon_dashboard_subtitle">
                        Operations &#183; Sales &#183; Finance &#183; Alerts
                    </p>
                </div>
                <div class="o_neon_dashboard_header_right">
                    <div class="o_neon_dashboard_user_line">
                        <span class="o_neon_dashboard_user_name"
                              t-esc="userName"/>
                        <span class="o_neon_dashboard_user_role"
                              t-if="userRoleLabel">
                            &#183; <t t-esc="userRoleLabel"/>
                        </span>
                        <small class="text-muted ms-2"
                               t-if="lastUpdated">
                            (refreshed <t t-esc="lastUpdated"/>)
                        </small>
                    </div>
                    <div class="o_neon_dashboard_controls">
                        <select t-if="isSuperuser"
                                class="o_neon_dashboard_viewas"
                                t-on-change="onViewAsChange">
                            <option value="" disabled="disabled">
                                View as...
                            </option>
                            <t t-foreach="availableTypes"
                               t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value"
                                        t-att-selected="state.data and state.data.dashboard_type === opt.value">
                                    <t t-esc="opt.label"/>
                                </option>
                            </t>
                        </select>
                        <button class="btn btn-sm btn-link o_neon_dashboard_edit_layout"
                                t-on-click="onEditLayoutClick">
                            <i class="fa fa-pencil me-1"/>
                            EDIT LAYOUT
                        </button>
                        <!-- M10: export buttons (PDF + Excel). -->
                        <button class="btn btn-sm btn-outline-secondary o_neon_dashboard_export_pdf"
                                t-on-click="onExportPdf"
                                t-att-disabled="state.exporting or state.loading"
                                title="Download PDF snapshot">
                            <i class="fa"
                               t-att-class="state.exporting === 'pdf' ? 'fa-spinner fa-spin' : 'fa-file-pdf-o'"/>
                            <span class="ms-1">PDF</span>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary o_neon_dashboard_export_xlsx"
                                t-on-click="onExportXlsx"
                                t-att-disabled="state.exporting or state.loading"
                                title="Download Excel snapshot">
                            <i class="fa"
                               t-att-class="state.exporting === 'xlsx' ? 'fa-spinner fa-spin' : 'fa-file-excel-o'"/>
                            <span class="ms-1">Excel</span>
                        </button>
                        <button class="btn btn-sm btn-outline-primary o_neon_dashboard_refresh"
                                t-on-click="onRefreshClick"
                                t-att-disabled="state.loading">
                            <i class="fa"
                               t-att-class="state.loading ? 'fa-refresh fa-spin' : 'fa-refresh'"/>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Error banner -->
            <div t-if="state.error"
                 class="alert alert-danger o_neon_dashboard_error"
                 role="alert">
                <i class="fa fa-exclamation-circle me-2"/>
                <span>Failed to load dashboard data: </span>
                <span t-esc="state.error"/>
                <button class="btn btn-sm btn-outline-danger ms-3"
                        t-on-click="onRefreshClick">Retry</button>
            </div>

            <!-- Loading skeleton (first load only) -->
            <div t-if="state.loading and !state.data"
                 class="o_neon_dashboard_loading">
                <div class="o_neon_kpi_strip">
                    <t t-foreach="[1,2,3,4,5,6,7]" t-as="_" t-key="_">
                        <div class="o_neon_kpi_tile o_neon_kpi_skeleton"/>
                    </t>
                </div>
            </div>

            <!-- ===================================================== -->
            <!-- Rendered content (after first successful load).      -->
            <!-- ===================================================== -->
            <div t-if="state.data" class="o_neon_dashboard_content">

                <!-- =================================================
                     KPI strip - 7 tiles, grid-template-columns 7.
                     ================================================= -->
                <section class="o_neon_kpi_strip">

                    <!-- Cash on Hand (mandatory; always visible per
                         schema sketch §4.2). -->
                    <div class="o_neon_kpi_tile o_neon_kpi_tile_big widget--kpi_cash"
                         t-if="isWidgetVisible('kpi_cash')"
                         t-att-class="kpi.kpi_cash and kpi.kpi_cash.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_cash)">
                        <div class="o_neon_kpi_label">Cash on Hand</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_cash and kpi.kpi_cash.empty ? 'o_neon_kpi_empty' : ''"
                             t-esc="kpi.kpi_cash and kpi.kpi_cash.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_cash and kpi.kpi_cash.subtitle"/>
                    </div>

                    <!-- AR Overdue (mandatory) -->
                    <div class="o_neon_kpi_tile widget--kpi_ar_overdue"
                         t-if="isWidgetVisible('kpi_ar_overdue')"
                         t-att-class="kpi.kpi_ar_overdue and kpi.kpi_ar_overdue.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_ar_overdue)">
                        <div class="o_neon_kpi_label">AR Overdue</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_ar_overdue and kpi.kpi_ar_overdue.empty ? 'o_neon_kpi_empty' : 'o_neon_kpi_value_red'"
                             t-esc="kpi.kpi_ar_overdue and kpi.kpi_ar_overdue.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_ar_overdue and kpi.kpi_ar_overdue.subtitle"/>
                    </div>

                    <div class="o_neon_kpi_tile widget--kpi_jobs_today"
                         t-if="isWidgetVisible('kpi_jobs_today')"
                         t-att-class="kpi.kpi_jobs_today and kpi.kpi_jobs_today.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_jobs_today)">
                        <div class="o_neon_kpi_label">Jobs Today</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_jobs_today and kpi.kpi_jobs_today.empty ? 'o_neon_kpi_empty' : ''"
                             t-esc="kpi.kpi_jobs_today and kpi.kpi_jobs_today.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_jobs_today and kpi.kpi_jobs_today.subtitle"/>
                    </div>

                    <div class="o_neon_kpi_tile widget--kpi_jobs_week"
                         t-if="isWidgetVisible('kpi_jobs_week')"
                         t-att-class="kpi.kpi_jobs_week and kpi.kpi_jobs_week.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_jobs_week)">
                        <div class="o_neon_kpi_label">Jobs This Week</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_jobs_week and kpi.kpi_jobs_week.empty ? 'o_neon_kpi_empty' : ''"
                             t-esc="kpi.kpi_jobs_week and kpi.kpi_jobs_week.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_jobs_week and kpi.kpi_jobs_week.subtitle"/>
                    </div>

                    <div class="o_neon_kpi_tile widget--kpi_pipeline"
                         t-if="isWidgetVisible('kpi_pipeline')"
                         t-att-class="kpi.kpi_pipeline and kpi.kpi_pipeline.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_pipeline)">
                        <div class="o_neon_kpi_label">Pipeline Value</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_pipeline and kpi.kpi_pipeline.empty ? 'o_neon_kpi_empty' : ''"
                             t-esc="kpi.kpi_pipeline and kpi.kpi_pipeline.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_pipeline and kpi.kpi_pipeline.subtitle"/>
                    </div>

                    <div class="o_neon_kpi_tile widget--kpi_leads"
                         t-if="isWidgetVisible('kpi_leads')"
                         t-att-class="kpi.kpi_leads and kpi.kpi_leads.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_leads)">
                        <div class="o_neon_kpi_label">New Leads</div>
                        <div class="o_neon_kpi_value"
                             t-att-class="kpi.kpi_leads and kpi.kpi_leads.empty ? 'o_neon_kpi_empty' : ''"
                             t-esc="kpi.kpi_leads and kpi.kpi_leads.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_leads and kpi.kpi_leads.subtitle"/>
                    </div>

                    <div class="o_neon_kpi_tile o_neon_kpi_tile_cta widget--kpi_forecast"
                         t-if="isWidgetVisible('kpi_forecast')"
                         t-att-class="kpi.kpi_forecast and kpi.kpi_forecast.deeplink_action ? 'o_neon_kpi_clickable' : ''"
                         t-on-click="() => this.onKpiClick(kpi.kpi_forecast)">
                        <div class="o_neon_kpi_label">Forecast vs Target</div>
                        <div class="o_neon_kpi_value o_neon_kpi_cta"
                             t-esc="kpi.kpi_forecast and kpi.kpi_forecast.value_display"/>
                        <div class="o_neon_kpi_subtitle"
                             t-esc="kpi.kpi_forecast and kpi.kpi_forecast.subtitle"/>
                    </div>
                </section>

                <!-- =================================================
                     View filter chip row.
                     ================================================= -->
                <section class="o_neon_filter_chips">
                    <t t-foreach="filters" t-as="f" t-key="f.key">
                        <button class="o_neon_filter_chip"
                                t-att-class="state.activeFilter === f.key ? 'o_neon_filter_chip_active' : ''"
                                t-on-click="() => this.onFilterChange(f.key)">
                            <t t-esc="f.label"/>
                        </button>
                    </t>
                </section>

                <!-- =================================================
                     Row A - Jobs block (M3) + Sales placeholder.
                     ================================================= -->
                <section class="o_neon_row_a">

                    <div class="o_neon_block o_neon_block_jobs widget--block_jobs"
                         t-if="isWidgetVisible('block_jobs')">
                        <div class="o_neon_block_header">
                            <h3>Jobs &#183; Today + This Week</h3>
                        </div>

                        <div class="o_neon_block_body">
                            <div t-if="jobsBlock.empty"
                                 class="o_neon_block_empty">
                                <p class="o_neon_block_empty_msg"
                                   t-esc="jobsBlock.empty_message"/>
                                <button class="btn btn-link"
                                        t-on-click="onEmptyJobsClick"
                                        t-if="jobsBlock.empty_cta_action">
                                    <t t-esc="jobsBlock.empty_cta_label"/>
                                </button>
                            </div>

                            <table t-if="!jobsBlock.empty"
                                   class="o_neon_jobs_table">
                                <thead>
                                    <tr>
                                        <th>Client</th>
                                        <th>Event</th>
                                        <th>When</th>
                                        <th>State</th>
                                        <th class="text-end">Crew</th>
                                        <th>Venue</th>
                                        <th class="text-end">Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="jobsBlock.rows"
                                       t-as="row" t-key="row.id">
                                        <tr class="o_neon_jobs_row"
                                            t-on-click="() => this.onJobClick(row)">
                                            <td t-esc="row.client_name"/>
                                            <td t-esc="row.event_name"/>
                                            <td>
                                                <div t-esc="row.event_label"/>
                                                <small class="text-muted"
                                                       t-esc="row.days_label"/>
                                            </td>
                                            <td>
                                                <span class="o_neon_jobs_badge"
                                                      t-att-class="'o_neon_jobs_badge_' + row.state_color"
                                                      t-esc="row.state_label"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="row.crew_confirmed"/>
                                                /
                                                <span t-esc="row.crew_required"/>
                                                <span t-if="row.crew_gap > 0"
                                                      class="o_neon_jobs_gap"
                                                      t-esc="' (-' + row.crew_gap + ')'"/>
                                            </td>
                                            <td t-esc="row.venue"/>
                                            <td class="text-end"
                                                t-esc="row.value_display"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- M5 - Sales block -->
                    <div t-if="isWidgetVisible('block_sales')"
                         class="o_neon_block o_neon_block_sales widget--block_sales">
                        <div class="o_neon_block_header">
                            <h3>Sales Pipeline</h3>
                        </div>
                        <div class="o_neon_block_body">

                            <!-- Pipeline by stage -->
                            <div class="o_neon_sales_subwidget">
                                <h4>Pipeline by stage</h4>
                                <div t-if="salesBlock.pipeline_by_stage.empty"
                                     class="o_neon_block_empty">
                                    <p class="o_neon_block_empty_msg"
                                       t-esc="salesBlock.pipeline_by_stage.empty_message"/>
                                </div>
                                <table t-if="!salesBlock.pipeline_by_stage.empty"
                                       class="o_neon_sales_table">
                                    <thead>
                                        <tr>
                                            <th>Stage</th>
                                            <th class="text-end">Count</th>
                                            <th class="text-end">Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="salesBlock.pipeline_by_stage.stages"
                                           t-as="stage" t-key="stage.state">
                                            <tr class="o_neon_sales_row"
                                                t-on-click="() => this.onPipelineStageClick(stage)">
                                                <td t-esc="stage.label"/>
                                                <td class="text-end"
                                                    t-esc="stage.count"/>
                                                <td class="text-end"
                                                    t-esc="stage.value_display"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <small class="text-muted o_neon_sales_currency_note"
                                       t-esc="salesBlock.pipeline_by_stage.currency_note"/>
                            </div>

                            <!-- Win rate + lead sources two-up row -->
                            <div class="o_neon_sales_subrow">

                                <div class="o_neon_sales_subwidget">
                                    <h4>Win rate</h4>
                                    <div t-if="salesBlock.win_rate.empty"
                                         class="text-muted small"
                                         t-esc="salesBlock.win_rate.empty_message"/>
                                    <div t-if="!salesBlock.win_rate.empty"
                                         class="o_neon_sales_win_rate">
                                        <div class="o_neon_sales_win_rate_value">
                                            <t t-esc="salesBlock.win_rate.rate_pct"/>%
                                        </div>
                                        <small class="text-muted">
                                            <t t-esc="salesBlock.win_rate.won_count"/>W /
                                            <t t-esc="salesBlock.win_rate.lost_count"/>L
                                            &#183;
                                            <t t-esc="salesBlock.win_rate.window_label"/>
                                        </small>
                                    </div>
                                </div>

                                <div class="o_neon_sales_subwidget">
                                    <h4>Lead sources</h4>
                                    <div t-if="salesBlock.lead_sources.empty"
                                         class="text-muted small"
                                         t-esc="salesBlock.lead_sources.empty_message"/>
                                    <table t-if="!salesBlock.lead_sources.empty"
                                           class="o_neon_sales_lead_table">
                                        <tbody>
                                            <t t-foreach="salesBlock.lead_sources.sources"
                                               t-as="src" t-key="src.source">
                                                <tr>
                                                    <td t-esc="src.source"/>
                                                    <td class="text-end">
                                                        <t t-esc="src.count"/>
                                                        <small class="text-muted ms-1">
                                                            (<t t-esc="src.pct"/>%)
                                                        </small>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                    <small t-if="!salesBlock.lead_sources.empty"
                                           class="text-muted"
                                           t-esc="salesBlock.lead_sources.window_label"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- =================================================
                     Row B - Finance + Alerts + Crew/Equipment.
                     M4 / M6 / M7 placeholders.
                     ================================================= -->
                <section class="o_neon_row_b">
                    <div t-if="isWidgetVisible('block_finance')"
                         class="o_neon_block o_neon_block_finance widget--block_finance">
                        <div class="o_neon_block_header">
                            <h3>Finance &#183; AR &amp; Cash</h3>
                            <button class="btn btn-sm btn-link o_neon_finance_manage_rate"
                                    t-if="isSuperuser"
                                    t-on-click="onManageRateClick">
                                <i class="fa fa-pencil me-1"/>
                                Manage ZiG rate
                            </button>
                        </div>
                        <div class="o_neon_block_body">

                            <!-- Cash detail card -->
                            <div class="o_neon_finance_cash_card">
                                <div t-if="financeBlock.cash.empty"
                                     class="o_neon_block_empty">
                                    <p class="o_neon_block_empty_msg">
                                        No bank/cash journals configured yet
                                    </p>
                                </div>
                                <div t-if="!financeBlock.cash.empty"
                                     class="o_neon_finance_cash_inner">
                                    <h4>Cash on Hand</h4>
                                    <table class="o_neon_finance_cash_table">
                                        <tr>
                                            <td>USD journals</td>
                                            <td class="text-end"
                                                t-esc="formatUsd(financeBlock.cash.usd_total)"/>
                                        </tr>
                                        <tr>
                                            <td>ZiG journals</td>
                                            <td class="text-end">
                                                <t t-esc="formatZwg(financeBlock.cash.zig_total)"/>
                                                <small class="text-muted ms-2"
                                                       t-if="financeBlock.cash.rate">
                                                    @ <t t-esc="financeBlock.cash.rate.toFixed(2)"/>
                                                </small>
                                            </td>
                                        </tr>
                                        <tr t-if="financeBlock.cash.rate"
                                            class="o_neon_finance_cash_zig_usd_row">
                                            <td>
                                                <small class="text-muted">ZiG in USD-equiv</small>
                                            </td>
                                            <td class="text-end">
                                                <small class="text-muted"
                                                       t-esc="formatUsd(financeBlock.cash.zig_in_usd)"/>
                                            </td>
                                        </tr>
                                        <tr class="o_neon_finance_cash_total_row">
                                            <td><strong>Total (USD-equiv)</strong></td>
                                            <td class="text-end">
                                                <strong t-esc="formatUsd(financeBlock.cash.usd_total + financeBlock.cash.zig_in_usd)"/>
                                            </td>
                                        </tr>
                                    </table>
                                    <small class="text-muted o_neon_finance_rate_meta">
                                        Rate source:
                                        <t t-esc="financeBlock.cash.rate_source"/>
                                        <t t-if="financeBlock.cash.rate_as_of">
                                            &#183; updated
                                            <t t-esc="financeBlock.cash.rate_as_of"/>
                                        </t>
                                    </small>
                                </div>
                            </div>

                            <!-- AR Aging table -->
                            <div class="o_neon_finance_ar_card">
                                <h4>AR Aging</h4>
                                <div t-if="financeBlock.ar_aging.empty"
                                     class="o_neon_block_empty">
                                    <p class="o_neon_block_empty_msg"
                                       t-esc="financeBlock.ar_aging.empty_message"/>
                                </div>
                                <table t-if="!financeBlock.ar_aging.empty"
                                       class="o_neon_finance_ar_table">
                                    <thead>
                                        <tr>
                                            <th>Bucket</th>
                                            <th class="text-end">#</th>
                                            <th class="text-end">USD-equiv</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="financeBlock.ar_aging.buckets"
                                           t-as="bucket" t-key="bucket.key">
                                            <tr class="o_neon_finance_ar_row"
                                                t-att-class="bucket.critical ? 'o_neon_finance_ar_row_critical' : ''"
                                                t-on-click="() => this.onAgingBucketClick(bucket)">
                                                <td t-esc="bucket.label"/>
                                                <td class="text-end" t-esc="bucket.count"/>
                                                <td class="text-end" t-esc="bucket.amount_display"/>
                                            </tr>
                                        </t>
                                        <tr class="o_neon_finance_ar_total_row">
                                            <td><strong>Total</strong></td>
                                            <td class="text-end">
                                                <strong t-esc="financeBlock.ar_aging.total_count"/>
                                            </td>
                                            <td class="text-end">
                                                <strong t-esc="financeBlock.ar_aging.total_amount_display"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <small t-if="financeBlock.ar_aging.zig_excluded_count"
                                       class="text-muted o_neon_finance_ar_excluded"
                                       t-esc="financeBlock.ar_aging.zig_excluded_message"/>
                            </div>
                        </div>
                    </div>

                    <div t-if="isWidgetVisible('block_alerts')"
                         class="o_neon_block o_neon_block_alerts widget--block_alerts">
                        <div class="o_neon_block_header">
                            <h3>Alerts</h3>
                            <span class="o_neon_alerts_total"
                                  t-if="!alertsBlock.empty">
                                <t t-esc="alertsBlock.total_count"/> active
                            </span>
                        </div>
                        <div class="o_neon_block_body">
                            <div t-if="alertsBlock.empty"
                                 class="o_neon_block_empty">
                                <p class="o_neon_block_empty_msg">
                                    <t t-esc="alertsBlock.empty_message"/> &#10003;
                                </p>
                            </div>

                            <div t-if="!alertsBlock.empty"
                                 class="o_neon_alerts_inner">
                                <div class="o_neon_alerts_severity_row">
                                    <span class="o_neon_alerts_pill o_neon_alerts_pill_critical"
                                          t-if="alertsBlock.severity_counts.critical">
                                        <t t-esc="alertsBlock.severity_counts.critical"/> critical
                                    </span>
                                    <span class="o_neon_alerts_pill o_neon_alerts_pill_warning"
                                          t-if="alertsBlock.severity_counts.warning">
                                        <t t-esc="alertsBlock.severity_counts.warning"/> warning
                                    </span>
                                    <span class="o_neon_alerts_pill o_neon_alerts_pill_info"
                                          t-if="alertsBlock.severity_counts.info">
                                        <t t-esc="alertsBlock.severity_counts.info"/> info
                                    </span>
                                </div>

                                <ul class="o_neon_alerts_list">
                                    <t t-foreach="alertsBlock.alerts"
                                       t-as="alert" t-key="alert.fingerprint">
                                        <li class="o_neon_alerts_row"
                                            t-att-class="'o_neon_alerts_row_' + alert.severity">
                                            <span class="o_neon_alerts_dot"
                                                  t-att-class="'o_neon_alerts_dot_' + alert.severity"/>
                                            <div class="o_neon_alerts_body"
                                                 t-on-click="() => this.onAlertClick(alert)">
                                                <div class="o_neon_alerts_title"
                                                     t-esc="alert.title"/>
                                                <small class="o_neon_alerts_subtitle"
                                                       t-esc="alert.subtitle"/>
                                            </div>
                                            <button class="btn btn-sm btn-link o_neon_alerts_ack"
                                                    t-if="alert.can_acknowledge"
                                                    t-on-click="() => this.onAlertAck(alert)">
                                                Ack
                                            </button>
                                        </li>
                                    </t>
                                </ul>

                                <div t-if="alertsBlock.has_more"
                                     class="o_neon_alerts_more">
                                    <small class="text-muted">
                                        + more alerts not shown
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div t-if="isWidgetVisible('block_crew_equipment')"
                         class="o_neon_block o_neon_block_crew_equipment widget--block_crew_equipment">
                        <div class="o_neon_block_header">
                            <h3>Crew &amp; Equipment</h3>
                        </div>
                        <div class="o_neon_block_body">

                            <!-- Crew sub-widget -->
                            <div class="o_neon_crew_subwidget">
                                <div t-if="crewEquipment.crew.empty"
                                     class="o_neon_block_empty">
                                    <p class="o_neon_block_empty_msg"
                                       t-esc="crewEquipment.crew.empty_message"/>
                                    <button class="btn btn-link"
                                            t-if="crewEquipment.crew.empty_cta_action"
                                            t-on-click="() => this.onCrewEmptyClick()">
                                        <t t-esc="crewEquipment.crew.empty_cta_label"/>
                                    </button>
                                </div>

                                <table t-if="!crewEquipment.crew.empty"
                                       class="o_neon_crew_table">
                                    <thead>
                                        <tr>
                                            <th>Crew</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="crewEquipment.crew.rows"
                                           t-as="crewRow" t-key="crewRow.user_id">
                                            <tr class="o_neon_crew_row"
                                                t-att-class="crewRow.deeplink_event_job_id ? 'o_neon_crew_row_clickable' : ''"
                                                t-on-click="() => this.onCrewRowClick(crewRow)">
                                                <td>
                                                    <div class="o_neon_crew_name"
                                                         t-esc="crewRow.name"/>
                                                    <small class="text-muted"
                                                           t-esc="crewRow.role_label"/>
                                                </td>
                                                <td>
                                                    <span class="o_neon_crew_status"
                                                          t-att-class="'o_neon_crew_status_' + crewRow.status"
                                                          t-esc="crewRow.booking_label"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <!-- Gap indicators (events with confirmed < required) -->
                                <div t-if="crewEquipment.crew.gaps and crewEquipment.crew.gaps.length"
                                     class="o_neon_crew_gaps">
                                    <h4>Gaps</h4>
                                    <t t-foreach="crewEquipment.crew.gaps"
                                       t-as="gap" t-key="gap.event_job_id">
                                        <div class="o_neon_crew_gap_row"
                                             t-on-click="() => this.onCrewGapClick(gap)">
                                            <span class="o_neon_crew_gap_badge">
                                                Gap - <t t-esc="gap.gap_count"/> needed
                                            </span>
                                            <span class="o_neon_crew_gap_event">
                                                <t t-esc="gap.event_name"/>
                                                <small class="text-muted">
                                                    <t t-esc="gap.event_date"/>
                                                </small>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Equipment sub-widget (one-liner per category) -->
                            <div class="o_neon_equipment_subwidget">
                                <div t-if="crewEquipment.equipment.empty"
                                     class="o_neon_block_empty">
                                    <p class="o_neon_block_empty_msg"
                                       t-esc="crewEquipment.equipment.empty_message"/>
                                    <button class="btn btn-link"
                                            t-if="crewEquipment.equipment.empty_cta_action"
                                            t-on-click="() => this.onEquipmentEmptyClick()">
                                        <t t-esc="crewEquipment.equipment.empty_cta_label"/>
                                    </button>
                                </div>

                                <div t-if="!crewEquipment.equipment.empty"
                                     class="o_neon_equipment_line">
                                    <h4>Equipment</h4>
                                    <t t-foreach="crewEquipment.equipment.categories"
                                       t-as="cat" t-key="cat.category_id || 'uncategorised'">
                                        <span class="o_neon_equipment_cat"
                                              t-on-click="() => this.onEquipmentCatClick(cat)">
                                            <span class="o_neon_equipment_cat_name"
                                                  t-esc="cat.category_name"/>:
                                            <span class="o_neon_equipment_cat_count"
                                                  t-esc="cat.display"/>
                                        </span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- =================================================
                     Row C - Tasks + AI Insights placeholders.
                     M8 / M11.
                     ================================================= -->
                <section class="o_neon_row_c">
                    <div t-if="isWidgetVisible('block_tasks')"
                         class="o_neon_block o_neon_block_tasks widget--block_tasks">
                        <div class="o_neon_block_header">
                            <h3>Tasks</h3>
                            <span class="o_neon_tasks_counts"
                                  t-if="!tasksBlock.empty">
                                <span t-if="tasksBlock.overdue_count"
                                      class="o_neon_tasks_count_overdue">
                                    <t t-esc="tasksBlock.overdue_count"/> overdue
                                </span>
                                <span t-if="tasksBlock.today_count"
                                      class="o_neon_tasks_count_today">
                                    <t t-if="tasksBlock.overdue_count"> &#183; </t>
                                    <t t-esc="tasksBlock.today_count"/> today
                                </span>
                                <span t-if="tasksBlock.upcoming_count"
                                      class="o_neon_tasks_count_upcoming">
                                    <t t-if="tasksBlock.overdue_count or tasksBlock.today_count"> &#183; </t>
                                    <t t-esc="tasksBlock.upcoming_count"/> upcoming
                                </span>
                            </span>
                        </div>
                        <div class="o_neon_block_body">
                            <div t-if="tasksBlock.empty"
                                 class="o_neon_block_empty">
                                <p class="o_neon_block_empty_msg">
                                    <t t-esc="tasksBlock.empty_message"/> &#10003;
                                </p>
                            </div>

                            <ul t-if="!tasksBlock.empty"
                                class="o_neon_tasks_list">
                                <t t-foreach="tasksBlock.tasks"
                                   t-as="task" t-key="task.id">
                                    <li class="o_neon_tasks_row"
                                        t-att-class="'o_neon_tasks_row_' + task.urgency">
                                        <i class="fa o_neon_tasks_icon"
                                           t-att-class="'fa ' + task.activity_icon"/>
                                        <div class="o_neon_tasks_body"
                                             t-on-click="() => this.onTaskClick(task)">
                                            <div class="o_neon_tasks_summary"
                                                 t-esc="task.summary"/>
                                            <small class="o_neon_tasks_source"
                                                   t-if="task.source_label"
                                                   t-esc="task.source_label"/>
                                        </div>
                                        <span class="o_neon_tasks_deadline"
                                              t-att-class="'o_neon_tasks_deadline_' + task.urgency"
                                              t-esc="task.deadline_display"/>
                                        <button class="btn btn-sm btn-link o_neon_tasks_done"
                                                t-on-click="() => this.onTaskDone(task)">
                                            Done
                                        </button>
                                    </li>
                                </t>
                            </ul>

                            <div t-if="!tasksBlock.empty and tasksBlock.has_more"
                                 class="o_neon_tasks_more">
                                <small class="text-muted">
                                    View all (<t t-esc="tasksBlock.total_count"/>)
                                </small>
                            </div>
                        </div>
                    </div>
                    <div t-if="isWidgetVisible('block_ai_insights')"
                         class="o_neon_block o_neon_block_ai widget--block_ai_insights">
                        <div class="o_neon_block_header">
                            <h3>AI Insights</h3>
                            <span class="o_neon_ai_subtitle text-muted"
                                  t-if="aiInsights.id">
                                <t t-if="aiInsights.is_fallback">
                                    AI provider unavailable. Rule-based fallback.
                                </t>
                                <t t-else="">
                                    Updated <t t-esc="aiInsights.age_display or 'just now'"/>
                                </t>
                            </span>
                            <button t-if="canRefreshAi"
                                    class="btn btn-sm btn-link o_neon_ai_refresh"
                                    t-on-click="onAiRefresh"
                                    t-att-disabled="state.aiRefreshing"
                                    title="Refresh AI Insights">
                                <i class="fa"
                                   t-att-class="state.aiRefreshing ? 'fa-spinner fa-spin' : 'fa-refresh'"/>
                            </button>
                        </div>
                        <div class="o_neon_block_body">
                            <div t-if="aiInsights.empty"
                                 class="o_neon_ai_empty text-muted">
                                <p t-esc="aiInsights.empty_message"/>
                            </div>
                            <ul t-if="!aiInsights.empty and aiInsights.insights and aiInsights.insights.length"
                                class="o_neon_ai_list">
                                <li t-foreach="aiInsights.insights" t-as="ins"
                                    t-key="ins_index"
                                    class="o_neon_ai_item"
                                    t-att-class="'o_neon_ai_priority_' + (ins.priority or 9)"
                                    t-on-click="() => this.onAiInsightClick(ins)">
                                    <div class="o_neon_ai_title">
                                        <span class="o_neon_ai_priority_badge"
                                              t-esc="ins.priority or '-'"/>
                                        <span t-esc="ins.title"/>
                                    </div>
                                    <p class="o_neon_ai_detail text-muted"
                                       t-esc="ins.detail"/>
                                </li>
                            </ul>
                            <div t-if="aiInsights.error_message and !aiInsights.is_fallback"
                                 class="o_neon_ai_error text-danger small">
                                <i class="fa fa-exclamation-circle me-1"/>
                                <t t-esc="aiInsights.error_message"/>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </div>
    </t>

</templates>

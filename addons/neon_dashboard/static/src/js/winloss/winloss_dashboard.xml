<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="neon_dashboard.NeonWinlossDashboard">
        <div t-attf-class="o_neon_wl #{state.data and state.data.can_chat ? (state.chatExpanded ? 'o_neon_wl_chat_expanded' : 'o_neon_wl_chat_rail') : ''}">
            <div class="o_neon_wl_main">
                <div class="o_neon_wl_header">
                    <h2>Realisation &amp; Win/Loss</h2>
                </div>
                <div class="o_neon_wl_summary" t-if="state.data">
                    <span class="o_neon_wl_chip">
                        Raw win rate <b><t t-esc="state.data.overall.win_rate_pct"/>%</b>
                        = won/total (<t t-esc="state.data.overall.won"/>/<t t-esc="state.data.overall.quotes"/>)
                        <small class="text-muted">— includes stale historical quotes</small>
                    </span>
                    <span class="o_neon_wl_chip">
                        Decided win rate <b><t t-esc="state.data.overall.decided_win_rate_pct"/>%</b>
                        = won/(won+lost) (<t t-esc="state.data.overall.won"/>/<t t-esc="state.data.overall.won + state.data.overall.lost"/>)
                    </span>
                    <span class="o_neon_wl_chip">
                        Realisation <b><t t-esc="state.data.overall.realisation_pct"/>%</b>
                        = invoiced ÷ won value
                    </span>
                    <span class="o_neon_wl_chip">
                        Value flow (USD, untaxed): quoted <t t-esc="fmt(state.data.overall.quoted_value_usd)"/> →
                        won <t t-esc="fmt(state.data.overall.won_value_usd)"/> →
                        invoiced <t t-esc="fmt(state.data.overall.invoiced_value_usd)"/>
                    </span>
                    <span class="o_neon_wl_chip" t-if="state.data.overall.nonusd_quote_value">
                        <span class="text-muted">non-USD <t t-esc="fmt(state.data.overall.nonusd_quote_value)"/> quoted — disclosed, never blended</span>
                    </span>
                    <div class="o_neon_wl_basisnote text-muted">
                        Value figures are <b>UNTAXED</b> (reconcile to the L1 Realisation pivot); Client Intel (L2.1) figures are incl-VAT — different bases, both correct.
                    </div>
                </div>

                <div t-if="state.loading" class="o_neon_wl_msg">Loading…</div>
                <div t-elif="state.error" class="o_neon_wl_msg text-danger">
                    <t t-esc="state.error"/>
                </div>

                <div t-else="" class="o_neon_wl_grid">
                    <!-- win-rate + realisation by rep -->
                    <div class="o_neon_wl_card o_neon_wl_wide">
                        <h3>By sales rep</h3>
                        <table class="table table-sm">
                            <thead><tr><th>Rep</th><th class="text-end">Win%</th><th class="text-end">Won/Quotes</th><th class="text-end">Won USD</th><th class="text-end">Invoiced USD</th><th class="text-end">Realised% (inv÷won)</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.by_rep" t-as="r" t-key="r_index">
                                    <td t-esc="r.key"/>
                                    <td class="text-end" t-esc="r.win_rate_pct + '%'"/>
                                    <td class="text-end"><t t-esc="r.won"/>/<t t-esc="r.quotes"/></td>
                                    <td class="text-end" t-esc="fmt(r.won_value_usd)"/>
                                    <td class="text-end" t-esc="fmt(r.invoiced_value_usd)"/>
                                    <td class="text-end" t-esc="r.realisation_pct + '%'"/>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- win-rate by category -->
                    <div class="o_neon_wl_card">
                        <h3>Win rate by category</h3>
                        <table class="table table-sm">
                            <thead><tr><th>Category</th><th class="text-end">Win%</th><th class="text-end">Won/Quotes</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.by_category" t-as="c" t-key="c_index">
                                    <td t-esc="c.key"/>
                                    <td class="text-end" t-esc="c.win_rate_pct + '%'"/>
                                    <td class="text-end"><t t-esc="c.won"/>/<t t-esc="c.quotes"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- top clients by win-rate (>=3 quotes) -->
                    <div class="o_neon_wl_card">
                        <h3>Top clients by win rate <small class="text-muted">(≥3 quotes)</small></h3>
                        <table class="table table-sm">
                            <thead><tr><th>Client</th><th class="text-end">Win%</th><th class="text-end">Won/Quotes</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.top_client_winrate" t-as="c" t-key="c_index">
                                    <td t-esc="c.key"/>
                                    <td class="text-end" t-esc="c.win_rate_pct + '%'"/>
                                    <td class="text-end"><t t-esc="c.won"/>/<t t-esc="c.quotes"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- realisation by client (value flow) -->
                    <div class="o_neon_wl_card">
                        <h3>Top clients — realisation <small class="text-muted">(won → invoiced USD)</small></h3>
                        <table class="table table-sm">
                            <thead><tr><th>Client</th><th class="text-end">Won USD</th><th class="text-end">Invoiced USD</th><th class="text-end">Realised% (inv÷won)</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.top_client_realisation" t-as="c" t-key="c_index">
                                    <td t-esc="c.key"/>
                                    <td class="text-end" t-esc="fmt(c.won_value_usd)"/>
                                    <td class="text-end" t-esc="fmt(c.invoiced_value_usd)"/>
                                    <td class="text-end" t-esc="c.realisation_pct + '%'"/>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- monthly win-rate + realisation -->
                    <div class="o_neon_wl_card o_neon_wl_wide">
                        <h3>By period <small class="text-muted">(win-rate + realisation over time)</small></h3>
                        <table class="table table-sm">
                            <thead><tr><th>Month</th><th class="text-end">Quotes</th><th class="text-end">Won</th><th class="text-end">Win%</th><th class="text-end">Won USD</th><th class="text-end">Invoiced USD</th></tr></thead>
                            <tbody>
                                <tr t-foreach="state.data.by_period" t-as="p" t-key="p.key">
                                    <td t-esc="p.key"/>
                                    <td class="text-end" t-esc="p.quotes"/>
                                    <td class="text-end" t-esc="p.won"/>
                                    <td class="text-end" t-esc="p.win_rate_pct + '%'"/>
                                    <td class="text-end" t-esc="fmt(p.won_value_usd)"/>
                                    <td class="text-end" t-esc="fmt(p.invoiced_value_usd)"/>
                                </tr>
                            </tbody>
                        </table>
                        <p class="text-muted" style="font-size:12px;margin-top:6px;">
                            Win rate = won / total quotes (matches Client Intel). Realisation value is USD untaxed and reconciles to the Realisation pivot. Every won quote carries an invoice link (link coverage 100% by construction — not a funnel); the real signal is invoiced/won value. No historical lost-reason (forward-only).
                        </p>
                    </div>
                </div>
            </div>

            <NeonAiChat t-if="state.data and state.data.can_chat"
                        expanded="state.chatExpanded"
                        activeVariant="activeVariant"
                        onToggle="(v) => this.onChatToggle(v)"/>
        </div>
    </t>

</templates>

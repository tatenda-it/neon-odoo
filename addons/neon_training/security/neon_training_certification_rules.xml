<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            P7a.M2 certification record rules.

            Per H2=A (crew can view own records), training_user is
            scoped to user_id = self via a restrictive ir.rule.
            training_signoff and training_admin get unconditional
            access via separate rules; Odoo evaluates rules per
            group and OR-combines, so the unconditional rules lift
            the sales-style restriction for signoff/admin users
            who also carry the training_user group (which they
            do, via implied_ids from M1).

            Pattern reference: neon_finance.quote ir.rule
            (addons/neon_finance/security/ir_rule.xml).

            perm_unlink=False on every rule, belt-and-braces beyond
            the CSV's perm_unlink=0 already blocking deletion
            (audit discipline H3=A).
        -->

        <record id="cert_rule_user_own_only" model="ir.rule">
            <field name="name">Certification: User sees own only</field>
            <field name="model_id"
                   ref="model_neon_training_certification"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_user')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="cert_rule_signoff_all" model="ir.rule">
            <field name="name">Certification: Sign-Off sees all</field>
            <field name="model_id"
                   ref="model_neon_training_certification"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_signoff')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="cert_rule_admin_all" model="ir.rule">
            <field name="name">Certification: Admin sees all</field>
            <field name="model_id"
                   ref="model_neon_training_certification"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_admin')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

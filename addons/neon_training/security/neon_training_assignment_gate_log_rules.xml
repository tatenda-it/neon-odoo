<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            P7a.M9 assignment_gate_log ir.rule scoping.

            training_user is scoped to triggered_by_id = self via a
            restrictive ir.rule (audit visibility per the assigning
            user: a sales rep sees the gate fires they themselves
            triggered, not other reps' fires).

            training_signoff sees all fires (organisation-wide
            audit). training_admin sees all and may write/create
            (override mechanics in M10/M11 write fields on
            existing records).

            Same three-rule pattern as P7a.M2 certification rules
            and P7a.M6 cross-competency rules. Pattern proven; no
            adjustments for gate_log.

            perm_unlink=False on every rule, belt-and-braces beyond
            the CSV perm_unlink=0 already blocking deletion (H3=A).
        -->

        <record id="gatelog_rule_user_own_only" model="ir.rule">
            <field name="name">Gate Log: User sees own triggered fires</field>
            <field name="model_id"
                   ref="model_neon_training_assignment_gate_log"/>
            <field name="domain_force">[('triggered_by_id', '=', user.id)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_user')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="gatelog_rule_signoff_all" model="ir.rule">
            <field name="name">Gate Log: Sign-Off sees all</field>
            <field name="model_id"
                   ref="model_neon_training_assignment_gate_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_signoff')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="gatelog_rule_admin_all" model="ir.rule">
            <field name="name">Gate Log: Admin sees all</field>
            <field name="model_id"
                   ref="model_neon_training_assignment_gate_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('neon_training.group_neon_training_admin')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

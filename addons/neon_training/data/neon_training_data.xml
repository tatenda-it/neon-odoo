<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        P7a.M1 — Seed data for certification categories + types.

        Loaded with noupdate="1" so subsequent `-u neon_training`
        reinstalls do NOT stomp manual edits made via the UI by
        the Lead Tech / Robin / Munashe post-install. Adding NEW rows
        in a later milestone requires either a new <record> here
        (will be created fresh on first install of that build) or
        manual UI creation — append-only audit discipline.

        Categories MUST load before types (the type's category_id
        ref="..." resolves at record-load time, not lazily).
    -->

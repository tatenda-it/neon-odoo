<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        P7a menu placement.

        M1 mounted Categories and Types as direct children of the
        top-level Neon Training menu. M2 introduces the per-person
        Certifications surface as the primary operational view,
        and reparents the reference-data screens under a new
        Configuration submenu so the top of the menu shows the
        thing admins do every day (manage certifications), not
        the thing they do once (configure categories/types).

        XMLIDs preserved on Categories and Types so the M1 browser
        smoke and any cross-module references still resolve.

        DECISION marker (build-time): Certifications menu visible
        to training_user too (not just admin) because crew
        members log in via Odoo (H2=A) to view their own records.
        The certification action's ir.rule scopes the data to own
        records for training_user. The configuration submenu
        stays admin-only (Categories and Types are admin reference
        data; crew have no business editing them).
    -->

    <!-- P7a.M12: root menu visible to training_user + finance_
         sales. Sales reps need the Find Qualified User wizard
         under this root for dispatch staffing; other Training
         children remain hidden behind their own per-menu group
         filters. -->
    <menuitem id="menu_neon_training_root"
              name="Neon Training"
              sequence="80"
              groups="neon_training.group_neon_training_user,neon_finance.group_neon_finance_sales"/>

    <!-- P7a.M12: top-of-menu Dashboard entry. Server-action
         wrapper (NOT direct ir.actions.act_window) so the
         access check fires before the form materialises. -->
    <menuitem id="menu_neon_training_dashboard"
              name="Dashboard"
              parent="menu_neon_training_root"
              action="neon_training_dashboard_action_server"
              sequence="5"
              groups="neon_training.group_neon_training_user"/>

    <!-- P7a.M12: Find Qualified User. Visible to training_user
         + finance_sales (sales reps need staffing search). -->
    <menuitem id="menu_neon_training_find_qualified_user"
              name="Find Qualified User"
              parent="menu_neon_training_root"
              action="neon_training_find_qualified_user_action_server"
              sequence="7"
              groups="neon_training.group_neon_training_user,neon_finance.group_neon_finance_sales"/>

    <menuitem id="menu_neon_training_certifications"
              name="Certifications"
              parent="menu_neon_training_root"
              action="neon_training_certification_action"
              sequence="10"
              groups="neon_training.group_neon_training_user"/>

    <!-- P7a.M6: Cross-Competencies menu. Visible to signoff +
         admin (Lead Tech records these; crew see their own via
         portal in 7b, not via this backend menu). -->
    <menuitem id="menu_neon_training_cross_competencies"
              name="Cross-Competencies"
              parent="menu_neon_training_root"
              action="neon_training_cross_competency_action"
              sequence="20"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <!-- P7a.M9: Gate Log menu. Visible to signoff + admin
         (audit surface; sales reps see their own via ir.rule on
         the action, but the menu itself isn't user-facing). -->
    <menuitem id="menu_neon_training_assignment_gate_log"
              name="Gate Log"
              parent="menu_neon_training_root"
              action="assignment_gate_log_action"
              sequence="30"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <!-- P7a.M12.1: Reports submenu (signoff + admin tiers only;
         sales does not see ZIMRA/NSSA compliance reports per
         DP8). Three child menu items invoke the M12.1 ir.actions
         .report records inline. -->
    <menuitem id="menu_neon_training_reports"
              name="Reports"
              parent="menu_neon_training_root"
              sequence="40"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <menuitem id="menu_neon_training_report_expiring"
              name="Expiring Soon"
              parent="menu_neon_training_reports"
              action="neon_training_expiring_report_action"
              sequence="10"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <menuitem id="menu_neon_training_report_compliance"
              name="Compliance Roster"
              parent="menu_neon_training_reports"
              action="neon_training_compliance_report_action"
              sequence="20"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <menuitem id="menu_neon_training_report_cross_competency"
              name="Cross-Competency Log"
              parent="menu_neon_training_reports"
              action="neon_training_cross_competency_report_action"
              sequence="30"
              groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>

    <menuitem id="menu_neon_training_configuration"
              name="Configuration"
              parent="menu_neon_training_root"
              sequence="90"
              groups="neon_training.group_neon_training_admin"/>

    <menuitem id="menu_neon_training_categories"
              name="Certification Categories"
              parent="menu_neon_training_configuration"
              action="neon_training_certification_category_action"
              sequence="10"/>

    <menuitem id="menu_neon_training_types"
              name="Certification Types"
              parent="menu_neon_training_configuration"
              action="neon_training_certification_type_action"
              sequence="20"/>

</odoo>

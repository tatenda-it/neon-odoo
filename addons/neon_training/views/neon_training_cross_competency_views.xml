<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neon_training_cross_competency_view_tree"
            model="ir.ui.view">
        <field name="name">neon.training.cross_competency.tree</field>
        <field name="model">neon.training.cross_competency</field>
        <field name="arch" type="xml">
            <tree string="Cross-Competencies"
                  decoration-success="performance_rating == 'exceeded_expectation'"
                  decoration-warning="performance_rating == 'below_expectation'"
                  decoration-info="leads_to_certification">
                <field name="display_name" string="Demonstration"/>
                <field name="user_id"/>
                <field name="certification_type_id"/>
                <field name="category_id"/>
                <field name="demonstrated_through_event_id"/>
                <field name="demonstrated_at"/>
                <field name="observed_by_id"/>
                <field name="performance_rating" widget="badge"
                       decoration-success="performance_rating == 'exceeded_expectation'"
                       decoration-warning="performance_rating == 'below_expectation'"/>
                <field name="leads_to_certification"
                       widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="neon_training_cross_competency_view_kanban"
            model="ir.ui.view">
        <field name="name">neon.training.cross_competency.kanban</field>
        <field name="model">neon.training.cross_competency</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id"
                    class="o_kanban_small_column">
                <field name="user_id"/>
                <field name="certification_type_id"/>
                <field name="category_id"/>
                <field name="demonstrated_through_event_id"/>
                <field name="demonstrated_at"/>
                <field name="performance_rating"/>
                <field name="leads_to_certification"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="user_id"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="certification_type_id"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-calendar" title="Demonstrated"/>
                                    <field name="demonstrated_at"/>
                                </div>
                                <div>
                                    <i class="fa fa-map-marker" title="Event"/>
                                    <field name="demonstrated_through_event_id"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span t-if="record.performance_rating.raw_value == 'exceeded_expectation'"
                                          class="badge text-bg-success">
                                        Exceeded
                                    </span>
                                    <span t-if="record.performance_rating.raw_value == 'met_expectation'"
                                          class="badge text-bg-secondary">
                                        Met
                                    </span>
                                    <span t-if="record.performance_rating.raw_value == 'below_expectation'"
                                          class="badge text-bg-warning">
                                        Below
                                    </span>
                                    <span t-if="record.leads_to_certification.raw_value"
                                          class="badge text-bg-info ms-1"
                                          title="Flagged for cert promotion review">
                                        <i class="fa fa-flag"/> Promote?
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="neon_training_cross_competency_view_form"
            model="ir.ui.view">
        <field name="name">neon.training.cross_competency.form</field>
        <field name="model">neon.training.cross_competency</field>
        <field name="arch" type="xml">
            <form string="Cross-Competency">
                <header>
                    <!-- P7a.M7: Promote button. Visible only when
                         the observation is flagged AND has not
                         already been promoted (is_promoted=False).
                         Available to signoff + admin (the same
                         tiers that record cross-competencies). -->
                    <button name="action_promote_to_cert"
                            type="object"
                            string="Promote to Certification Draft"
                            class="oe_highlight"
                            invisible="not leads_to_certification or is_promoted"
                            groups="neon_training.group_neon_training_signoff,neon_training.group_neon_training_admin"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- "Already Promoted" badge surfaces the
                             linked cert(s) when promotion happened.
                             Mutually exclusive with the Promote
                             button above via the same is_promoted
                             flag. -->
                        <button class="oe_stat_button"
                                type="object"
                                name="action_open_promoted_certs"
                                icon="fa-certificate"
                                invisible="not is_promoted">
                            <field name="is_promoted" widget="boolean"
                                   invisible="1"/>
                            <span class="o_stat_text">
                                Already Promoted
                            </span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="user_id" class="oe_edit_only"/>
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Person and Competency">
                            <field name="user_id"
                                   options="{'no_create': True}"/>
                            <field name="certification_type_id"
                                   options="{'no_create': True}"/>
                            <field name="category_id" readonly="1"/>
                        </group>
                        <group string="Event">
                            <field name="demonstrated_through_event_id"
                                   options="{'no_create': True}"/>
                            <field name="event_partner_id" readonly="1"/>
                            <field name="demonstrated_at"/>
                        </group>
                    </group>
                    <group>
                        <group string="Observation">
                            <field name="observed_by_id"
                                   options="{'no_create': True}"/>
                            <field name="performance_rating"
                                   widget="radio"/>
                            <field name="leads_to_certification"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observation Notes" name="notes">
                            <field name="notes" nolabel="1"
                                   placeholder="What was the task? Level of comfort? How did they handle edge cases? Required to make the record actionable."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="neon_training_cross_competency_view_search"
            model="ir.ui.view">
        <field name="name">neon.training.cross_competency.search</field>
        <field name="model">neon.training.cross_competency</field>
        <field name="arch" type="xml">
            <search string="Cross-Competencies">
                <field name="user_id"/>
                <field name="certification_type_id"/>
                <field name="demonstrated_through_event_id"/>
                <field name="event_partner_id"/>
                <field name="observed_by_id"/>
                <separator/>
                <filter name="rating_exceeded"
                        string="Exceeded Expectation"
                        domain="[('performance_rating', '=', 'exceeded_expectation')]"/>
                <filter name="rating_met"
                        string="Met Expectation"
                        domain="[('performance_rating', '=', 'met_expectation')]"/>
                <filter name="rating_below"
                        string="Below Expectation"
                        domain="[('performance_rating', '=', 'below_expectation')]"/>
                <separator/>
                <filter name="leads_to_certification"
                        string="Flagged for Cert Promotion"
                        domain="[('leads_to_certification', '=', True)]"/>
                <separator/>
                <filter name="last_30d"
                        string="Demonstrated in last 30 days"
                        domain="[('demonstrated_at', '&gt;=',
                                  (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <filter name="last_90d"
                        string="Demonstrated in last 90 days"
                        domain="[('demonstrated_at', '&gt;=',
                                  (context_today() - datetime.timedelta(days=90)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_type" string="Competency"
                            context="{'group_by': 'certification_type_id'}"/>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_event"
                            string="Event"
                            context="{'group_by': 'demonstrated_through_event_id'}"/>
                    <filter name="group_observer"
                            string="Observed By"
                            context="{'group_by': 'observed_by_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="neon_training_cross_competency_action"
            model="ir.actions.act_window">
        <field name="name">Cross-Competencies</field>
        <field name="res_model">neon.training.cross_competency</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id"
               ref="neon_training_cross_competency_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No cross-competency observations recorded yet
            </p>
            <p>
                A cross-competency record captures real-world capability
                demonstrated on an event_job where the crew member did
                not (yet) hold a formal certification. Lead Tech records
                these after each event; the data feeds 'who can do what'
                reports and softens assignment gates when a crew member
                lacks a formal cert but has demonstrated equivalent
                capability.
            </p>
        </field>
    </record>

</odoo>

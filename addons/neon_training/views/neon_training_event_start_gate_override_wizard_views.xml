<?xml version="1.0" encoding="utf-8"?>
<!--
    P7a.M11 event-start training gate override wizard view.
    Single form view, opened as a modal via target='new' from
    the inherited action_move_to_in_progress on commercial.
    event.job.

    Stricter visual styling than M10's tier-2 wizard: alert
    banner inside the summary, danger-coloured Confirm button.
    Operator must read the consequences before committing.
-->
<odoo>

    <record id="neon_training_event_start_gate_override_wizard_view_form" model="ir.ui.view">
        <field name="name">neon.training.event_start_gate_override_wizard.form</field>
        <field name="model">neon.training.event_start_gate_override_wizard</field>
        <field name="arch" type="xml">
            <form string="Event Start Blocked -- Training Gate Override Required">
                <group>
                    <field name="event_job_id" readonly="1"/>
                    <field name="target_state" readonly="1" invisible="1"/>
                </group>
                <field name="affected_summary_html"
                       widget="html"
                       readonly="1"/>
                <group>
                    <field name="override_reason"
                           placeholder="Explain why this event must start despite the training gaps. Robin / Munashe will see this on the notification TODO and may escalate (replacement crew, client conversation, Ranganai dispatch). Be specific."
                           required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_override"
                            type="object"
                            string="Confirm Override + Start Event"
                            class="btn-danger"
                            confirm="This will start the event AND notify Robin / Munashe. Proceed?"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

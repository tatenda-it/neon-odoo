<?xml version="1.0" encoding="utf-8"?>
<!--
    P7f: Neon training certificate PDF (Design A, approved).
    QWeb/wkhtmltopdf, landscape A4, zero margins, full-page custom
    layout (NOT web.external_layout). One cert per page. Renders for
    both sub-certs (one track highlighted) and the capstone (all 7 lit)
    via doc._get_certificate_render_vals(). The font-family stacks below
    request Fraunces / Spline Sans / Spline Sans Mono with serif/sans/
    mono fallbacks; those faces are OS-installed in the image at the
    prod-deploy step (wkhtmltopdf honours only OS fonts, not @font-face).
    Until then the cert renders in the clean fallback — Design-A-faithful
    in every other respect. See models/..._certification.py for the why.
-->
<odoo>
    <!-- Landscape A4, no margins; the cert frame is drawn by the
         template itself. -->
    <record id="paperformat_neon_certificate" model="report.paperformat">
        <field name="name">Neon Certificate (A4 landscape, full bleed)</field>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_spacing">0</field>
        <field name="dpi">110</field>
    </record>

    <record id="action_report_certificate" model="ir.actions.report">
        <field name="name">Certificate (PDF)</field>
        <field name="model">neon.training.certification</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">neon_training.report_certificate_document</field>
        <field name="report_file">neon_training.report_certificate_document</field>
        <field name="paperformat_id" ref="paperformat_neon_certificate"/>
        <field name="binding_model_id" ref="model_neon_training_certification"/>
        <field name="binding_type">report</field>
        <!-- Cert owner (training_user, scoped to own via ir.rule) +
             signoff + admin can print. -->
        <field name="groups_id" eval="[(4, ref('neon_training.group_neon_training_user')),
                                        (4, ref('neon_training.group_neon_training_signoff')),
                                        (4, ref('neon_training.group_neon_training_admin'))]"/>
    </record>

    <template id="report_certificate_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="v" t-value="doc._get_certificate_render_vals()"/>
                <!-- All styling is INLINE: wkhtmltopdf 0.12.6 reliably
                     applies style="" attributes but NOT the head-linked
                     report bundle (verified on prod) and NOT an inline
                     <style> block (dropped by Odoo's body-split). Layout is
                     absolute-positioned divs + a footer table; no flexbox /
                     clip-path / var() / pseudo-elements (unsupported by the
                     2016-era QtWebKit). Copy is ASCII (see render-vals). -->
                <div class="page">
                    <div style="font-family:'Spline Sans','Helvetica Neue',Arial,sans-serif;color:#171019;width:100%;">
                        <div style="position:relative;width:100%;height:196mm;background:#fffdf9;overflow:hidden;">
                            <!-- double frame -->
                            <div style="position:absolute;top:5mm;left:5mm;right:5mm;bottom:5mm;border:1.5px solid #b794d4;"/>
                            <div style="position:absolute;top:7mm;left:7mm;right:7mm;bottom:7mm;border:1px solid #ddc89a;"/>
                            <!-- corner accents -->
                            <div style="position:absolute;top:7mm;left:7mm;width:13mm;height:13mm;border-top:3px solid #6B21A8;border-left:3px solid #6B21A8;"/>
                            <div style="position:absolute;top:7mm;right:7mm;width:13mm;height:13mm;border-top:3px solid #6B21A8;border-right:3px solid #6B21A8;"/>
                            <div style="position:absolute;bottom:7mm;left:7mm;width:13mm;height:13mm;border-bottom:3px solid #6B21A8;border-left:3px solid #6B21A8;"/>
                            <div style="position:absolute;bottom:7mm;right:7mm;width:13mm;height:13mm;border-bottom:3px solid #6B21A8;border-right:3px solid #6B21A8;"/>
                            <!-- ribbon + CSS diamond emblem -->
                            <div style="position:absolute;top:5mm;right:24mm;width:15mm;height:23mm;background:#3f0f6b;">
                                <div style="width:5mm;height:5mm;margin:6mm auto 0;background:#ffffff;transform:rotate(45deg);"/>
                            </div>
                            <!-- content column -->
                            <div style="position:absolute;top:13mm;left:16mm;right:16mm;text-align:center;">
                                <img t-if="v['logo']" t-att-src="v['logo']" style="height:15mm;margin:0 auto 4mm;display:block;"/>
                                <div style="font-family:'Spline Sans Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#8a8290;"><t t-out="v['eyebrow']"/></div>
                                <div style="font-family:'Fraunces',Georgia,'Times New Roman',serif;font-weight:900;font-size:33px;line-height:1.05;margin-top:3mm;"><t t-raw="v['title_html']"/></div>
                                <div style="color:#4b4350;font-size:13px;margin-top:6mm;">This is proudly presented to</div>
                                <div style="margin-top:1mm;"><span style="font-family:'Fraunces',Georgia,serif;font-style:italic;font-weight:500;font-size:31px;color:#3f0f6b;padding-bottom:2mm;border-bottom:1.5px solid #c9a35e;display:inline-block;" t-out="v['recipient']"/></div>
                                <div style="color:#4b4350;font-size:12.5px;line-height:1.6;max-width:165mm;margin:5mm auto 0;"><t t-raw="v['body_html']"/></div>
                                <div style="margin-top:6mm;">
                                    <t t-foreach="v['tracks']" t-as="trk">
                                        <span t-att-style="trk['style']" t-out="trk['label']"/>
                                    </t>
                                </div>
                            </div>
                            <!-- footer: sig | seal | meta (table = reliable 3-up).
                                 Wrapped in a positioned div so the table can be
                                 width:100% of the 18mm-inset box and the cells
                                 actually spread (a positioned table with width
                                 auto shrinks + clusters left). -->
                            <div style="position:absolute;bottom:14mm;left:18mm;right:18mm;">
                            <table style="width:100%;border-collapse:collapse;">
                                <tr>
                                    <td style="vertical-align:bottom;text-align:left;width:33%;">
                                        <div style="display:inline-block;width:55mm;border-top:1.5px solid #171019;padding-top:2mm;text-align:center;">
                                            <div style="font-weight:600;font-size:12px;" t-out="v['signatory']"/>
                                            <div style="font-family:'Spline Sans Mono',monospace;font-size:8.5px;letter-spacing:1px;text-transform:uppercase;color:#8a8290;margin-top:1mm;" t-out="v['signatory_role']"/>
                                        </div>
                                    </td>
                                    <td style="vertical-align:bottom;text-align:center;width:34%;">
                                        <div style="display:inline-block;width:24mm;height:24mm;border-radius:50%;background:#6B21A8;color:#ffffff;text-align:center;">
                                            <span style="font-family:'Spline Sans Mono',monospace;font-size:7px;letter-spacing:1px;line-height:1.3;padding:8mm 2mm 0;display:block;" t-out="v['seal']"/>
                                        </div>
                                    </td>
                                    <td style="vertical-align:bottom;text-align:right;width:33%;">
                                        <div style="font-family:'Spline Sans Mono',monospace;font-size:9px;color:#8a8290;line-height:1.5;">
                                            <div>Certificate No. <b style="color:#171019;" t-out="v['number']"/></div>
                                            <div>Issued <b style="color:#171019;" t-out="v['issued']"/></div>
                                            <div>Verify: ref <b style="color:#171019;" t-out="v['verify_ref']"/></div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>

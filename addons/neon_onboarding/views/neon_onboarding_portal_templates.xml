<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        M8 portal templates.

        portal_my_home_onboarding extends the /my dashboard
        with a card linking to /my/onboarding.

        portal_my_onboarding is the actual profile page.

        portal_no_candidate is the fallback when the
        requesting user has no candidate record (e.g., a
        portal user provisioned outside the onboarding flow,
        or a candidate record deleted while the user
        persists).
    -->

    <template id="portal_my_home_onboarding"
              name="Portal Home Onboarding Card"
              inherit_id="portal.portal_my_home"
              priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]"
               position="inside">
            <t t-if="onboarding_count">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">My Onboarding</t>
                    <t t-set="url">/my/onboarding</t>
                    <t t-set="placeholder_count" t-value="'onboarding_count'"/>
                </t>
            </t>
            <t t-if="onboarding_jobs_count">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">My Jobs</t>
                    <t t-set="url">/my/onboarding/jobs</t>
                    <t t-set="placeholder_count" t-value="'onboarding_jobs_count'"/>
                </t>
            </t>
        </xpath>
    </template>

    <template id="portal_my_onboarding" name="My Onboarding">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Onboarding Profile</t>
            </t>
            <div t-if="upload_success"
                 class="alert alert-success mt16">
                Certificate uploaded successfully. Robin or
                Munashe will verify and you'll see the status
                update in the Collected Certifications section
                below.
            </div>
            <div t-if="candidate.state == 'cert_collection'"
                 class="row mt16">
                <div class="col-12">
                    <a href="/my/onboarding/upload"
                       class="btn btn-primary">
                        Upload Certificate
                    </a>
                </div>
            </div>
            <div t-if="candidate.state in ('probationary', 'active')"
                 class="row mt16">
                <div class="col-12">
                    <a href="/my/onboarding/jobs"
                       class="btn btn-secondary">
                        My Jobs
                    </a>
                </div>
            </div>
            <div class="row mt16">
                <div class="col-md-6">
                    <h3>Profile</h3>
                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">
                            <span t-field="candidate.name"/>
                        </dd>
                        <dt class="col-sm-4">Intended Role</dt>
                        <dd class="col-sm-8">
                            <span t-field="candidate.intended_role"/>
                        </dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge text-bg-info">
                                <span t-field="candidate.state"/>
                            </span>
                        </dd>
                        <dt class="col-sm-4">Started</dt>
                        <dd class="col-sm-8">
                            <span t-field="candidate.date_started"/>
                        </dd>
                        <dt class="col-sm-4">Contact Phone</dt>
                        <dd class="col-sm-8">
                            <span t-field="candidate.contact_phone"/>
                        </dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <h3>Required Certifications</h3>
                    <ul t-if="required_certs">
                        <li t-foreach="required_certs" t-as="cert">
                            <span t-esc="cert.name"/>
                        </li>
                    </ul>
                    <p t-if="not required_certs"
                       class="text-muted">
                        No requirements yet. Your manager
                        will assign a requirement template
                        once your intended role is confirmed.
                    </p>
                </div>
            </div>
            <div class="row mt16">
                <div class="col-12">
                    <h3>Collected Certifications</h3>
                    <table class="table" t-if="collected_certs">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>State</th>
                                <th>Date Obtained</th>
                                <th>Expires</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="collected_certs"
                                t-as="c">
                                <td>
                                    <span t-field="c.type_id"/>
                                </td>
                                <td>
                                    <span t-field="c.state"/>
                                </td>
                                <td>
                                    <span t-field="c.date_obtained"/>
                                </td>
                                <td>
                                    <span t-field="c.date_expires"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <p t-if="not collected_certs"
                       class="text-muted">
                        No certifications uploaded yet. The
                        self-upload feature arrives in M9.
                        For now, send certificate scans /
                        photos to your manager and they will
                        upload on your behalf.
                    </p>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_no_candidate" name="No Candidate">
        <t t-call="portal.portal_layout">
            <div class="alert alert-info mt16">
                No onboarding profile found for this account.
                If you believe this is an error, contact your
                administrator.
            </div>
        </t>
    </template>

    <!--
        M9 upload templates. portal_upload_list shows the
        available cert types as clickable cards. portal_upload_
        form is the per-type submission form.
    -->
    <template id="portal_upload_list" name="Upload Cert List">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Upload Certificate</t>
            </t>
            <p class="mt16">
                Select a certification type to upload. Only
                the certifications your role requires are
                listed. Already-submitted certs are not
                shown.
            </p>
            <div t-if="available_types" class="row mt16">
                <div class="col-md-6 mb-3"
                     t-foreach="available_types" t-as="ct">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <span t-field="ct.name"/>
                            </h5>
                            <p class="card-text text-muted small">
                                <span t-field="ct.description"/>
                            </p>
                            <a t-attf-href="/my/onboarding/upload/#{ct.id}"
                               class="btn btn-primary btn-sm">
                                Upload This Cert
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div t-if="not available_types"
                 class="alert alert-info mt16">
                All required certs have been submitted. Wait
                for Robin or Munashe to verify, then your
                onboarding will advance automatically.
            </div>
            <div class="mt16">
                <a href="/my/onboarding" class="btn btn-link">
                    Back to my onboarding profile
                </a>
            </div>
        </t>
    </template>

    <!--
        M10 jobs templates. portal_jobs is the table view +
        filter chips; portal_job_detail is the read-only
        single-event-job page.
    -->
    <template id="portal_jobs" name="My Jobs">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Jobs</t>
            </t>
            <div class="mt16 mb-3">
                <a href="/my/onboarding/jobs?filter_state=all"
                   t-attf-class="btn btn-sm #{'btn-primary' if filter_state == 'all' else 'btn-outline-secondary'}">
                    All
                </a>
                <a href="/my/onboarding/jobs?filter_state=upcoming"
                   t-attf-class="btn btn-sm #{'btn-primary' if filter_state == 'upcoming' else 'btn-outline-secondary'} ms-1">
                    Upcoming
                </a>
                <a href="/my/onboarding/jobs?filter_state=in_progress"
                   t-attf-class="btn btn-sm #{'btn-primary' if filter_state == 'in_progress' else 'btn-outline-secondary'} ms-1">
                    In Progress
                </a>
                <a href="/my/onboarding/jobs?filter_state=completed"
                   t-attf-class="btn btn-sm #{'btn-primary' if filter_state == 'completed' else 'btn-outline-secondary'} ms-1">
                    Completed
                </a>
            </div>
            <table class="table" t-if="jobs_data">
                <thead>
                    <tr>
                        <th>Event Date</th>
                        <th>Job</th>
                        <th>Venue</th>
                        <th>Role</th>
                        <th>State</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="jobs_data" t-as="row">
                        <td>
                            <span t-field="row['event_job'].event_date"/>
                        </td>
                        <td>
                            <a t-attf-href="/my/onboarding/jobs/#{row['event_job'].id}">
                                <span t-field="row['event_job'].name"/>
                            </a>
                        </td>
                        <td>
                            <span t-field="row['event_job'].commercial_job_id.venue_id"/>
                        </td>
                        <td>
                            <span t-esc="row['role']"/>
                        </td>
                        <td>
                            <span class="badge text-bg-info">
                                <span t-field="row['event_job'].state"/>
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div t-if="not jobs_data"
                 class="alert alert-info">
                No jobs match this filter. Try the All chip
                to see every assigned job, or wait for your
                next scheduling.
            </div>
            <div class="mt16">
                <a href="/my/onboarding" class="btn btn-link">
                    Back to onboarding profile
                </a>
            </div>
        </t>
    </template>

    <template id="portal_job_detail" name="Job Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Job Detail</t>
            </t>
            <div class="mt16">
                <h3>
                    <span t-field="event_job.name"/>
                </h3>
                <dl class="row mt16">
                    <dt class="col-sm-3">Event Date</dt>
                    <dd class="col-sm-9">
                        <span t-field="event_job.event_date"/>
                    </dd>
                    <dt class="col-sm-3">End Date</dt>
                    <dd class="col-sm-9">
                        <span t-field="event_job.event_end_date"/>
                    </dd>
                    <dt class="col-sm-3">Venue</dt>
                    <dd class="col-sm-9">
                        <span t-field="event_job.commercial_job_id.venue_id"/>
                    </dd>
                    <dt class="col-sm-3">Client</dt>
                    <dd class="col-sm-9">
                        <span t-field="event_job.commercial_job_id.partner_id"/>
                    </dd>
                    <dt class="col-sm-3">State</dt>
                    <dd class="col-sm-9">
                        <span class="badge text-bg-info">
                            <span t-field="event_job.state"/>
                        </span>
                    </dd>
                    <dt class="col-sm-3">Your Role</dt>
                    <dd class="col-sm-9">
                        <span t-field="crew_assignment.role"/>
                    </dd>
                </dl>
            </div>
            <div class="mt16">
                <a href="/my/onboarding/jobs"
                   class="btn btn-link">
                    Back to my jobs
                </a>
            </div>
        </t>
    </template>

    <template id="portal_upload_form" name="Upload Cert Form">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Upload Certificate</t>
            </t>
            <div class="mt16">
                <h3>
                    Upload: <span t-field="cert_type.name"/>
                </h3>
                <p t-if="cert_type.description"
                   class="text-muted">
                    <span t-field="cert_type.description"/>
                </p>
                <div t-if="error"
                     class="alert alert-danger">
                    <span t-esc="error"/>
                </div>
                <form action="" method="POST"
                      enctype="multipart/form-data"
                      class="mt16">
                    <input type="hidden" name="csrf_token"
                           t-att-value="request.csrf_token()"/>
                    <div class="mb-3">
                        <label class="form-label"
                               for="cert_file">
                            Certificate File (PDF / JPG /
                            PNG, max 10 MB)
                        </label>
                        <input type="file" name="cert_file"
                               id="cert_file"
                               class="form-control"
                               accept=".pdf,.jpg,.jpeg,.png"
                               required="required"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"
                               for="date_obtained">
                            Date Obtained
                        </label>
                        <input type="date"
                               name="date_obtained"
                               id="date_obtained"
                               class="form-control"
                               required="required"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"
                               for="date_expires">
                            Date Expires (optional)
                        </label>
                        <input type="date"
                               name="date_expires"
                               id="date_expires"
                               class="form-control"/>
                    </div>
                    <button type="submit"
                            class="btn btn-primary">
                        Submit
                    </button>
                    <a href="/my/onboarding/upload"
                       class="btn btn-link">
                        Cancel
                    </a>
                </form>
            </div>
        </t>
    </template>
</odoo>

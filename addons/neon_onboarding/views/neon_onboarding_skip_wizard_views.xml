<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_neon_onboarding_skip_wizard_form"
            model="ir.ui.view">
        <field name="name">neon.onboarding.skip.wizard.form</field>
        <field name="model">neon.onboarding.skip.wizard</field>
        <field name="arch" type="xml">
            <form string="Skip Onboarding">
                <p>
                    Skip Onboarding promotes the candidate
                    directly to <strong>Active</strong>,
                    bypassing the cert collection +
                    probationary stages. Use for existing crew
                    members being bulk-imported, or when admin
                    discretion warrants.
                </p>
                <p class="text-muted">
                    The audit log captures who triggered this
                    and why. This cannot be undone -- the
                    candidate becomes Active and the bypass
                    metadata is permanent.
                </p>
                <group>
                    <field name="candidate_id" readonly="1"/>
                    <field name="candidate_state" readonly="1"/>
                    <field name="candidate_user_id" readonly="1"/>
                    <field name="reason" placeholder="e.g., Existing crew from pre-Phase-7b deploy, added 22 May 2026"/>
                </group>
                <separator string="User Account"/>
                <group>
                    <field name="create_user"/>
                    <field name="proposed_login"
                           invisible="not create_user"
                           required="create_user"/>
                </group>
                <separator string="Skip Notes (optional)"/>
                <field name="notes"
                       nolabel="1"
                       placeholder="Additional context appended to the audit log. e.g. 'Existing crew from pre-deploy 21 May 2026'."/>
                <footer>
                    <button name="action_skip" type="object"
                            string="Skip Onboarding"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_neon_onboarding_skip_wizard"
            model="ir.actions.act_window">
        <field name="name">Skip Onboarding</field>
        <field name="res_model">neon.onboarding.skip.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id"
               eval="[(4, ref('neon_core.group_neon_superuser'))]"/>
    </record>
</odoo>

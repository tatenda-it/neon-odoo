<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        M3 view set: kanban (manager-facing primary view) +
        tree + polished form. Menus + actions live in
        neon_onboarding_menu.xml so view-vs-menu changes are
        decoupled going forward.
    -->

    <record id="view_neon_onboarding_candidate_kanban"
            model="ir.ui.view">
        <field name="name">neon.onboarding.candidate.kanban</field>
        <field name="model">neon.onboarding.candidate</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="intended_role"/>
                <field name="state"/>
                <field name="date_started"/>
                <field name="photo"/>
                <field name="requirement_template_id"/>
                <field name="bypass_actor_id"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_image">
                                    <img t-if="record.photo.raw_value"
                                         t-att-src="kanban_image('neon.onboarding.candidate', 'photo', record.id.raw_value)"
                                         alt="Photo"
                                         class="o_kanban_avatar"
                                         style="width:48px;height:48px;border-radius:50%;object-fit:cover;"/>
                                    <div t-else=""
                                         class="o_kanban_avatar bg-secondary text-white d-flex align-items-center justify-content-center"
                                         style="width:48px;height:48px;border-radius:50%;font-weight:bold;">
                                        <span t-esc="record.name.raw_value ? record.name.raw_value[0].toUpperCase() : '?'"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_headings ms-2">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted small">
                                        <field name="intended_role"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body small text-muted mt-2">
                                <div t-if="record.requirement_template_id.raw_value">
                                    Template: <field name="requirement_template_id"/>
                                </div>
                                <div>
                                    Started: <field name="date_started" widget="date"/>
                                </div>
                                <div t-if="record.bypass_actor_id.raw_value"
                                     class="text-warning">
                                    <i class="fa fa-shield"/> Admin override applied
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_neon_onboarding_candidate_tree" model="ir.ui.view">
        <field name="name">neon.onboarding.candidate.tree</field>
        <field name="model">neon.onboarding.candidate</field>
        <field name="arch" type="xml">
            <tree string="Onboarding Candidates"
                  decoration-info="state == 'candidate'"
                  decoration-warning="state == 'cert_collection'"
                  decoration-success="state == 'active'">
                <field name="name"/>
                <field name="intended_role"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'candidate'"
                       decoration-warning="state == 'cert_collection'"
                       decoration-muted="state == 'probationary'"
                       decoration-success="state == 'active'"/>
                <field name="requirement_template_id" optional="show"/>
                <field name="contact_phone" optional="hide"/>
                <field name="date_started"/>
                <field name="user_id" optional="show"/>
                <field name="bypass_actor_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_onboarding_candidate_form" model="ir.ui.view">
        <field name="name">neon.onboarding.candidate.form</field>
        <field name="model">neon.onboarding.candidate</field>
        <field name="arch" type="xml">
            <form string="Onboarding Candidate">
                <header>
                    <button name="%(action_neon_onboarding_skip_wizard)d"
                            type="action"
                            string="Skip Onboarding (Admin)"
                            class="oe_highlight"
                            groups="neon_core.group_neon_superuser"
                            context="{'default_candidate_id': active_id}"
                            invisible="state == 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="candidate,cert_collection,probationary,active"/>
                </header>
                <sheet>
                    <field name="photo" widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'photo'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Full Name"/></h1>
                        <h3 class="text-muted">
                            <field name="intended_role"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Person &amp; Contact">
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_phone"/>
                        </group>
                        <group string="Linkage &amp; Dates">
                            <field name="user_id"
                                   readonly="state != 'active'"
                                   options="{'no_create': True}"/>
                            <field name="date_started"/>
                            <field name="date_activated" readonly="1"/>
                        </group>
                    </group>
                    <group string="Requirements" col="2">
                        <field name="requirement_template_id"
                               options="{'no_create': True}"/>
                        <div colspan="2"
                             invisible="not requirement_template_id"
                             class="text-muted small">
                            Click the template to view required
                            cert types. Inline list of certs
                            with held / pending / missing
                            indicators lands in M4 alongside
                            cert collection integration.
                        </div>
                    </group>
                    <group string="Sign-Off (Admin Override)"
                           invisible="not bypass_actor_id">
                        <field name="bypass_actor_id" readonly="1"/>
                        <field name="bypass_reason" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Probationary"
                              invisible="state not in ('probationary', 'active')">
                            <group>
                                <field name="probationary_jobs_target"/>
                                <field name="probationary_jobs_completed" readonly="1"/>
                            </group>
                            <div class="text-muted small">
                                Full job-counting compute lands in M5.
                                M3 ships the field surface only.
                            </div>
                        </page>
                        <page string="Audit Log"
                              groups="neon_core.group_neon_superuser,neon_training.group_neon_training_admin,neon_training.group_neon_training_signoff">
                            <field name="audit_log_ids" readonly="1">
                                <tree decoration-warning="action == 'skip_onboarding'">
                                    <field name="timestamp"/>
                                    <field name="action"/>
                                    <field name="actor_id"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                    <field name="reason"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_neon_onboarding_candidate_search" model="ir.ui.view">
        <field name="name">neon.onboarding.candidate.search</field>
        <field name="model">neon.onboarding.candidate</field>
        <field name="arch" type="xml">
            <search string="Search Candidates">
                <field name="name"/>
                <field name="intended_role"/>
                <field name="user_id"/>
                <field name="requirement_template_id"/>
                <separator/>
                <filter name="filter_candidate" string="New Candidates"
                        domain="[('state', '=', 'candidate')]"/>
                <filter name="filter_cert_collection" string="Cert Collection"
                        domain="[('state', '=', 'cert_collection')]"/>
                <filter name="filter_probationary" string="Probationary"
                        domain="[('state', '=', 'probationary')]"/>
                <filter name="filter_active" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <separator/>
                <filter name="filter_bypassed" string="Admin Override Applied"
                        domain="[('bypass_actor_id', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_role" string="Intended Role"
                            context="{'group_by': 'intended_role'}"/>
                    <filter name="group_template" string="Requirement Template"
                            context="{'group_by': 'requirement_template_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_neon_onboarding_candidate" model="ir.actions.act_window">
        <field name="name">Onboarding Candidates</field>
        <field name="res_model">neon.onboarding.candidate</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_neon_onboarding_candidate_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first onboarding candidate.
            </p>
            <p>
                Track new crew through Candidate -> Cert
                Collection -> Probationary -> Active. Use the
                Skip Onboarding button (admin only) for
                existing crew bulk-imports.
            </p>
        </field>
    </record>
</odoo>

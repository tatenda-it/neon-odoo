<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Record rule: crew tier sees only their own candidate
        record. Filters by user_id == self.

        noupdate=1 so admin tweaks to the rule survive future
        upgrades.

        Bookkeeper / Sales Rep / Lead Tech tiers do NOT have an
        ACL row in ir.model.access.csv, so they have no row-
        level access regardless of this rule. The rule applies
        only to the crew tier which DOES have an ACL row.

        Superuser + training_admin + training_signoff bypass
        this rule by virtue of having ACL but no rule attached
        to their group (Odoo ir.rule semantics: rules are
        per-group; users in other groups skip the rule).
    -->
    <record id="rule_candidate_crew_own" model="ir.rule">
        <field name="name">Crew sees own candidate record only</field>
        <field name="model_id" ref="model_neon_onboarding_candidate"/>
        <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!--
        Audit log read access: crew tier can read their own
        candidate's audit entries (helpful for "why was I
        promoted/skipped?" visibility), but only via the
        candidate they own.

        Training tiers (user / signoff / admin) see all audit
        entries (no row-level filter) via their CSV
        permissions.
    -->
    <record id="rule_audit_log_crew_own_candidate"
            model="ir.rule">
        <field name="name">Crew sees audit entries on own candidate</field>
        <field name="model_id" ref="model_neon_onboarding_audit_log"/>
        <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
        <field name="domain_force">[('candidate_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_neon_doc_gen_set_key_wizard_form" model="ir.ui.view">
        <field name="name">neon.doc.gen.set.key.wizard.form</field>
        <field name="model">neon.doc.gen.set.key.wizard</field>
        <field name="arch" type="xml">
            <form string="Set Doc-Gen API Key">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Paste the Anthropic API key below. The value
                        is masked, never logged, and the wizard row
                        is removed immediately after saving.
                    </div>
                    <group>
                        <field name="provider_id" readonly="1"/>
                        <field name="api_key" password="True"
                               placeholder="sk-ant-..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save_key"
                            type="object"
                            string="Save key"
                            class="btn-primary"/>
                    <button special="cancel"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

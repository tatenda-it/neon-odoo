<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============ LINE views (the Excel-tabs feel) ============ -->
    <record id="view_weekly_budget_line_tree" model="ir.ui.view">
        <field name="name">neon.weekly.budget.line.tree</field>
        <field name="model">neon.weekly.budget.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom" sample="1">
                <field name="week_id" optional="show"/>
                <field name="date"/>
                <field name="details"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="amount" sum="Total Planned"/>
                <field name="paid" sum="Total Paid"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'paid'"
                       decoration-warning="status == 'pending'"
                       decoration-info="status == 'planned'"/>
                <field name="due_date" optional="show"/>
                <field name="currency_id" optional="hide" groups="base.group_multi_currency"/>
                <field name="notes" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_weekly_budget_line_form" model="ir.ui.view">
        <field name="name">neon.weekly.budget.line.form</field>
        <field name="model">neon.weekly.budget.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="week_id"/>
                            <field name="date"/>
                            <field name="details"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="currency_id"/>
                            <field name="amount"/>
                            <field name="paid"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Conditions / comments (e.g. payable when X pays)"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_weekly_budget_line" model="ir.actions.act_window">
        <field name="name">Weekly Budget</field>
        <field name="res_model">neon.weekly.budget.line</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">No budget lines yet</p>
            <p>Plan the week's cash items here, grouped by week.</p>
        </field>
    </record>

    <record id="view_weekly_budget_line_search" model="ir.ui.view">
        <field name="name">neon.weekly.budget.line.search</field>
        <field name="model">neon.weekly.budget.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="details"/>
                <field name="week_id"/>
                <filter name="planned" string="Planned" domain="[('status','=','planned')]"/>
                <filter name="pending" string="Pending" domain="[('status','=','pending')]"/>
                <filter name="paid" string="Paid" domain="[('status','=','paid')]"/>
                <group expand="1" string="Group By">
                    <filter name="group_week" string="Week" context="{'group_by': 'week_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ WEEK container views (totals) ============ -->
    <record id="view_weekly_budget_tree" model="ir.ui.view">
        <field name="name">neon.weekly.budget.tree</field>
        <field name="model">neon.weekly.budget</field>
        <field name="arch" type="xml">
            <tree>
                <field name="week_start"/>
                <field name="name"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="total_planned" sum="Planned"/>
                <field name="total_paid" sum="Paid"/>
            </tree>
        </field>
    </record>

    <record id="view_weekly_budget_form" model="ir.ui.view">
        <field name="name">neon.weekly.budget.form</field>
        <field name="model">neon.weekly.budget</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="week_start"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="total_planned"/>
                            <field name="total_paid"/>
                        </group>
                    </group>
                    <field name="line_ids" context="{'default_week_id': id}">
                        <tree editable="bottom">
                            <field name="date"/>
                            <field name="details"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="amount" sum="Planned"/>
                            <field name="paid" sum="Paid"/>
                            <field name="status" widget="badge"/>
                            <field name="due_date"/>
                            <field name="notes"/>
                        </tree>
                    </field>
                    <field name="note" placeholder="Week notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_weekly_budget" model="ir.actions.act_window">
        <field name="name">Weeks</field>
        <field name="res_model">neon.weekly.budget</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ============ Menu (finance-gated, NOT base.group_user) ============ -->
    <menuitem id="menu_weekly_budget_root"
              name="Weekly Budget"
              web_icon="account,static/description/icon.png"
              sequence="17"
              groups="neon_finance.group_neon_finance_bookkeeper,neon_finance.group_neon_finance_approver,account.group_account_manager,neon_core.group_neon_superuser"/>

    <menuitem id="menu_weekly_budget_lines"
              name="Weekly Budget"
              parent="menu_weekly_budget_root"
              action="action_weekly_budget_line"
              sequence="10"/>

    <menuitem id="menu_weekly_budget_weeks"
              name="Weeks"
              parent="menu_weekly_budget_root"
              action="action_weekly_budget"
              sequence="20"/>

</odoo>

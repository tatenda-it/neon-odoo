<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ INVOICE ARCHIVE ============ -->
    <record id="view_invoice_archive_tree" model="ir.ui.view">
        <field name="model">neon.finance.invoice.archive</field>
        <field name="arch" type="xml">
            <tree string="Archived Zoho Invoices" create="false" edit="false">
                <field name="zoho_invoice_number"/>
                <field name="invoice_date"/>
                <field name="partner_id"/>
                <field name="zoho_estimate_number" optional="show"/>
                <field name="status_bucket"/>
                <field name="status" optional="hide"/>
                <field name="currency_code"/>
                <field name="amount_untaxed" sum="Untaxed" optional="hide"/>
                <field name="amount_tax" optional="hide"/>
                <field name="amount_total" sum="Total"/>
                <field name="salesperson_id" optional="hide"/>
                <field name="event_summary" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_invoice_archive_form" model="ir.ui.view">
        <field name="model">neon.finance.invoice.archive</field>
        <field name="arch" type="xml">
            <form string="Archived Zoho Invoice" create="false">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="zoho_invoice_number" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="zoho_customer_source_id" readonly="1"/>
                            <field name="zoho_estimate_number" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="event_summary" readonly="1"/>
                        </group>
                        <group>
                            <field name="status_bucket" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="currency_code" readonly="1"/>
                            <field name="salesperson_id" readonly="1"/>
                            <field name="salesperson_name" readonly="1"/>
                            <field name="active" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="1">
                                <tree string="Lines">
                                    <field name="sequence" widget="handle"/>
                                    <field name="category_prefix"/>
                                    <field name="name"/>
                                    <field name="description" optional="hide"/>
                                    <field name="unit" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="unit_rate"/>
                                    <field name="line_total"/>
                                    <field name="zoho_item_id" optional="hide"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed" readonly="1"/>
                                <field name="amount_tax" readonly="1"/>
                                <field name="amount_total" readonly="1"/>
                            </group>
                        </page>
                        <page string="Import Note">
                            <field name="note" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_invoice_archive_search" model="ir.ui.view">
        <field name="model">neon.finance.invoice.archive</field>
        <field name="arch" type="xml">
            <search string="Archived Zoho Invoices">
                <field name="zoho_invoice_number"/>
                <field name="partner_id"/>
                <field name="zoho_estimate_number"/>
                <filter name="f_paid" string="Paid"
                        domain="[('status_bucket','=','paid')]"/>
                <filter name="f_unpaid" string="Unpaid"
                        domain="[('status_bucket','=','unpaid')]"/>
                <filter name="f_void" string="Void"
                        domain="[('status_bucket','=','void')]"/>
                <separator/>
                <filter name="f_archived" string="Archived"
                        domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_status" string="Status"
                            context="{'group_by':'status_bucket'}"/>
                    <filter name="g_partner" string="Customer"
                            context="{'group_by':'partner_id'}"/>
                    <filter name="g_currency" string="Currency"
                            context="{'group_by':'currency_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_invoice_archive" model="ir.actions.act_window">
        <field name="name">Archived Zoho Invoices</field>
        <field name="res_model">neon.finance.invoice.archive</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_invoice_archive_search"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No archived Zoho invoices yet</p>
            <p>Reference / historical invoices imported from Zoho Books.
               Read-only — these are NOT real invoices and never touch the
               live ledger; Zoho remains the system of record for collections.</p>
        </field>
    </record>

    <!-- ============ EXPENSE ARCHIVE ============ -->
    <record id="view_expense_archive_tree" model="ir.ui.view">
        <field name="model">neon.finance.expense.archive</field>
        <field name="arch" type="xml">
            <tree string="Archived Zoho Expenses" create="false" edit="false">
                <field name="zoho_expense_id" optional="hide"/>
                <field name="expense_date"/>
                <field name="account_name"/>
                <field name="description"/>
                <field name="is_billable"/>
                <field name="partner_id" optional="show"/>
                <field name="status" optional="hide"/>
                <field name="currency_code"/>
                <field name="amount" sum="Amount"/>
                <field name="tax" optional="hide"/>
                <field name="reference_number" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_expense_archive_form" model="ir.ui.view">
        <field name="model">neon.finance.expense.archive</field>
        <field name="arch" type="xml">
            <form string="Archived Zoho Expense" create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="zoho_expense_id" readonly="1"/>
                            <field name="expense_date" readonly="1"/>
                            <field name="account_name" readonly="1"/>
                            <field name="description" readonly="1"/>
                            <field name="reference_number" readonly="1"/>
                        </group>
                        <group>
                            <field name="status" readonly="1"/>
                            <field name="is_billable" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="currency_code" readonly="1"/>
                            <field name="amount" readonly="1"/>
                            <field name="tax" readonly="1"/>
                            <field name="active" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="1">
                                <tree string="Lines">
                                    <field name="description"/>
                                    <field name="account_name"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Import Note">
                            <field name="note" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_expense_archive_search" model="ir.ui.view">
        <field name="model">neon.finance.expense.archive</field>
        <field name="arch" type="xml">
            <search string="Archived Zoho Expenses">
                <field name="account_name"/>
                <field name="description"/>
                <field name="partner_id"/>
                <filter name="f_billable" string="Billable"
                        domain="[('is_billable','=',True)]"/>
                <separator/>
                <filter name="f_archived" string="Archived"
                        domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_account" string="Account"
                            context="{'group_by':'account_name'}"/>
                    <filter name="g_currency" string="Currency"
                            context="{'group_by':'currency_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_expense_archive" model="ir.actions.act_window">
        <field name="name">Archived Zoho Expenses</field>
        <field name="res_model">neon.finance.expense.archive</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_expense_archive_search"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No archived Zoho expenses yet</p>
            <p>Reference / historical expenses imported from Zoho Books.
               Read-only — never posted to the ledger.</p>
        </field>
    </record>

    <!-- menus under the existing Zoho Archive root -->
    <menuitem id="menu_invoice_archive" name="Archived Invoices"
              parent="menu_neon_migration_root"
              action="action_invoice_archive" sequence="20"/>
    <menuitem id="menu_expense_archive" name="Archived Expenses"
              parent="menu_neon_migration_root"
              action="action_expense_archive" sequence="30"/>

</odoo>

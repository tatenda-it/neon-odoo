<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit the standard CRM opportunity/lead form view.
        Adds:
            Round D:
            - x_brand              (selection, in the opportunity group)
            - x_lead_score         (integer, inline next to priority stars)
            - x_sla_breached       (boolean, displayed as a red web_ribbon)

            Round E:
            - x_consent_given      (checkbox, near email_from)
            - x_first_response_time (datetime, in Internal Notes tab)
            - x_equipment_required (text, new notebook page Event Brief)
            - x_annual_event_month (selection, always visible)
    -->
    <record id="view_crm_lead_form_neon" model="ir.ui.view">
        <field name="name">crm.lead.form.neon.extensions</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//widget[@name='web_ribbon'][1]" position="before">
                <field name="x_alert_label" invisible="1"/>
                <field name="x_alert_color" invisible="1"/>
                <widget name="web_ribbon"
                        title="SLA + DUPLICATE"
                        bg_color="text-bg-danger"
                        invisible="x_alert_label != 'SLA + DUPLICATE'"/>
                <widget name="web_ribbon"
                        title="SLA Breached"
                        bg_color="text-bg-danger"
                        invisible="x_alert_label != 'SLA Breached'"/>
                <widget name="web_ribbon"
                        title="Possible Duplicate"
                        bg_color="text-bg-warning"
                        invisible="x_alert_label != 'Possible Duplicate'"/>
            </xpath>

            <xpath expr="//div[hasclass('o_lead_opportunity_form_inline_fields')]/field[@name='priority']" position="after">
                <field name="x_lead_score"
                       readonly="1"
                       class="oe_inline"
                       string="Score"/>
            </xpath>

            <xpath expr="//group[not(@name='lead_partner') and not(@name='opportunity_partner') and not(@name='lead_priority')]/field[@name='tag_ids']" position="after">
                <field name="x_brand"/>
                <field name="x_annual_event_month"/>
            </xpath>

            <xpath expr="//field[@name='email_from']" position="after">
                <field name="x_consent_given"/>
            </xpath>

            <xpath expr="//page[@name='internal_notes']/field[@name='description']" position="before">
                <group>
                    <field name="x_first_response_time" readonly="1"/>
                </group>
            </xpath>

            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Event Brief" name="event_brief">
                    <group>
                        <field name="x_equipment_required" nolabel="1" placeholder="e.g. 2x LED wall, 12-channel mixer, 6m x 4m stage"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <record id="view_crm_lead_tree_neon" model="ir.ui.view">
        <field name="name">crm.lead.tree.neon.extensions</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="x_brand" optional="show"/>
                <field name="x_lead_score" optional="show" readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>
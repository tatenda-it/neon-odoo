<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Daily deduplication scan.

            Runs once a day, scans all active opportunities, and sets
            x_duplicate_flag on any lead that shares a phone or email
            with another active lead.

            noupdate="1" means: on module upgrade, do NOT overwrite the
            user's customisations to schedule (e.g. if Robin or Tatenda
            edits the cron interval in the UI, that won't be reverted).
        -->
        <record id="ir_cron_neon_dedup_check" model="ir.cron">
            <field name="name">Neon: Daily lead deduplication check</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_run_dedup_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
        <!--
            Section 6 automation rules — Round I (detection only).
            All five rules log their findings to the Odoo log but do
            NOT yet create activities or send notifications. Round J
            will add real side effects.
        -->

        <record id="ir_cron_neon_rule3_quote_d3" model="ir.cron">
            <field name="name">Neon Rule 3: Quote follow-up Day 3</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_rule3_quote_followup_d3()</field>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_neon_rule4_quote_d7" model="ir.cron">
            <field name="name">Neon Rule 4: Quote follow-up Day 7 escalation</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_rule4_quote_followup_d7()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_neon_rule5_stuck_deal" model="ir.cron">
            <field name="name">Neon Rule 5: Stuck deal alert</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_rule5_stuck_deal()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_neon_rule8_annual_client" model="ir.cron">
            <field name="name">Neon Rule 8: Annual client re-engagement</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_rule8_annual_client()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_neon_rule9_duplicate_warning" model="ir.cron">
            <field name="name">Neon Rule 9: Duplicate lead warning</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._neon_rule9_duplicate_warning()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
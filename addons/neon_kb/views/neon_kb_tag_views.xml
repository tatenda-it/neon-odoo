<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kb_tag_tree" model="ir.ui.view">
        <field name="name">neon.kb.tag.tree</field>
        <field name="model">neon.kb.tag</field>
        <field name="arch" type="xml">
            <tree string="KB Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="article_count"/>
                <field name="active" widget="boolean_toggle"
                       optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_kb_tag_form" model="ir.ui.view">
        <field name="name">neon.kb.tag.form</field>
        <field name="model">neon.kb.tag</field>
        <field name="arch" type="xml">
            <form string="KB Tag">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="Tag name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="color"
                               widget="color_picker"/>
                        <field name="article_count"
                               readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kb_tag"
            model="ir.actions.act_window">
        <field name="name">KB Tags</field>
        <field name="res_model">neon.kb.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

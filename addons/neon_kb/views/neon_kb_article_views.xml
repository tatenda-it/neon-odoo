<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        M2 ships basic tree + form views for the article
        model. M3 layers on kanban + search filters +
        polished form.
    -->

    <record id="view_kb_article_tree" model="ir.ui.view">
        <field name="name">neon.kb.article.tree</field>
        <field name="model">neon.kb.article</field>
        <field name="arch" type="xml">
            <tree string="KB Articles"
                  decoration-muted="state == 'archived'"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'published'">
                <field name="name"/>
                <field name="category_id"/>
                <field name="author_id"/>
                <field name="state" widget="badge"/>
                <field name="last_updated"/>
                <field name="view_count" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_kb_article_form" model="ir.ui.view">
        <field name="name">neon.kb.article.form</field>
        <field name="model">neon.kb.article</field>
        <field name="arch" type="xml">
            <form string="KB Article">
                <header>
                    <button name="action_publish"
                            string="Publish"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_archive_article"
                            string="Archive"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'published'"/>
                    <button name="action_republish"
                            string="Republish"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'archived'"
                            groups="neon_core.group_neon_superuser,neon_training.group_neon_training_admin"/>
                    <button name="action_back_to_draft"
                            string="Back to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'published'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="Article title"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="category_id"
                                   options="{'no_create': True}"/>
                            <field name="code"/>
                            <field name="tag_ids"
                                   widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Metadata">
                            <field name="author_id"
                                   readonly="state != 'draft'"/>
                            <field name="published_by_id"
                                   readonly="1"/>
                            <field name="date_published"
                                   readonly="1"/>
                            <field name="last_updated"
                                   readonly="1"/>
                            <field name="view_count"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Summary">
                        <field name="summary" nolabel="1"
                               colspan="2"
                               placeholder="1-line description for list view + portal card (max 280 chars)."/>
                    </group>
                    <group string="Search Keywords">
                        <field name="keywords" nolabel="1"
                               colspan="2"
                               placeholder="Comma-separated keywords."/>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="body"
                                   widget="html"
                                   options="{'resizable': true}"/>
                        </page>
                        <page string="Attachments"
                              name="attachments">
                            <field name="attachment_ids"
                                   nolabel="1"
                                   readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="create_date"/>
                                    <field name="create_uid"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Related"
                              name="related"
                              groups="neon_core.group_neon_superuser,neon_training.group_neon_training_admin">
                            <group string="Related Certifications">
                                <field name="related_cert_type_ids"
                                       widget="many2many_tags"
                                       nolabel="1"
                                       options="{'no_create': True}"/>
                            </group>
                            <group string="Related SOPs">
                                <field name="related_sop_ids"
                                       nolabel="1"
                                       options="{'no_create': True}">
                                    <tree>
                                        <field name="name"/>
                                        <field name="equipment_or_procedure"/>
                                    </tree>
                                </field>
                            </group>
                            <group string="Related LMS Modules">
                                <field name="related_module_ids"
                                       nolabel="1"
                                       options="{'no_create': True}">
                                    <tree>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="track_id"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!--
        M3 kanban view grouped by category. Cards show
        name + summary + state badge + tags + author +
        last_updated + view_count.
    -->
    <record id="view_kb_article_kanban" model="ir.ui.view">
        <field name="name">neon.kb.article.kanban</field>
        <field name="model">neon.kb.article</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id"
                    sample="1"
                    quick_create="false">
                <field name="name"/>
                <field name="summary"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <field name="state"/>
                <field name="author_id"/>
                <field name="last_updated"/>
                <field name="view_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                    <br/>
                                    <span class="text-muted small">
                                        <field name="summary"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <span class="badge"
                                          t-attf-class="badge text-bg-#{record.state.raw_value == 'published' and 'success' or (record.state.raw_value == 'draft' and 'info' or 'secondary')}">
                                        <field name="state"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <field name="tag_ids"
                                       widget="many2many_tags"
                                       options="{'color_field': 'color'}"/>
                                <div class="d-flex justify-content-between mt-2 small text-muted">
                                    <span>
                                        <field name="author_id"
                                               widget="many2one_avatar_user"/>
                                    </span>
                                    <span>
                                        <i class="fa fa-clock-o me-1"
                                           role="img"
                                           aria-label="Last updated"
                                           title="Last updated"/>
                                        <field name="last_updated"/>
                                    </span>
                                </div>
                                <div class="mt-1 small text-muted"
                                     t-if="record.view_count.raw_value">
                                    <i class="fa fa-eye me-1"
                                       role="img"
                                       aria-label="Views"
                                       title="Views"/>
                                    <field name="view_count"/> views
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--
        M3 search view with 5 filter chips + 4 group-by
        options. Search input drives name_search across
        name + summary + keywords (model-side override).
    -->
    <record id="view_kb_article_search" model="ir.ui.view">
        <field name="name">neon.kb.article.search</field>
        <field name="model">neon.kb.article</field>
        <field name="arch" type="xml">
            <search string="KB Articles">
                <field name="name"
                       filter_domain="['|', '|',
                           ('name', 'ilike', self),
                           ('summary', 'ilike', self),
                           ('keywords', 'ilike', self)]"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <field name="author_id"/>
                <filter name="filter_published"
                        string="Published"
                        domain="[('state', '=', 'published')]"/>
                <filter name="filter_draft"
                        string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_my"
                        string="My Articles"
                        domain="[('author_id', '=', uid)]"/>
                <filter name="filter_this_month"
                        string="This Month"
                        domain="[('date_published', '&gt;=',
                                  (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_popular"
                        string="Popular"
                        domain="[('view_count', '&gt;=', 10)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category"
                            string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_tag"
                            string="Tag"
                            context="{'group_by': 'tag_ids'}"/>
                    <filter name="group_by_state"
                            string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_by_author"
                            string="Author"
                            context="{'group_by': 'author_id'}"/>
                    <filter name="group_by_last_updated"
                            string="Last Updated"
                            context="{'group_by': 'last_updated:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kb_article"
            model="ir.actions.act_window">
        <field name="name">KB Articles</field>
        <field name="res_model">neon.kb.article</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id"
               ref="view_kb_article_search"/>
        <field name="context">
            {'group_by': 'category_id'}
        </field>
    </record>

</odoo>

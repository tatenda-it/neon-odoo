<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        M5 record rule: learner can read only their own
        scenario completion records. Higher tiers (admin,
        signoff authorities) read all completions via the
        ACL CSV.
    -->
    <record id="rule_scenario_completion_learner_own"
            model="ir.rule">
        <field name="name">Learner sees own scenario completions</field>
        <field name="model_id" ref="model_neon_lms_scenario_completion"/>
        <field name="groups" eval="[(4, ref('neon_jobs.group_neon_jobs_crew'))]"/>
        <field name="domain_force">[('learner_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>

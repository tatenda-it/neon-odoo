<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_neon_lms_quiz_import_wizard_form"
            model="ir.ui.view">
        <field name="name">neon.lms.quiz.import.wizard.form</field>
        <field name="model">neon.lms.quiz.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Quiz Import">
                <sheet>
                    <group>
                        <group string="Target + Defaults">
                            <field name="module_id"
                                   options="{'no_create': True}"/>
                            <field name="default_question_type"/>
                            <field name="default_points"/>
                            <field name="mode" widget="radio"/>
                        </group>
                        <group string="CSV Source">
                            <field name="csv_file"
                                   filename="csv_file_name"/>
                            <field name="csv_file_name"
                                   invisible="1"/>
                            <field name="has_preview"
                                   invisible="1"/>
                            <field name="csv_data"
                                   widget="text"
                                   placeholder="Paste CSV here (or upload above). Header row required: question_text, type, option_1_text, option_1_correct, ... option_4_text, option_4_correct, points, explanation, correct_answer"/>
                        </group>
                    </group>
                    <group string="Preview">
                        <field name="preview_html"
                               nolabel="1" colspan="2"/>
                    </group>
                    <group string="Result"
                           invisible="not wizard_state">
                        <field name="wizard_state"
                               nolabel="1" colspan="2"
                               widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_parse_preview"
                            string="Preview"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_import"
                            string="Import"
                            type="object"
                            class="btn-success"
                            invisible="mode != 'import' or not has_preview"/>
                    <button special="cancel"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_neon_lms_quiz_import_wizard"
            model="ir.actions.act_window">
        <field name="name">Bulk Quiz Import</field>
        <field name="res_model">neon.lms.quiz.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>

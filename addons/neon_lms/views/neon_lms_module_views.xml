<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        LMS Admin Polish M2 module form + tree views.
        Phase 7e shipped neon.lms.module with no custom views;
        admin authoring went through stdlib slide.channel UI.
        M2 introduces a native module form with 4-tab notebook
        (Content / Quiz Questions / Scenarios / SOPs) so quiz
        + scenario records can be authored inline.
    -->

    <record id="view_neon_lms_module_tree" model="ir.ui.view">
        <field name="name">neon.lms.module.tree</field>
        <field name="model">neon.lms.module</field>
        <field name="arch" type="xml">
            <tree string="LMS Modules">
                <field name="code"/>
                <field name="name"/>
                <field name="track_id"/>
                <field name="sequence_in_track"/>
                <field name="min_quiz_score"/>
            </tree>
        </field>
    </record>

    <record id="view_neon_lms_module_form" model="ir.ui.view">
        <field name="name">neon.lms.module.form</field>
        <field name="model">neon.lms.module</field>
        <field name="arch" type="xml">
            <form string="LMS Module">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" placeholder="M01"/>
                        </h1>
                        <h2>
                            <field name="name"
                                   placeholder="Module name"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Track + Sequence">
                            <field name="track_id"
                                   options="{'no_create': True}"/>
                            <field name="channel_id"
                                   readonly="1"/>
                            <field name="sequence_in_track"/>
                            <field name="min_quiz_score"
                                   widget="percentage"/>
                        </group>
                        <group string="Prerequisites">
                            <field name="prerequisite_module_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <p class="text-muted">
                                Slide content lives on the
                                shared slide.channel
                                (Coursera-style program
                                channel). Edit slides via
                                Website Slides &gt; Channels
                                or the LMS dashboard slide
                                editor.
                            </p>
                        </page>
                        <page string="Quiz Questions"
                              name="quiz">
                            <div class="mb-2">
                                <button name="action_quick_create_mc"
                                        string="Add MC Question"
                                        type="object"
                                        class="btn-link"/>
                                <button name="action_quick_create_tf"
                                        string="Add T/F Question"
                                        type="object"
                                        class="btn-link"/>
                                <button name="action_quick_create_sa"
                                        string="Add Short Answer"
                                        type="object"
                                        class="btn-link"/>
                            </div>
                            <field name="quiz_question_ids"
                                   mode="tree,form">
                                <tree editable="bottom">
                                    <field name="sequence"
                                           widget="handle"/>
                                    <field name="question_text"
                                           required="1"/>
                                    <field name="question_type"/>
                                    <field name="points"/>
                                    <field name="active"
                                           widget="boolean_toggle"/>
                                </tree>
                                <form string="Quiz Question">
                                    <sheet>
                                        <group>
                                            <field name="question_type"/>
                                            <field name="points"/>
                                            <field name="active"/>
                                            <field name="sequence"/>
                                        </group>
                                        <group string="Question">
                                            <field name="question_text"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                        <group string="Options"
                                               invisible="question_type == 'short_answer'">
                                            <field name="option_ids"
                                                   nolabel="1"
                                                   colspan="2">
                                                <tree editable="bottom">
                                                    <field name="sequence"
                                                           widget="handle"/>
                                                    <field name="option_text"/>
                                                    <field name="is_correct"
                                                           widget="boolean_toggle"/>
                                                </tree>
                                            </field>
                                        </group>
                                        <group string="Correct Answer"
                                               invisible="question_type != 'short_answer'">
                                            <field name="correct_answer"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                        <group string="Explanation">
                                            <field name="explanation"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Scenarios"
                              name="scenarios">
                            <div class="mb-2">
                                <button name="action_quick_create_scenario"
                                        string="Add Scenario"
                                        type="object"
                                        class="btn-link"/>
                            </div>
                            <field name="practical_scenario_ids"
                                   mode="tree,form">
                                <tree editable="bottom">
                                    <field name="sequence"
                                           widget="handle"/>
                                    <field name="title"
                                           required="1"/>
                                    <field name="signoff_authority"/>
                                    <field name="active"
                                           widget="boolean_toggle"/>
                                </tree>
                                <form string="Practical Scenario">
                                    <sheet>
                                        <group>
                                            <field name="title"/>
                                            <field name="signoff_authority"/>
                                            <field name="active"/>
                                            <field name="sequence"/>
                                        </group>
                                        <group string="Description">
                                            <field name="description"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                        <group string="Expected Actions">
                                            <field name="expected_actions"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                        <group string="Evaluation Criteria">
                                            <field name="evaluation_criteria"
                                                   nolabel="1"
                                                   colspan="2"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="SOPs" name="sops">
                            <p class="text-muted">
                                Reference SOPs attached to
                                this module. SOPs don't gate
                                progression -- learner
                                reference only (M6).
                            </p>
                            <field name="sop_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_neon_lms_module"
            model="ir.actions.act_window">
        <field name="name">LMS Modules</field>
        <field name="res_model">neon.lms.module</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_neon_lms_modules"
              name="Modules"
              parent="menu_neon_lms_root"
              action="action_neon_lms_module"
              sequence="10"
              groups="neon_training.group_neon_training_admin"/>

</odoo>

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Odoo runtime artefacts (belong in the Docker volume, not the repo)
filestore/
sessions/
*.log

# Secrets
.env

# Odoo config — contains passwords, never commit
config/odoo.conf

# Python bytecode — never commit
__pycache__/
*.pyc
*.pyo

# Database backups — local only, never push to GitHub
backups/

# Browser-smoke artefacts — never commit. The venv carries the
# Playwright + bundled Chromium download (~250 MB); smoke-output
# carries per-run screenshots that bloat the repo and leak no
# value once a smoke has passed.
.claude/.venv-browser/
.claude/smoke-output/
